# Firebase Admin SDK
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# AI Configuration
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Deployment
DEPLOY_WEBHOOK_URL=https://api.vercel.com/v1/integrations/deploy/your-hook-id

# Google Indexing API
GOOGLE_INDEXING_EMAIL=your-indexing-service-account@your-project.iam.gserviceaccount.com
GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour indexing private key\n-----END PRIVATE KEY-----\n"

# News API (optional)
NEWS_API_KEY=

# Cricket API (optional)
CRICKET_API_KEY=your-cricket-api-key

