---
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: 'dashboard' | 'posts' | 'new-post' | 'categories';
}

const { title, activeNav } = Astro.props;

const navItems = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin/dashboard', icon: 'M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z' },
  { id: 'posts', label: 'All Posts', href: '/admin/posts', icon: 'M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z' },
  { id: 'new-post', label: 'New Post', href: '/admin/posts/new', icon: 'M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z' },
  { id: 'categories', label: 'Categories', href: '/admin/categories', icon: 'M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Mershal Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-gray-950 text-white min-h-screen flex">

  <!-- Sidebar -->
  <aside class="w-60 bg-gray-900 border-r border-gray-800 flex flex-col fixed h-full z-10">
    <div class="p-6 border-b border-gray-800">
      <a href="/" class="text-xl font-black text-rose-500">Mershal</a>
      <p class="text-xs text-gray-500 mt-0.5">Admin Panel</p>
    </div>

    <nav class="flex-1 p-4 space-y-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition ${
            activeNav === item.id
              ? 'bg-gray-800 text-white'
              : 'text-gray-400 hover:bg-gray-800 hover:text-white'
          }`}
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path d={item.icon} fill-rule="evenodd" clip-rule="evenodd" />
          </svg>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="p-4 border-t border-gray-800 space-y-1">
      <a href="/" target="_blank" class="flex items-center gap-2 px-3 py-2 text-gray-500 hover:text-gray-300 text-xs transition">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/><path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"/></svg>
        View Site
      </a>
      <button id="logout-btn" class="flex items-center gap-2 px-3 py-2 text-gray-500 hover:text-red-400 text-xs transition w-full text-left">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/></svg>
        Logout
      </button>
    </div>
  </aside>

  <!-- Page Content -->
  <main class="ml-60 flex-1 p-8">
    <slot />
  </main>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/admin/auth', { method: 'DELETE' });
      window.location.href = '/admin';
    });
  </script>
</body>
</html>
