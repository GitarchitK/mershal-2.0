---
import '../styles/global.css';

interface Props {
  title: string;
  activeNav?: 'dashboard' | 'posts' | 'new-post' | 'categories';
}

const { title, activeNav } = Astro.props;

const navItems = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin/dashboard', icon: 'M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z' },
  { id: 'posts', label: 'All Posts', href: '/admin/posts', icon: 'M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z' },
  { id: 'new-post', label: 'New Post', href: '/admin/posts/new', icon: 'M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z' },
  { id: 'categories', label: 'Categories', href: '/admin/categories', icon: 'M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z' },
];
---

<!DOCTYPE html>
<html lang="en" class="selection:bg-indigo-500/10 selection:text-indigo-600">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Mershal Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
    .font-outfit {
      font-family: 'Outfit', sans-serif;
    }
  </style>
</head>
<body class="bg-[#f8fafc] text-slate-800 min-h-screen flex antialiased overflow-x-hidden">

  <!-- Ambient Glow Backgrounds -->
  <div class="fixed top-[-10%] right-[-10%] w-[500px] h-[500px] rounded-full bg-indigo-500/3 blur-[120px] pointer-events-none z-0"></div>
  <div class="fixed bottom-[-10%] left-[-10%] w-[500px] h-[500px] rounded-full bg-violet-500/2 blur-[120px] pointer-events-none z-0"></div>

  <!-- Sidebar -->
  <aside class="w-64 bg-white border-r border-slate-200/80 flex flex-col fixed h-full z-20">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between">
      <div>
        <a href="/" class="text-2xl font-black font-outfit tracking-wider bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">Mershal</a>
        <p class="text-[10px] font-bold font-outfit uppercase tracking-widest text-slate-400 mt-0.5">Control Center</p>
      </div>
      <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.3)]"></div>
    </div>

    <nav class="flex-1 p-4 space-y-1.5">
      {navItems.map(item => {
        const isActive = activeNav === item.id;
        return (
          <a
            href={item.href}
            class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all duration-300 relative group ${
              isActive
                ? 'bg-indigo-50/70 text-indigo-600 border-l-2 border-indigo-600 pl-3.5 font-semibold'
                : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900 border-l-2 border-transparent hover:pl-3.5'
            }`}
          >
            <svg class={`w-4 h-4 flex-shrink-0 transition-transform duration-300 group-hover:scale-110 ${isActive ? 'text-indigo-600' : 'text-slate-400 group-hover:text-slate-600'}`} fill="currentColor" viewBox="0 0 20 20">
              <path d={item.icon} fill-rule="evenodd" clip-rule="evenodd" />
            </svg>
            <span class="font-outfit font-medium">{item.label}</span>
            {isActive && (
              <span class="absolute right-3 w-1.5 h-1.5 rounded-full bg-indigo-600 shadow-[0_0_6px_rgba(79,70,229,0.4)]"></span>
            )}
          </a>
        );
      })}
    </nav>

    <div class="p-4 border-t border-slate-100 space-y-1 bg-slate-50/40">
      <a href="/" target="_blank" class="flex items-center gap-2.5 px-3 py-2 text-slate-500 hover:text-slate-800 text-xs font-outfit font-medium transition-all group">
        <svg class="w-4 h-4 text-slate-400 group-hover:text-slate-600 transition-colors" fill="currentColor" viewBox="0 0 20 20">
          <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/>
          <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"/>
        </svg>
        View Website
      </a>
      <button id="logout-btn" class="flex items-center gap-2.5 px-3 py-2 text-slate-500 hover:text-red-600 text-xs font-outfit font-medium transition-all w-full text-left cursor-pointer group">
        <svg class="w-4 h-4 text-slate-400 group-hover:text-red-500 transition-colors" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd" />
        </svg>
        Sign Out
      </button>
    </div>
  </aside>

  <!-- Page Content -->
  <main class="ml-64 flex-1 p-8 min-h-screen relative z-10 flex flex-col">
    <slot />
  </main>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/admin/auth', { method: 'DELETE' });
      window.location.href = '/admin';
    });
  </script>
</body>
</html>
