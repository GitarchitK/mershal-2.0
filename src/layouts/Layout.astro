---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import { adminDb } from '../lib/firebase-admin';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  image?: string;
  type?: string;
  author?: string;
  publishedAt?: string;
  modifiedAt?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Mershal delivers reviews, tutorials, and insights about AI tools, CRM software, digital marketing, SaaS, and productivity software.',
  canonicalUrl,
  image = 'https://mershal.in/og-default.png',
  type = 'website',
  author = 'Mershal Editorial Team',
  publishedAt,
  modifiedAt,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://mershal.in';
const currentUrl = canonicalUrl || Astro.url.href;
const fullTitle = title.includes('Mershal') ? title : `${title} | Mershal`;

// Load Google AdSense scripts dynamically
let adsenseHeaderCode = '';
let adsenseFooterCode = '';
let adsenseClientId = '';

if (adminDb) {
  try {
    const doc = await adminDb.collection('settings').doc('adsense').get();
    if (doc.exists) {
      const data = doc.data();
      adsenseHeaderCode = data?.header_code || '';
      adsenseFooterCode = data?.footer_code || '';
      
      // Extract client ID from headerCode if present
      const match = adsenseHeaderCode.match(/client=(ca-pub-\d+)/);
      if (match) {
        adsenseClientId = match[1];
        // Strip the main script tag to prevent it from loading synchronously
        adsenseHeaderCode = adsenseHeaderCode.replace(/<script[^>]*src="[^"]*adsbygoogle[^"]*"[^>]*><\/script>/gi, '');
      }
    }
  } catch (e) {
    console.error('Layout settings fetch error:', e);
  }
}

// Fallback client ID if not configured or in development
if (!adsenseClientId) {
  adsenseClientId = 'ca-pub-9426217436033785';
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="language" content="en" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
    <meta name="googlebot" content={noindex ? 'noindex' : 'index, follow'} />

    <!-- Canonical -->
    <link rel="canonical" href={currentUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Mershal" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {modifiedAt && <meta property="article:modified_time" content={modifiedAt} />}
    {type === 'article' && <meta property="article:author" content={author} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@mershal_in" />
    <meta name="twitter:creator" content="@archit_karmakar" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#8b0222" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
      />
    </noscript>

    <!-- AdSense Header Integration -->
    {adsenseHeaderCode && <Fragment set:html={adsenseHeaderCode} />}

    <!-- Lazy Loaded AdSense Script -->
    <script is:inline define:vars={{ adsenseClientId }}>
      (function() {
        var adsenseLoaded = false;
        function loadAdSense() {
          if (adsenseLoaded) return;
          adsenseLoaded = true;
          
          var script = document.createElement('script');
          script.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=' + adsenseClientId;
          script.async = true;
          script.crossOrigin = 'anonymous';
          document.head.appendChild(script);
          
          // Remove event listeners
          window.removeEventListener('scroll', loadAdSense);
          window.removeEventListener('mousemove', loadAdSense);
          window.removeEventListener('touchstart', loadAdSense);
        }
        
        // Load AdSense on user interaction (scroll, mouse movement, touch)
        window.addEventListener('scroll', loadAdSense, { passive: true });
        window.addEventListener('mousemove', loadAdSense, { passive: true });
        window.addEventListener('touchstart', loadAdSense, { passive: true });
        
        // Fallback: load after 4.5 seconds if no interaction
        setTimeout(loadAdSense, 4500);
      })();
    </script>

    <!-- Website Schema -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "NewsMediaOrganization",
      "name": "Mershal",
      "url": "https://mershal.in",
      "description": "Mershal delivers expert reviews, guides, and insights on AI tools, SaaS, productivity, and online business automation.",
      "inLanguage": "en-US",
      "publisher": {
        "@type": "Organization",
        "name": "Mershal",
        "url": "https://mershal.in",
        "logo": {
          "@type": "ImageObject",
          "url": "https://mershal.in/logo.png"
        }
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://mershal.in/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <!-- Breadcrumb / Page slot for extra head tags -->
    <slot name="head" />
  </head>
  <body class="bg-slate-50 font-sans antialiased text-slate-900 min-h-screen flex flex-col justify-between">
    <div class="flex-1">
      <slot />
    </div>
    
    <!-- AdSense Footer Integration -->
    {adsenseFooterCode && <div class="container mx-auto px-4 py-4 max-w-7xl text-center"><Fragment set:html={adsenseFooterCode} /></div>}
    
    <CookieConsent />
  </body>
</html>
