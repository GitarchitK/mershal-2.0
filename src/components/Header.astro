---
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';

const categories = [
  { name: 'AI Tools', slug: '/category/ai-tools' },
  { name: 'SaaS Reviews', slug: '/category/saas-reviews' },
  { name: 'Productivity', slug: '/category/productivity' },
  { name: 'Freelancing', slug: '/category/freelancing' },
  { name: 'Online Business', slug: '/category/online-business' },
  { name: 'CRM', slug: '/category/crm' },
  { name: 'Marketing', slug: '/category/marketing' },
];

const today = new Date();
const shortDate = today.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<header class="sticky top-0 z-50 bg-white border-b border-slate-200/80 shadow-sm transition-all duration-300">
  <!-- Top decorative thin brand accent bar -->
  <div class="h-1 bg-gradient-to-r from-primary-crimson via-primary-gold to-primary-crimson w-full"></div>

  <!-- Row 1: Brand Logo & Primary Action Row -->
  <div class="border-b border-slate-100 bg-white">
    <div class="container mx-auto px-3 md:px-4 max-w-7xl flex items-center justify-between h-14 md:h-20">
      
      <!-- Left side: Hamburger + Logo + Horizontal Quick Links -->
      <div class="flex items-center gap-4">
        <!-- Mobile menu hamburger trigger -->
        <button id="mobile-menu-btn" class="lg:hidden text-slate-700 hover:text-primary-crimson p-2 rounded-lg hover:bg-slate-50 transition flex-shrink-0" aria-label="Open Menu">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Brand logo -->
        <a href="/" class="flex items-center flex-shrink-0 mr-1 md:mr-4">
          <Image src={logoImg} alt="Mershal Logo" width={180} height={36} class="mobile-logo-adjust max-w-[110px] sm:max-w-none object-contain transition-transform duration-300 hover:scale-[1.01]" />
        </a>

        <!-- Horizontal Quick Links with Icons (Desktop Only) -->
        <nav class="hidden lg:flex items-center gap-2">
          <!-- News / Home -->
          <a href="/" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider bg-primary-crimson/10 text-primary-crimson border border-primary-crimson/5 hover:bg-primary-crimson/15 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
            Home
          </a>
          <!-- SaaS Reviews -->
          <a href="/category/saas-reviews" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider text-slate-600 hover:text-primary-crimson hover:bg-slate-50 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499c.172-.376.702-.376.874 0l2.23 4.518 4.984.724c.414.06.58.567.28.854l-3.606 3.513 1.123 4.954c.093.412-.34.726-.708.532l-4.52-2.379-4.52 2.379c-.368.194-.801-.12-.708-.532l1.123-4.954-3.606-3.513c-.3-.287-.133-.794.28-.854l4.984-.724 2.23-4.52z" />
            </svg>
            SaaS Reviews
          </a>
          <!-- AI Tools -->
          <a href="/category/ai-tools" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider text-slate-600 hover:text-primary-crimson hover:bg-slate-50 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 21l8.988-8.102a.5.5 0 00-.327-.898h-4.834L14.187 7 5.2 15.102a.5.5 0 00.327.898h4.286z" />
            </svg>
            AI Tools
          </a>
          <!-- Productivity -->
          <a href="/category/productivity" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider text-slate-600 hover:text-primary-crimson hover:bg-slate-50 transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 002-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
            Productivity
          </a>
        </nav>
      </div>

      <!-- Right side: Search Bar + CTA -->
      <div class="flex items-center gap-2 md:gap-3 flex-shrink-0">
        <!-- Search trigger box (Desktop) / Search trigger icon (Mobile) -->
        <div class="relative flex-shrink-0">
          <div id="search-trigger-bar" class="hidden md:flex items-center gap-2.5 bg-slate-100 hover:bg-slate-200/60 border border-slate-200/50 rounded-full px-4 py-2 w-44 lg:w-56 cursor-pointer transition-colors duration-150">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <span class="text-xs text-slate-400 select-none">Search Mershal...</span>
          </div>
          <button id="search-trigger-mobile" class="md:hidden text-slate-500 hover:text-primary-crimson p-2 rounded-lg hover:bg-slate-50 transition flex-shrink-0" aria-label="Search">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </button>
        </div>

        <!-- Subscribe Button (Hidden on Mobile) -->
        <a href="/newsletter" class="hidden sm:flex items-center gap-1.5 bg-primary-crimson hover:bg-primary-crimson/95 text-white text-xs font-black uppercase tracking-wider px-4 py-2.5 rounded-lg shadow-sm hover:shadow transition-all flex-shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <span>Subscribe</span>
        </a>
      </div>

    </div>
  </div>

  <!-- Row 2: Secondary Category Navigation Bar -->
  <div class="bg-slate-50 border-b border-slate-200/60 py-2">
    <div class="container mx-auto px-4 max-w-7xl flex items-center justify-between min-w-0">
      
      <!-- Scrollable Categories Menu (with swiping for mobile) -->
      <nav class="flex-1 min-w-0 overflow-x-auto whitespace-nowrap scrollbar-none flex items-center gap-1 px-3">
        {categories.map(cat => (
          <a
            href={cat.slug}
            class="px-3.5 py-1 text-xs font-black uppercase tracking-wider text-slate-600 hover:text-primary-crimson transition-all duration-150 flex-shrink-0"
          >
            {cat.name}
          </a>
        ))}
      </nav>

      <!-- Right dots placeholder/extra options -->
      <div class="flex-shrink-0 pl-3.5 border-l border-slate-200 text-slate-400 hover:text-primary-crimson transition-colors cursor-pointer" aria-label="More categories">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
        </svg>
      </div>

    </div>
  </div>

  <!-- Mobile Dropdown Navigation Drawer -->
  <div id="mobile-nav" class="lg:hidden hidden border-t border-slate-100 bg-white shadow-inner max-h-[80vh] overflow-y-auto">
    <div class="p-4 space-y-1">
      {categories.map(cat => (
        <a href={cat.slug} class="block px-4 py-3 rounded-lg text-sm font-black uppercase tracking-wide text-slate-700 hover:bg-slate-50 hover:text-primary-crimson transition">
          {cat.name}
        </a>
      ))}
    </div>
  </div>

  <!-- Search Modal Backdrop Overlay -->
  <div id="search-modal" class="fixed inset-0 z-[100] bg-slate-900/60 backdrop-blur-sm flex items-start justify-center pt-[10vh] px-4 hidden">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-xl overflow-hidden border border-slate-100 animate-in fade-in zoom-in-95 duration-200">
      <div class="p-4 border-b border-slate-100 flex items-center gap-3 bg-slate-50">
        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder="Search AI Tools, reviews, guides..."
          class="flex-1 bg-transparent text-sm focus:outline-none text-slate-800 placeholder-slate-400"
          autocomplete="off"
        />
        <button id="close-search" class="text-xs font-semibold text-slate-400 hover:text-slate-600 bg-slate-200/50 hover:bg-slate-200 px-2.5 py-1.5 rounded-md transition">
          Esc
        </button>
      </div>
      <div id="search-results" class="max-h-[350px] overflow-y-auto p-2 divide-y divide-slate-50 empty:hidden">
        <!-- Results populated dynamically via client scripts -->
      </div>
      <div id="search-empty" class="p-8 text-center text-slate-400 text-sm">
        Type to search articles...
      </div>
    </div>
  </div>
</header>

<script>
  // Dynamic mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');

  mobileBtn?.addEventListener('click', () => {
    mobileNav?.classList.toggle('hidden');
  });

  // Modal Search Mechanics
  const searchTriggerBar = document.getElementById('search-trigger-bar');
  const searchTriggerMobile = document.getElementById('search-trigger-mobile');
  const searchModal = document.getElementById('search-modal');
  const closeSearch = document.getElementById('close-search');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLDivElement;
  const searchEmpty = document.getElementById('search-empty') as HTMLDivElement;

  function openSearch() {
    searchModal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => searchInput?.focus(), 50);
  }

  function closeSearchModal() {
    searchModal?.classList.add('hidden');
    document.body.style.overflow = '';
    if (searchInput) searchInput.value = '';
    if (searchResults) searchResults.innerHTML = '';
    if (searchEmpty) {
      searchEmpty.textContent = 'Type to search articles...';
      searchEmpty.classList.remove('hidden');
    }
  }

  searchTriggerBar?.addEventListener('click', openSearch);
  searchTriggerMobile?.addEventListener('click', openSearch);
  closeSearch?.addEventListener('click', closeSearchModal);
  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal) closeSearchModal();
  });

  // Global escape key handler
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearchModal();
  });

  // Simple client-side search lookup using Firestore query or a JSON search index endpoint
  let articlesIndex: any[] = [];
  let isFetchingIndex = false;

  async function fetchSearchIndex() {
    if (articlesIndex.length > 0 || isFetchingIndex) return;
    isFetchingIndex = true;
    try {
      // Query standard articles lists from the server dynamic endpoint
      const response = await fetch('/api/articles');
      if (response.ok) {
        articlesIndex = await response.json();
      }
    } catch (err) {
      console.error('Failed to load search index:', err);
    } finally {
      isFetchingIndex = false;
    }
  }

  searchInput?.addEventListener('focus', fetchSearchIndex);
  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    if (!q) {
      searchResults.innerHTML = '';
      searchEmpty.textContent = 'Type to search articles...';
      searchEmpty.classList.remove('hidden');
      return;
    }

    const matches = articlesIndex.filter(art => 
      art.title?.toLowerCase().includes(q) || 
      art.excerpt?.toLowerCase().includes(q) ||
      art.tags?.some((t: string) => t.toLowerCase().includes(q))
    );

    if (matches.length === 0) {
      searchResults.innerHTML = '';
      searchEmpty.textContent = `No results found for "${q}"`;
      searchEmpty.classList.remove('hidden');
      return;
    }

    searchEmpty.classList.add('hidden');
    searchResults.innerHTML = matches.slice(0, 5).map(art => `
      <a href="/articles/${art.slug}" class="block p-3 rounded-lg hover:bg-slate-50 transition-colors">
        <span class="text-xs uppercase font-extrabold text-primary-crimson tracking-wider">${art.category || 'Article'}</span>
        <h4 class="text-sm font-bold text-slate-800 line-clamp-1 mt-0.5">${art.title}</h4>
        <p class="text-xs text-slate-400 line-clamp-1 mt-0.5">${art.excerpt}</p>
      </a>
    `).join('');
  });
</script>

<style>
  .mobile-logo-adjust {
    height: 28px !important;
    width: auto !important;
  }
  @media (min-width: 768px) {
    .mobile-logo-adjust {
      height: 36px !important;
    }
  }
</style>
