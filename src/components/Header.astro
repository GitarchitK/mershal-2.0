---
import { getCurrentWeather, getWeatherEmoji } from '../lib/weather';

const categories = [
  { name: 'Home', slug: '/' },
  { name: 'Tutorials', slug: '/category/tutorials' },
  { name: 'Programming', slug: '/category/programming' },
  { name: 'Tech News', slug: '/category/technology' },
];

// Fetch weather data
const weatherData = await getCurrentWeather('Kolkata');
const currentTemp = weatherData?.current.temp_c || 25;
const weatherEmoji = weatherData ? getWeatherEmoji(weatherData.current.condition.text) : '🌤️';
const humidity = weatherData?.current.humidity || 65;
const windSpeed = weatherData?.current.wind_kph || 12;
const condition = weatherData?.current.condition.text || 'Partly Cloudy';

// Get current day name
const today = new Date();
const dayName = today.toLocaleDateString('en-US', { weekday: 'long' });
const shortDate = today.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
const year = today.getFullYear();
---

<header class="bg-white shadow-md sticky top-0 z-50">
  <!-- Top Info Bar -->
  <div class="bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
    <div class="container mx-auto px-4 py-2 md:py-2.5">
      <div class="flex items-center justify-between">
        <!-- Left: Date & Time -->
        <div class="flex items-center gap-3 md:gap-5">
          <!-- Day & Date -->
          <div class="flex items-center gap-1.5 md:gap-2">
            <svg class="w-4 h-4 md:w-5 md:h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
            </svg>
            <div class="text-xs md:text-sm">
              <span id="live-day" class="font-semibold text-gray-800 hidden sm:inline">{dayName}</span>
              <span class="text-gray-600">{shortDate}, {year}</span>
            </div>
          </div>
          
          <span class="text-gray-300 hidden md:inline">|</span>
          
          <!-- Time -->
          <div class="flex items-center gap-1.5 md:gap-2">
            <svg class="w-4 h-4 md:w-5 md:h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            <span id="live-time" class="font-mono font-medium text-gray-800 text-xs md:text-sm">--:--:--</span>
          </div>
        </div>
        
        <!-- Right: Weather -->
        <div class="flex items-center gap-3 md:gap-5">
          <!-- Weather Icon & Temp -->
          <div class="flex items-center gap-1.5 md:gap-2">
            <span class="text-xl md:text-2xl">{weatherEmoji}</span>
            <div class="text-xs md:text-sm">
              <span id="temperature" class="font-bold text-gray-800">{currentTemp}°C</span>
              <span class="text-gray-500 hidden sm:inline">{condition}</span>
            </div>
          </div>
          
          <span class="text-gray-300 hidden lg:inline">|</span>
          
          <!-- Humidity & Wind -->
          <div class="hidden lg:flex items-center gap-4 text-xs text-gray-600">
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M14.243 5.757a6 6 0 10-.986 9.284 1 1 0 111.087 1.678A8 8 0 1118 10a3 3 0 01-4.8 2.401A4 4 0 1114 10a1 1 0 102 0c0-1.537-.586-3.07-1.757-4.243zM12 17a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
              </svg>
              <span>{humidity}%</span>
            </div>
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.5 16a3.5 3.5 0 01-.369-6.98 4 4 0 117.753-1.977A4.5 4.5 0 1113.5 16h-8z" clip-rule="evenodd"/>
              </svg>
              <span>{windSpeed} km/h</span>
            </div>
          </div>
          
          <!-- Location -->
          <div class="hidden md:flex items-center gap-1 text-xs text-gray-500">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            <span>Kolkata</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4">
    <!-- Main Header -->
    <div class="flex items-center justify-between py-3 border-b border-gray-200">
      <!-- Mobile Menu Button (3 dots) -->
      <button 
        id="mobile-menu-btn"
        class="lg:hidden text-gray-700 hover:text-red-600 p-2"
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/>
        </svg>
      </button>

      <!-- Desktop Links -->
      <div class="hidden lg:flex items-center gap-4 text-sm">
        <a href="/about" class="text-gray-600 hover:text-red-600 transition font-medium">About</a>
        <span class="text-gray-300">|</span>
        <a href="/contact" class="text-gray-600 hover:text-red-600 transition font-medium">Contact</a>
        <span class="text-gray-300">|</span>
        <a href="/privacy" class="text-gray-600 hover:text-red-600 transition font-medium">Privacy</a>
        <span class="text-gray-300">|</span>
        <a href="/terms" class="text-gray-600 hover:text-red-600 transition font-medium">Terms</a>
      </div>
      
      <a href="/" class="flex flex-col items-center">
        <span class="text-3xl font-bold text-red-600 logo-font tracking-tighter">Mershal</span>
        <span class="text-xs text-gray-500 -mt-1">by Navroll Studio</span>
      </a>
      
      <div class="w-10 lg:w-auto"></div>
    </div>
    
    <!-- Navigation -->
    <nav class="flex items-center gap-6 py-3 overflow-x-auto scrollbar-hide">
      {categories.map(cat => (
        <a 
          href={cat.slug} 
          class="text-gray-700 hover:text-red-600 whitespace-nowrap font-semibold text-sm uppercase tracking-wide transition-colors"
        >
          {cat.name}
        </a>
      ))}
      <button class="text-gray-700 hover:text-red-600">▼</button>
    </nav>
  </div>

  <!-- Mobile Sidebar Menu -->
  <div 
    id="mobile-sidebar"
    class="fixed inset-0 bg-black bg-opacity-60 z-50 hidden backdrop-blur-sm"
  >
    <div 
      id="sidebar-content"
      class="fixed left-0 top-0 bottom-0 w-80 bg-gradient-to-b from-white to-gray-50 shadow-2xl transform -translate-x-full transition-transform duration-300 ease-out"
    >
      <!-- Sidebar Header -->
      <div class="bg-gradient-to-r from-rose-600 via-pink-600 to-rose-700 text-white p-6 shadow-lg">
        <div class="flex items-center justify-between mb-2">
          <div>
            <h2 class="text-2xl font-bold logo-font tracking-tight">Mershal</h2>
            <p class="text-sm text-rose-100 font-medium">Tech Blog by Archit Karmakar</p>
          </div>
          <button 
            id="close-sidebar"
            class="text-white hover:bg-white hover:bg-opacity-20 p-2 rounded-lg transition-all"
            aria-label="Close menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Sidebar Content -->
      <div class="overflow-y-auto h-full pb-24 bg-white">
        <!-- Categories -->
        <div class="px-5 py-6 border-b border-gray-100">
          <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4 px-2">Browse</h3>
          <nav class="space-y-1">
            <a href="/" class="flex items-center gap-3 text-gray-700 hover:text-rose-600 hover:bg-rose-50 px-4 py-3 rounded-xl transition-all group">
              <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center group-hover:bg-rose-100 transition-all">
                <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
                </svg>
              </div>
              <span class="font-semibold text-sm">Home</span>
            </a>
            <a href="/category/tutorials" class="flex items-center gap-3 text-gray-700 hover:text-rose-600 hover:bg-rose-50 px-4 py-3 rounded-xl transition-all group">
              <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center group-hover:bg-rose-100 transition-all">
                <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
                </svg>
              </div>
              <span class="font-semibold text-sm">Tutorials</span>
            </a>
            <a href="/category/programming" class="flex items-center gap-3 text-gray-700 hover:text-rose-600 hover:bg-rose-50 px-4 py-3 rounded-xl transition-all group">
              <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center group-hover:bg-rose-100 transition-all">
                <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="font-semibold text-sm">Programming</span>
            </a>
            <a href="/category/technology" class="flex items-center gap-3 text-gray-700 hover:text-rose-600 hover:bg-rose-50 px-4 py-3 rounded-xl transition-all group">
              <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center group-hover:bg-rose-100 transition-all">
                <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="font-semibold text-sm">Tech News</span>
            </a>
          </nav>
        </div>

        <!-- Pages -->
        <div class="px-5 py-6 border-b border-gray-100">
          <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4 px-2">Explore</h3>
          <nav class="space-y-1">
            <a href="/about" class="flex items-center gap-3 text-gray-700 hover:text-rose-600 hover:bg-rose-50 px-4 py-3 rounded-xl transition-all group">
              <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center group-hover:bg-rose-100 transition-all">
                <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="font-semibold text-sm">About Archit</span>
            </a>
            <a href="/contact" class="flex items-center gap-3 text-gray-700 hover:text-rose-600 hover:bg-rose-50 px-4 py-3 rounded-xl transition-all group">
              <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center group-hover:bg-rose-100 transition-all">
                <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                  <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                </svg>
              </div>
              <span class="font-semibold text-sm">Contact</span>
            </a>
            <a href="/advertise" class="flex items-center gap-3 text-gray-700 hover:text-rose-600 hover:bg-rose-50 px-4 py-3 rounded-xl transition-all group">
              <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center group-hover:bg-rose-100 transition-all">
                <svg class="w-5 h-5 text-rose-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 2a2 2 0 00-2 2v11a3 3 0 106 0V4a2 2 0 00-2-2H4zm1 14a1 1 0 100-2 1 1 0 000 2zm5-1.757l4.9-4.9a2 2 0 000-2.828L13.485 5.1a2 2 0 00-2.828 0L10 5.757v8.486zM16 18H9.071l6-6H16a2 2 0 012 2v2a2 2 0 01-2 2z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="font-semibold text-sm">Advertise</span>
            </a>
          </nav>
        </div>

        <!-- Legal -->
        <div class="px-5 py-6">
          <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4 px-2">Legal</h3>
          <nav class="space-y-1">
            <a href="/privacy" class="flex items-center gap-3 text-gray-600 hover:text-rose-600 hover:bg-gradient-to-r hover:from-rose-50 hover:to-pink-50 px-4 py-2.5 rounded-xl transition-all text-sm">
              <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
              </svg>
              <span class="font-medium">Privacy Policy</span>
            </a>
            <a href="/terms" class="flex items-center gap-3 text-gray-600 hover:text-rose-600 hover:bg-gradient-to-r hover:from-rose-50 hover:to-pink-50 px-4 py-2.5 rounded-xl transition-all text-sm">
              <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
              </svg>
              <span class="font-medium">Terms of Service</span>
            </a>
            <a href="/cookies" class="flex items-center gap-3 text-gray-600 hover:text-rose-600 hover:bg-gradient-to-r hover:from-rose-50 hover:to-pink-50 px-4 py-2.5 rounded-xl transition-all text-sm">
              <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
                <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/>
              </svg>
              <span class="font-medium">Cookie Policy</span>
            </a>
          </nav>
        </div>

        <!-- Footer in Sidebar -->
        <div class="px-5 py-6 bg-gradient-to-br from-gray-50 to-rose-50 border-t border-gray-100">
          <p class="text-xs text-gray-500 text-center mb-2">© 2026 Mershal</p>
          <p class="text-xs text-gray-400 text-center">Developed by <span class="text-rose-600 font-medium">Navroll Studio</span></p>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  function updateDateTime() {
    const now = new Date();
    
    // Format time
    const timeOptions: Intl.DateTimeFormatOptions = { 
      hour: '2-digit', 
      minute: '2-digit', 
      second: '2-digit',
      hour12: true 
    };
    const timeStr = now.toLocaleTimeString('en-US', timeOptions);
    
    // Update DOM
    const timeElement = document.getElementById('live-time');
    if (timeElement) timeElement.textContent = timeStr;
  }
  
  // Update immediately
  updateDateTime();
  
  // Update every second
  setInterval(updateDateTime, 1000);

  // Mobile sidebar functionality
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileSidebar = document.getElementById('mobile-sidebar');
  const sidebarContent = document.getElementById('sidebar-content');
  const closeSidebar = document.getElementById('close-sidebar');

  function openSidebar() {
    if (mobileSidebar && sidebarContent) {
      mobileSidebar.classList.remove('hidden');
      setTimeout(() => {
        sidebarContent.classList.remove('-translate-x-full');
      }, 10);
    }
  }

  function closeSidebarFunc() {
    if (sidebarContent && mobileSidebar) {
      sidebarContent.classList.add('-translate-x-full');
      setTimeout(() => {
        mobileSidebar.classList.add('hidden');
      }, 300);
    }
  }

  mobileMenuBtn?.addEventListener('click', openSidebar);
  closeSidebar?.addEventListener('click', closeSidebarFunc);
  
  // Close sidebar when clicking outside
  mobileSidebar?.addEventListener('click', (e) => {
    if (e.target === mobileSidebar) {
      closeSidebarFunc();
    }
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .logo-font {
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
    letter-spacing: -0.05em;
  }
</style>
