---
import { getCurrentWeather, getWeatherEmoji } from '../lib/weather';

const categories = [
  { name: 'Home', slug: '/' },
  { name: 'India', slug: '/category/india' },
  { name: 'World', slug: '/category/world' },
  { name: 'Politics', slug: '/category/politics' },
  { name: 'Sports', slug: '/category/sports' },
  { name: 'Technology', slug: '/category/technology' },
  { name: 'Business', slug: '/category/business' },
  { name: 'IPL', slug: '/ipl' }
];

// Fetch weather data
const weatherData = await getCurrentWeather('Kolkata');
const currentTemp = weatherData?.current.temp_c || 25;
const weatherEmoji = weatherData ? getWeatherEmoji(weatherData.current.condition.text) : '🌤️';
const humidity = weatherData?.current.humidity || 65;
const windSpeed = weatherData?.current.wind_kph || 12;
const condition = weatherData?.current.condition.text || 'Partly Cloudy';

// Get current day name
const today = new Date();
const dayName = today.toLocaleDateString('en-US', { weekday: 'long' });
const shortDate = today.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
const year = today.getFullYear();
---

<header class="bg-white shadow-md sticky top-0 z-50">
  <!-- Top Info Bar -->
  <div class="bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
    <div class="container mx-auto px-4 py-2 md:py-2.5">
      <div class="flex items-center justify-between">
        <!-- Left: Date & Time -->
        <div class="flex items-center gap-3 md:gap-5">
          <!-- Day & Date -->
          <div class="flex items-center gap-1.5 md:gap-2">
            <svg class="w-4 h-4 md:w-5 md:h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
            </svg>
            <div class="text-xs md:text-sm">
              <span id="live-day" class="font-semibold text-gray-800 hidden sm:inline">{dayName}</span>
              <span class="text-gray-600">{shortDate}, {year}</span>
            </div>
          </div>
          
          <span class="text-gray-300 hidden md:inline">|</span>
          
          <!-- Time -->
          <div class="flex items-center gap-1.5 md:gap-2">
            <svg class="w-4 h-4 md:w-5 md:h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            <span id="live-time" class="font-mono font-medium text-gray-800 text-xs md:text-sm">--:--:--</span>
          </div>
        </div>
        
        <!-- Right: Weather -->
        <div class="flex items-center gap-3 md:gap-5">
          <!-- Weather Icon & Temp -->
          <div class="flex items-center gap-1.5 md:gap-2">
            <span class="text-xl md:text-2xl">{weatherEmoji}</span>
            <div class="text-xs md:text-sm">
              <span id="temperature" class="font-bold text-gray-800">{currentTemp}°C</span>
              <span class="text-gray-500 hidden sm:inline">{condition}</span>
            </div>
          </div>
          
          <span class="text-gray-300 hidden lg:inline">|</span>
          
          <!-- Humidity & Wind -->
          <div class="hidden lg:flex items-center gap-4 text-xs text-gray-600">
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M14.243 5.757a6 6 0 10-.986 9.284 1 1 0 111.087 1.678A8 8 0 1118 10a3 3 0 01-4.8 2.401A4 4 0 1114 10a1 1 0 102 0c0-1.537-.586-3.07-1.757-4.243zM12 17a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
              </svg>
              <span>{humidity}%</span>
            </div>
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.5 16a3.5 3.5 0 01-.369-6.98 4 4 0 117.753-1.977A4.5 4.5 0 1113.5 16h-8z" clip-rule="evenodd"/>
              </svg>
              <span>{windSpeed} km/h</span>
            </div>
          </div>
          
          <!-- Location -->
          <div class="hidden md:flex items-center gap-1 text-xs text-gray-500">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            <span>Kolkata</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4">
    <!-- Main Header -->
    <div class="flex items-center justify-between py-3 border-b border-gray-200">
      <!-- Hidden hamburger menu - using bottom nav instead -->
      <div class="hidden lg:flex items-center gap-4 text-sm">
        <a href="/about" class="text-gray-600 hover:text-red-600 transition font-medium">About</a>
        <span class="text-gray-300">|</span>
        <a href="/contact" class="text-gray-600 hover:text-red-600 transition font-medium">Contact</a>
        <span class="text-gray-300">|</span>
        <a href="/privacy" class="text-gray-600 hover:text-red-600 transition font-medium">Privacy</a>
        <span class="text-gray-300">|</span>
        <a href="/terms" class="text-gray-600 hover:text-red-600 transition font-medium">Terms</a>
      </div>
      <div class="w-8 lg:hidden"></div>
      
      <a href="/" class="flex flex-col items-center">
        <span class="text-3xl font-bold text-red-600 logo-font tracking-tighter">Mershal</span>
        <span class="text-xs text-gray-500 -mt-1">by Navroll Studio</span>
      </a>
      
      <div class="flex items-center gap-3 hidden">
        <button class="px-4 py-1.5 bg-white border-2 border-red-600 text-red-600 rounded-full text-sm font-semibold hover:bg-red-600 hover:text-white transition">
          APP ↓
        </button>
        <button class="text-2xl text-gray-700 hover:text-red-600">👤</button>
      </div>
    </div>
    
    <!-- Navigation -->
    <nav class="flex items-center gap-6 py-3 overflow-x-auto scrollbar-hide">
      {categories.map(cat => (
        <a 
          href={cat.slug} 
          class="text-gray-700 hover:text-red-600 whitespace-nowrap font-semibold text-sm uppercase tracking-wide transition-colors"
        >
          {cat.name}
        </a>
      ))}
      <button class="text-gray-700 hover:text-red-600">▼</button>
    </nav>
  </div>
</header>

<script>
  function updateDateTime() {
    const now = new Date();
    
    // Format time
    const timeOptions: Intl.DateTimeFormatOptions = { 
      hour: '2-digit', 
      minute: '2-digit', 
      second: '2-digit',
      hour12: true 
    };
    const timeStr = now.toLocaleTimeString('en-US', timeOptions);
    
    // Update DOM
    const timeElement = document.getElementById('live-time');
    if (timeElement) timeElement.textContent = timeStr;
  }
  
  // Update immediately
  updateDateTime();
  
  // Update every second
  setInterval(updateDateTime, 1000);
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .logo-font {
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
    letter-spacing: -0.05em;
  }
</style>
