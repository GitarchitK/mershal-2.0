---
// Breaking News Ticker Component
---

<div class="bg-red-600 text-white py-2 overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="flex items-center">
      <div class="flex-shrink-0 font-bold text-sm uppercase tracking-wider mr-4 bg-white text-red-600 px-3 py-1 rounded">
        Breaking News
      </div>
      <div class="flex-1 overflow-hidden">
        <div id="breaking-news-ticker" class="whitespace-nowrap animate-scroll">
          <span class="inline-block px-8">Loading breaking news...</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-scroll {
    animation: scroll 60s linear infinite;
  }

  .animate-scroll:hover {
    animation-play-state: paused;
  }
</style>

<script>
  async function fetchBreakingNews() {
    try {
      const response = await fetch('/api/breaking-news');
      
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      
      const data = await response.json();
      console.log('Breaking news data:', data);
      
      if (data.headlines && data.headlines.length > 0) {
        const ticker = document.getElementById('breaking-news-ticker');
        if (ticker) {
          // Duplicate headlines for seamless loop
          const headlines = data.headlines.concat(data.headlines);
          ticker.innerHTML = headlines
            .map((headline) => `<span class="inline-block px-8">🔴 ${headline}</span>`)
            .join('');
        }
      } else {
        console.warn('No headlines received');
      }
    } catch (error) {
      console.error('Failed to fetch breaking news:', error);
      // Show default headlines on error
      const ticker = document.getElementById('breaking-news-ticker');
      if (ticker) {
        const defaultHeadlines = [
          'Breaking: Global markets show strong performance',
          'Technology sector announces major innovations',
          'International leaders meet for climate summit',
          'Sports world celebrates record-breaking achievements',
          'Economic indicators point to steady growth',
          'New developments in space exploration'
        ];
        const headlines = defaultHeadlines.concat(defaultHeadlines);
        ticker.innerHTML = headlines
          .map((headline) => `<span class="inline-block px-8">🔴 ${headline}</span>`)
          .join('');
      }
    }
  }

  // Fetch on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fetchBreakingNews);
  } else {
    fetchBreakingNews();
  }

  // Refresh every 5 minutes
  setInterval(fetchBreakingNews, 5 * 60 * 1000);
</script>
