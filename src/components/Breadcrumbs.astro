---
interface Props {
  category: string;
  categorySlug: string;
  title: string;
}

const { category, categorySlug, title } = Astro.props;
---

<nav class="flex items-center gap-2 text-xs font-semibold text-slate-500 font-sans py-3" aria-label="Breadcrumb">
  <a href="/" class="hover:text-primary-crimson transition-colors">Home</a>
  <svg class="w-3 h-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  <a href={`/category/${categorySlug}`} class="hover:text-primary-crimson uppercase tracking-wider text-[10px] font-black transition-colors">{category}</a>
  <svg class="w-3 h-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  <span class="text-slate-700 truncate max-w-[200px] md:max-w-xs">{title}</span>
</nav>
