---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

{items && items.length > 0 && (
  <div class="mt-12 pt-8 border-t border-slate-200 font-sans">
    <h3 class="text-xl md:text-2xl font-black font-serif text-slate-900 mb-6 flex items-center gap-2">
      <span class="w-1.5 h-5 bg-primary-gold rounded-full inline-block"></span>
      Frequently Asked Questions
    </h3>
    
    <div class="space-y-4">
      {items.map((item, index) => (
        <details class="group bg-white rounded-xl border border-slate-100 shadow-sm p-4 [&_summary::-webkit-details-marker]:hidden" open={index === 0}>
          <summary class="flex items-center justify-between cursor-pointer focus:outline-none">
            <h4 class="text-sm md:text-base font-bold text-slate-800 group-hover:text-primary-crimson transition-colors pr-4">
              {item.question}
            </h4>
            <span class="ml-1.5 flex-shrink-0 rounded-full bg-slate-50 p-1 text-slate-400 group-open:rotate-180 transition duration-300">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </summary>
          
          <div class="mt-3 border-t border-slate-50 pt-3 text-slate-600 text-sm leading-relaxed">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
)}
