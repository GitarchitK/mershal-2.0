---
const categories = [
  { name: 'AI Tools', slug: '/category/ai-tools' },
  { name: 'SaaS Reviews', slug: '/category/saas-reviews' },
  { name: 'Productivity', slug: '/category/productivity' },
  { name: 'Freelancing', slug: '/category/freelancing' },
  { name: 'Online Business', slug: '/category/online-business' },
  { name: 'CRM', slug: '/category/crm' },
  { name: 'Marketing', slug: '/category/marketing' },
];
---

<footer class="bg-slate-950 text-slate-400 py-16 border-t-2 border-primary-gold mt-16 font-sans">
  <div class="container mx-auto px-4 max-w-7xl">
    
    <!-- Top section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      
      <!-- Brand column -->
      <div class="space-y-4">
        <a href="/" class="block">
          <img src="/logo.png" alt="Mershal Logo" width="120" height="24" class="h-6 w-auto object-contain brightness-0 invert" />
        </a>
        <p class="text-sm text-slate-400 leading-relaxed">
          Mershal is a premium digital publication delivering expert analysis, tool recommendations, and software comparisons to scale business automation and online growth.
        </p>
        <!-- Social rows -->
        <div class="flex gap-3">
          <a href="#" class="w-8 h-8 rounded-lg bg-slate-800 hover:bg-primary-crimson hover:text-white transition flex items-center justify-center text-slate-400" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-8 h-8 rounded-lg bg-slate-800 hover:bg-primary-crimson hover:text-white transition flex items-center justify-center text-slate-400" aria-label="Twitter">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      <!-- Categories Links -->
      <div>
        <h3 class="text-xs font-black uppercase tracking-wider text-slate-200 mb-4 font-serif">Categories</h3>
        <ul class="space-y-2.5">
          {categories.map(cat => (
            <li>
              <a href={cat.slug} class="hover:text-primary-gold text-sm transition-colors duration-150">
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="text-xs font-black uppercase tracking-wider text-slate-200 mb-4 font-serif">Company</h3>
        <ul class="space-y-2.5">
          <li><a href="/about" class="hover:text-primary-gold text-sm transition">About Us</a></li>
          <li><a href="/contact" class="hover:text-primary-gold text-sm transition">Contact Us</a></li>
          <li><a href="/advertise" class="hover:text-primary-gold text-sm transition">Advertise</a></li>
          <li><a href="/sitemap.xml" class="hover:text-primary-gold text-sm transition">XML Sitemap</a></li>
        </ul>
      </div>

      <!-- Contact details -->
      <div>
        <h3 class="text-xs font-black uppercase tracking-wider text-slate-200 mb-4 font-serif">Legal & Contact</h3>
        <ul class="space-y-2.5 mb-4">
          <li><a href="/privacy" class="hover:text-primary-gold text-sm transition">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-primary-gold text-sm transition">Terms of Service</a></li>
          <li><a href="/cookies" class="hover:text-primary-gold text-sm transition">Cookie Settings</a></li>
        </ul>
        <div class="text-xs text-slate-500 space-y-1.5 pt-2 border-t border-slate-900">
          <p>📧 <a href="mailto:contact@mershal.in" class="hover:text-primary-gold transition">contact@mershal.in</a></p>
          <p>📧 <a href="mailto:advertise@mershal.in" class="hover:text-primary-gold transition">advertise@mershal.in</a></p>
        </div>
      </div>
    </div>

    <!-- Bottom copyrights row -->
    <div class="border-t border-slate-900 pt-8 mt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500">
      <p class="text-center md:text-left">
        © 2026 Mershal. All rights reserved. Content is for educational and informational reviews.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/about" class="hover:text-slate-300 transition">About</a>
        <a href="/contact" class="hover:text-slate-300 transition">Contact</a>
        <a href="/privacy" class="hover:text-slate-300 transition">Privacy</a>
        <a href="/terms" class="hover:text-slate-300 transition">Terms</a>
      </div>
    </div>
  </div>
</footer>
