---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BreakingNews from '../components/BreakingNews.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Contact Mershal - Get in Touch" description="Contact Archit Karmakar - Questions about tutorials, collaborations, or just want to say hi? We'd love to hear from you!">
  <Header />
  <BreakingNews />
  
  <main class="container mx-auto px-4 py-8 pb-20 md:pb-8">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold mb-6">Get in Touch</h1>
      
      <p class="text-xl text-gray-600 mb-8">
        Got a question? Want to collaborate? Just want to say hi? Drop me a message!
      </p>

      <div class="bg-white rounded-lg shadow-lg p-8">
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Your Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
              placeholder="What's your name?"
              required
            />
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
              placeholder="your@email.com"
              required
            />
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">Subject</label>
            <select 
              id="subject" 
              name="subject" 
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            >
              <option value="">Select a topic...</option>
              <option value="question">Question about a tutorial</option>
              <option value="collaboration">Collaboration opportunity</option>
              <option value="feedback">Feedback or suggestions</option>
              <option value="bug">Report a bug</option>
              <option value="other">Something else</option>
            </select>
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="6" 
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
              placeholder="Tell me what's on your mind..."
              required
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            class="w-full bg-red-600 text-white py-3 px-6 rounded-lg font-semibold hover:bg-red-700 transition"
          >
            Send Message 🚀
          </button>
        </form>

        <div class="mt-8 pt-8 border-t border-gray-200">
          <h3 class="text-lg font-semibold mb-4">Other ways to reach me:</h3>
          <ul class="space-y-3 text-gray-600">
            <li>📧 Email: <a href="mailto:contact@mershal.in" class="text-red-600 hover:underline">contact@mershal.in</a></li>
            <li>💬 Social media links coming soon!</li>
          </ul>
        </div>
      </div>

      <div class="mt-12 bg-gray-100 rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Quick FAQ</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold">Can I guest post on Mershal?</h3>
            <p class="text-gray-600">Absolutely! Send me a message with your pitch and we'll discuss.</p>
          </div>
          <div>
            <h3 class="font-semibold">Can I use your tutorials in my project?</h3>
            <p class="text-gray-600">Yes! All tutorials are free to use. A credit link back is appreciated but not required.</p>
          </div>
          <div>
            <h3 class="font-semibold">Do you offer coding mentorship?</h3>
            <p class="text-gray-600">I occasionally take on mentees. Contact me with details about what you'd like to learn!</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>