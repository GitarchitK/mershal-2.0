---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout
  title="Contact Us — Mershal World News"
  description="Get in touch with the Mershal editorial team. Submit news tips, corrections, advertising enquiries, or general questions."
>
  <Header />

  <main class="bg-white pb-20 md:pb-8">

    <!-- Page Header -->
    <div class="bg-red-600 text-white">
      <div class="container mx-auto px-4 max-w-5xl py-12">
        <p class="text-red-200 text-xs font-bold uppercase tracking-widest mb-2">Reach Out</p>
        <h1 class="text-4xl md:text-5xl font-black leading-tight mb-4">Contact Us</h1>
        <p class="text-red-100 text-lg max-w-2xl leading-relaxed">
          News tips, corrections, advertising, or general enquiries — we'd love to hear from you.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-black text-gray-900 mb-1 pb-2 border-b-4 border-red-600 inline-block">Send a Message</h2>

          <form id="contact-form" class="mt-6 space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1.5">Full Name *</label>
                <input
                  type="text" id="name" name="name" required
                  placeholder="Your full name"
                  class="w-full border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:border-red-600 focus:ring-1 focus:ring-red-600 transition"
                />
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1.5">Email Address *</label>
                <input
                  type="email" id="email" name="email" required
                  placeholder="your@email.com"
                  class="w-full border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:border-red-600 focus:ring-1 focus:ring-red-600 transition"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1.5">Subject *</label>
              <select
                id="subject" name="subject" required
                class="w-full border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:border-red-600 focus:ring-1 focus:ring-red-600 transition bg-white"
              >
                <option value="">Select a subject</option>
                <option value="news-tip">News Tip / Story Suggestion</option>
                <option value="correction">Correction or Clarification</option>
                <option value="advertising">Advertising Enquiry</option>
                <option value="partnership">Partnership / Collaboration</option>
                <option value="general">General Question</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-bold text-gray-700 uppercase tracking-wider mb-1.5">Message *</label>
              <textarea
                id="message" name="message" rows="6" required
                placeholder="Write your message here..."
                class="w-full border border-gray-300 px-4 py-3 text-sm text-gray-900 focus:outline-none focus:border-red-600 focus:ring-1 focus:ring-red-600 transition resize-none"
              ></textarea>
            </div>

            <div id="form-status" class="hidden p-4 text-sm font-medium"></div>

            <button
              type="submit" id="submit-btn"
              class="w-full bg-red-600 hover:bg-red-700 text-white py-3.5 text-sm font-black uppercase tracking-widest transition"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">

          <!-- Contact Details -->
          <div class="border border-gray-200">
            <div class="bg-gray-900 text-white px-4 py-3">
              <p class="text-xs font-black uppercase tracking-widest">Contact Details</p>
            </div>
            <div class="divide-y divide-gray-100">
              <div class="px-4 py-4">
                <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">General Enquiries</p>
                <a href="mailto:contact@mershal.in" class="text-sm text-red-600 hover:underline font-medium">contact@mershal.in</a>
              </div>
              <div class="px-4 py-4">
                <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">News Tips</p>
                <a href="mailto:tips@mershal.in" class="text-sm text-red-600 hover:underline font-medium">tips@mershal.in</a>
              </div>
              <div class="px-4 py-4">
                <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Advertising</p>
                <a href="mailto:advertise@mershal.in" class="text-sm text-red-600 hover:underline font-medium">advertise@mershal.in</a>
              </div>
              <div class="px-4 py-4">
                <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Response Time</p>
                <p class="text-sm text-gray-700 font-medium">Within 24–48 hours</p>
              </div>
            </div>
          </div>

          <!-- News Tips -->
          <div class="border border-red-200 bg-red-50">
            <div class="bg-red-600 text-white px-4 py-3">
              <p class="text-xs font-black uppercase tracking-widest">Submit a News Tip</p>
            </div>
            <div class="p-4">
              <p class="text-sm text-gray-700 leading-relaxed mb-3">
                Have a story we should cover? Send us your tip with as much detail as possible. All sources are kept confidential.
              </p>
              <a href="mailto:tips@mershal.in" class="block text-center bg-red-600 hover:bg-red-700 text-white py-2.5 text-xs font-black uppercase tracking-widest transition">
                Submit a Tip
              </a>
            </div>
          </div>

          <!-- Advertise -->
          <div class="border border-gray-200">
            <div class="bg-gray-900 text-white px-4 py-3">
              <p class="text-xs font-black uppercase tracking-widest">Advertise with Us</p>
            </div>
            <div class="p-4">
              <p class="text-sm text-gray-600 leading-relaxed mb-3">
                Reach thousands of engaged readers. View our advertising plans starting at ₹299/month.
              </p>
              <a href="/advertise" class="block text-center border border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white py-2.5 text-xs font-black uppercase tracking-widest transition">
                View Plans
              </a>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.textContent = 'Sending...';
    btn.disabled = true;

    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const subject = (document.getElementById('subject') as HTMLSelectElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    // Open mailto as fallback (no backend needed)
    const mailtoLink = `mailto:contact@mershal.in?subject=${encodeURIComponent(subject + ' - ' + name)}&body=${encodeURIComponent('Name: ' + name + '\nEmail: ' + email + '\n\n' + message)}`;
    window.location.href = mailtoLink;

    status.textContent = '✓ Your email client has been opened. Please send the email to complete your message.';
    status.className = 'p-4 text-sm font-medium bg-green-50 border border-green-200 text-green-800';
    status.classList.remove('hidden');

    btn.textContent = 'Send Message';
    btn.disabled = false;
  });
</script>
