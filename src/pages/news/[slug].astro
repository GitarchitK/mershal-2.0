---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BottomNav from '../../components/BottomNav.astro';
import { adminDb } from '../../lib/firebase-admin';

const { slug } = Astro.params;

let article: any = null;
let relatedArticles: any[] = [];

if (adminDb && slug) {
  try {
    const snapshot = await adminDb.collection('posts')
      .where('slug', '==', slug)
      .where('status', '==', 'published')
      .limit(1)
      .get();
    
    if (!snapshot.empty) {
      const doc = snapshot.docs[0];
      article = { id: doc.id, ...doc.data() };
      
      // Fetch related articles
      const relatedSnapshot = await adminDb.collection('posts')
        .where('category', '==', article.category)
        .where('status', '==', 'published')
        .limit(4)
        .get();
      
      relatedArticles = relatedSnapshot.docs
        .filter(d => d.id !== doc.id)
        .map(d => ({ id: d.id, ...d.data() }));
    }
  } catch (error) {
    console.error('Error fetching article:', error);
  }
}

if (!article) {
  return Astro.redirect('/404');
}

const publishedDate = article.publishedAt ? new Date(article.publishedAt) : new Date();
const updatedDate = article.updatedAt ? new Date(article.updatedAt) : publishedDate;

// Google News structured data
const structuredData = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": article.title,
  "description": article.excerpt,
  "image": article.featuredImage,
  "datePublished": publishedDate.toISOString(),
  "dateModified": updatedDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": article.author || "Mershal Editorial Team"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Mershal News",
    "logo": {
      "@type": "ImageObject",
      "url": "https://mershal.in/logo.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://mershal.in/news/${article.slug}`
  },
  "articleSection": article.category,
  "inLanguage": article.language || "en",
  "spatialCoverage": article.country || "US"
};
---

<Layout title={article.seoTitle || article.title} description={article.seoDescription || article.excerpt}>
  <!-- Google News Structured Data -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)}></script>
  
  <Header />
  
  <main class="bg-gray-50">
    <!-- Article Container -->
    <article class="container mx-auto px-4 py-8 pb-20 md:pb-8">
      <div class="max-w-4xl mx-auto">
        <!-- Breadcrumb -->
        <nav class="mb-6 text-sm">
          <ol class="flex items-center gap-2 text-gray-600">
            <li><a href="/" class="hover:text-red-600 transition">Home</a></li>
            <li>›</li>
            <li><a href={`/category/${article.category}`} class="hover:text-red-600 transition capitalize">{article.category}</a></li>
            <li>›</li>
            <li class="text-gray-400 truncate">{article.title}</li>
          </ol>
        </nav>

        <!-- Category Badge -->
        <div class="mb-4">
          <a href={`/category/${article.category}`} class="inline-block bg-red-600 text-white px-4 py-1.5 text-xs font-bold uppercase tracking-wider rounded hover:bg-red-700 transition">
            {article.category}
          </a>
        </div>
        
        <!-- Article Title -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
          {article.title}
        </h1>
        
        <!-- Article Meta -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 mb-8 pb-6 border-b border-gray-200">
          <div class="flex items-center gap-2">
            <div class="w-10 h-10 bg-red-600 rounded-full flex items-center justify-center text-white font-bold">
              {article.author.charAt(0)}
            </div>
            <div>
              <p class="font-semibold text-gray-900">{article.author}</p>
              <p class="text-xs text-gray-500">Staff Writer</p>
            </div>
          </div>
          <span class="hidden md:inline text-gray-300">|</span>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
            </svg>
            <time datetime={publishedDate.toISOString()}>
              {publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <span class="hidden md:inline text-gray-300">|</span>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            <span>{article.readingTime} min read</span>
          </div>
        </div>
        
        <!-- Featured Image -->
        <figure class="mb-10 -mx-4 md:mx-0">
          <img 
            src={article.featuredImage} 
            alt={article.title}
            class="w-full rounded-none md:rounded-2xl shadow-2xl"
          />
        </figure>
        
        <!-- Article Excerpt -->
        <div class="bg-gradient-to-r from-red-50 to-orange-50 border-l-4 border-red-600 p-6 md:p-8 mb-10 rounded-r-xl">
          <p class="text-xl md:text-2xl text-gray-800 font-medium leading-relaxed italic">
            {article.excerpt}
          </p>
        </div>
        
        <!-- Article Content -->
        <div class="prose prose-lg md:prose-xl max-w-none mb-12">
          <div 
            set:html={article.content} 
            class="article-content text-gray-800 leading-relaxed"
          />
        </div>
        
        <!-- Tags -->
        {article.tags && article.tags.length > 0 && (
          <div class="mb-10 pb-10 border-b border-gray-200">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Topics</h3>
            <div class="flex flex-wrap gap-2">
              {article.tags.map((tag: string) => (
                <a 
                  href={`/search?q=${tag}`}
                  class="px-4 py-2 bg-white border border-gray-200 text-gray-700 rounded-full text-sm hover:border-red-600 hover:text-red-600 transition"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}
        
        <!-- Share Section -->
        <div class="mb-12 pb-10 border-b border-gray-200">
          <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Share This Article</h3>
          <div class="flex flex-wrap gap-2">
            <button class="flex items-center gap-2 px-3 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </button>
            <button class="flex items-center gap-2 px-3 py-2 bg-sky-500 text-white rounded-lg hover:bg-sky-600 transition text-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
              Twitter
            </button>
            <button class="flex items-center gap-2 px-3 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition text-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              WhatsApp
            </button>
          </div>
        </div>
        
        <!-- Related Articles -->
        {relatedArticles.length > 0 && (
          <section>
            <h2 class="text-3xl font-bold mb-8 text-gray-900">Related Articles</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {relatedArticles.map(related => (
                <a href={`/news/${related.slug}`} class="group bg-white rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300">
                  <div class="relative overflow-hidden">
                    <img 
                      src={related.featuredImage} 
                      alt={related.title} 
                      class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                    <div class="absolute top-3 left-3">
                      <span class="bg-red-600 text-white px-3 py-1 text-xs font-bold uppercase rounded">
                        {related.category}
                      </span>
                    </div>
                  </div>
                  <div class="p-5">
                    <h3 class="font-bold text-lg text-gray-900 line-clamp-2 group-hover:text-red-600 transition mb-2">
                      {related.title}
                    </h3>
                    <p class="text-sm text-gray-600 line-clamp-2 mb-3">{related.excerpt}</p>
                    <div class="flex items-center text-xs text-gray-500">
                      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                      </svg>
                      {related.readingTime} min read
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </article>
  </main>
  
  <Footer />
  <BottomNav />
</Layout>

<style>
  /* Modern Professional Article Styles */
  .article-content {
    font-size: 1.125rem;
    line-height: 1.9;
    color: #1f2937;
    max-width: 75ch;
    margin: 0 auto;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  
  /* Enhanced Typography */
  .article-content h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: #111827;
    line-height: 1.2;
    letter-spacing: -0.025em;
  }
  
  .article-content h2 {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    color: #111827;
    line-height: 1.3;
    letter-spacing: -0.02em;
    position: relative;
    padding-bottom: 1rem;
  }
  
  .article-content h2::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, #dc2626, #f87171);
    border-radius: 2px;
  }
  
  .article-content h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    color: #1f2937;
    line-height: 1.4;
    position: relative;
    padding-left: 1rem;
  }
  
  .article-content h3::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 4px;
    height: 1.5rem;
    background: #dc2626;
    border-radius: 2px;
  }
  
  /* Enhanced Paragraphs */
  .article-content p {
    margin-bottom: 1.75rem;
    color: #374151;
    font-size: 1.125rem;
    line-height: 1.8;
    text-align: justify;
  }
  
  .article-content p:first-of-type {
    font-size: 1.25rem;
    font-weight: 500;
    color: #1f2937;
    line-height: 1.7;
  }
  
  /* Professional Lists */
  .article-content ul,
  .article-content ol {
    margin-bottom: 2rem;
    padding-left: 0;
  }
  
  .article-content li {
    margin-bottom: 1rem;
    color: #4b5563;
    font-size: 1.0625rem;
    line-height: 1.7;
    padding: 0.75rem 1.5rem;
    background: #f9fafb;
    border-radius: 0.5rem;
    border-left: 4px solid #dc2626;
    position: relative;
  }
  
  .article-content ol li {
    counter-increment: item;
    padding-left: 3rem;
  }
  
  .article-content ol li::before {
    content: counter(item);
    position: absolute;
    left: 1rem;
    top: 0.75rem;
    background: #dc2626;
    color: white;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 600;
  }
  
  .article-content ol {
    counter-reset: item;
  }
  
  /* Enhanced Links */
  .article-content a {
    color: #dc2626;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
    padding: 0.1rem 0.2rem;
    border-radius: 0.25rem;
  }
  
  .article-content a:hover {
    color: #b91c1c;
    background: #fef2f2;
    border-bottom-color: #dc2626;
  }
  
  /* Premium Blockquotes */
  .article-content blockquote {
    border: none;
    margin: 3rem 0;
    padding: 2.5rem;
    background: linear-gradient(135deg, #fef2f2 0%, #fff5f5 100%);
    border-radius: 1rem;
    position: relative;
    box-shadow: 0 10px 40px rgba(220, 38, 38, 0.1);
    border-left: 6px solid #dc2626;
  }
  
  .article-content blockquote::before {
    content: '"';
    position: absolute;
    top: -1rem;
    left: 1.5rem;
    font-size: 6rem;
    color: #dc2626;
    opacity: 0.15;
    font-family: Georgia, serif;
    line-height: 1;
  }
  
  .article-content blockquote p {
    margin-bottom: 0;
    color: #4b5563;
    font-size: 1.25rem;
    line-height: 1.7;
    font-style: italic;
    font-weight: 500;
  }
  
  /* Enhanced Text Emphasis */
  .article-content b,
  .article-content strong {
    font-weight: 700;
    color: #111827;
    background: linear-gradient(120deg, rgba(220, 38, 38, 0.1) 0%, rgba(220, 38, 38, 0.05) 100%);
    padding: 0.15rem 0.3rem;
    border-radius: 0.25rem;
    border-bottom: 2px solid rgba(220, 38, 38, 0.2);
  }
  
  .article-content em {
    font-style: italic;
    color: #6b7280;
  }
  
  /* Professional Callout Boxes */
  .article-content .key-point {
    background: linear-gradient(135deg, #f0fdf4 0%, #ecfccb 100%);
    border: 1px solid #bbf7d0;
    border-left: 6px solid #22c55e;
    padding: 2rem;
    margin: 3rem 0;
    border-radius: 0.75rem;
    box-shadow: 0 4px 20px rgba(34, 197, 94, 0.1);
  }
  
  .article-content .key-point::before {
    content: '💡';
    font-size: 1.5rem;
    margin-right: 0.5rem;
  }
  
  .article-content .key-point p {
    margin-bottom: 0;
    color: #166534;
    font-weight: 600;
    font-size: 1.125rem;
  }
  
  /* Important/Warning Callout */
  .article-content .important {
    background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
    border: 1px solid #fecaca;
    border-left: 6px solid #dc2626;
    padding: 2rem;
    margin: 3rem 0;
    border-radius: 0.75rem;
    box-shadow: 0 4px 20px rgba(220, 38, 38, 0.1);
  }
  
  .article-content .important::before {
    content: '⚠️';
    font-size: 1.5rem;
    margin-right: 0.5rem;
  }
  
  .article-content .important p {
    margin-bottom: 0;
    color: #991b1b;
    font-weight: 600;
    font-size: 1.125rem;
  }
  
  /* Info Callout */
  .article-content .info-box {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 1px solid #bfdbfe;
    border-left: 6px solid #3b82f6;
    padding: 2rem;
    margin: 3rem 0;
    border-radius: 0.75rem;
    box-shadow: 0 4px 20px rgba(59, 130, 246, 0.1);
  }
  
  .article-content .info-box::before {
    content: 'ℹ️';
    font-size: 1.5rem;
    margin-right: 0.5rem;
  }
  
  .article-content .info-box p {
    margin-bottom: 0;
    color: #1e40af;
    font-weight: 600;
    font-size: 1.125rem;
  }
  
  /* Numbered highlights */
  .article-content .highlight-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: linear-gradient(135deg, #dc2626, #f87171);
    color: white;
    font-weight: 700;
    border-radius: 50%;
    margin-right: 1rem;
    font-size: 1rem;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
  }
  
  /* Professional Stats Box */
  .article-content .stats-box {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin: 3rem 0;
    padding: 2.5rem;
    background: linear-gradient(135deg, #1f2937 0%, #374151 100%);
    border-radius: 1rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  }
  
  .article-content .stats-box .stat {
    text-align: center;
    color: white;
    padding: 1rem;
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }
  
  .article-content .stats-box .stat-value {
    font-size: 2.5rem;
    font-weight: 800;
    color: #f87171;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  
  .article-content .stat-label {
    font-size: 0.875rem;
    color: #d1d5db;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Enhanced Images */
  .article-content img {
    border-radius: 1rem;
    margin: 3rem 0;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.15);
    width: 100%;
    max-width: 100%;
    transition: transform 0.3s ease;
  }
  
  .article-content img:hover {
    transform: scale(1.02);
  }
  
  /* Professional Dividers */
  .article-content hr {
    border: none;
    margin: 4rem 0;
    position: relative;
    height: 1px;
    background: linear-gradient(90deg, transparent, #e5e7eb, transparent);
  }
  
  .article-content hr::after {
    content: '◆';
    position: absolute;
    top: -0.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: white;
    color: #dc2626;
    padding: 0 1rem;
    font-size: 1rem;
  }
  
  /* Quote Attribution */
  .article-content .quote-author {
    text-align: right;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: #6b7280;
    font-style: normal;
    font-weight: 600;
  }
  
  .article-content .quote-author::before {
    content: '— ';
  }
  
  /* Timeline Elements */
  .article-content .timeline {
    position: relative;
    padding-left: 2rem;
    margin: 3rem 0;
  }
  
  .article-content .timeline::before {
    content: '';
    position: absolute;
    left: 0.75rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, #dc2626, #f87171);
  }
  
  .article-content .timeline-item {
    position: relative;
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 0.75rem;
    border-left: 4px solid #dc2626;
  }
  
  .article-content .timeline-item::before {
    content: '';
    position: absolute;
    left: -2.25rem;
    top: 1.5rem;
    width: 1rem;
    height: 1rem;
    background: #dc2626;
