---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import BreakingNews from '../../components/BreakingNews.astro';
import Footer from '../../components/Footer.astro';
import BottomNav from '../../components/BottomNav.astro';
import { adminDb } from '../../lib/firebase-admin';

const { slug } = Astro.params;

let article: any = null;
let relatedArticles: any[] = [];

if (adminDb && slug) {
  try {
    const snapshot = await adminDb.collection('posts')
      .where('slug', '==', slug)
      .where('status', '==', 'published')
      .limit(1)
      .get();
    
    if (!snapshot.empty) {
      const doc = snapshot.docs[0];
      article = { id: doc.id, ...doc.data() };
      
      // Fetch related articles
      const relatedSnapshot = await adminDb.collection('posts')
        .where('category', '==', article.category)
        .where('status', '==', 'published')
        .limit(4)
        .get();
      
      relatedArticles = relatedSnapshot.docs
        .filter(d => d.id !== doc.id)
        .map(d => ({ id: d.id, ...d.data() }));
    }
  } catch (error) {
    console.error('Error fetching article:', error);
  }
}

if (!article) {
  return Astro.redirect('/404');
}

const publishedDate = article.publishedAt?.toDate?.() || new Date();
---

<Layout title={article.seoTitle || article.title} description={article.seoDescription || article.excerpt}>
  <Fragment slot="head">
    <!-- Schema.org JSON-LD for Article -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": article.title,
      "description": article.excerpt,
      "image": article.featuredImage,
      "datePublished": publishedDate.toISOString(),
      "dateModified": publishedDate.toISOString(),
      "author": {
        "@type": "Person",
        "name": article.author
      },
      "publisher": {
        "@type": "Organization",
        "name": "Mershal",
        "logo": {
          "@type": "ImageObject",
          "url": "https://mershal.in/logo.svg"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://mershal.in/news/${slug}`
      }
    })} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`https://mershal.in/news/${slug}`} />
    <meta property="og:title" content={article.title} />
    <meta property="og:description" content={article.excerpt} />
    <meta property="og:image" content={article.featuredImage} />
    <meta property="article:published_time" content={publishedDate.toISOString()} />
    <meta property="article:author" content={article.author} />
    <meta property="article:section" content={article.category} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={`https://mershal.in/news/${slug}`} />
    <meta name="twitter:title" content={article.title} />
    <meta name="twitter:description" content={article.excerpt} />
    <meta name="twitter:image" content={article.featuredImage} />
  </Fragment>
  
  <Header />
  <BreakingNews />
  
  <main class="bg-gray-50">
    <!-- Article Container -->
    <article class="container mx-auto px-4 py-8 pb-20 md:pb-8">
      <div class="max-w-4xl mx-auto">
        <!-- Breadcrumb -->
        <nav class="mb-6 text-sm">
          <ol class="flex items-center gap-2 text-gray-600">
            <li><a href="/" class="hover:text-red-600 transition">Home</a></li>
            <li>›</li>
            <li><a href={`/category/${article.category}`} class="hover:text-red-600 transition capitalize">{article.category}</a></li>
            <li>›</li>
            <li class="text-gray-400 truncate">{article.title}</li>
          </ol>
        </nav>

        <!-- Category Badge -->
        <div class="mb-4">
          <a href={`/category/${article.category}`} class="inline-block bg-red-600 text-white px-4 py-1.5 text-xs font-bold uppercase tracking-wider rounded hover:bg-red-700 transition">
            {article.category}
          </a>
        </div>
        
        <!-- Article Title -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
          {article.title}
        </h1>
        
        <!-- Article Meta -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 mb-8 pb-6 border-b border-gray-200">
          <div class="flex items-center gap-2">
            <div class="w-10 h-10 bg-gradient-to-br from-rose-500 to-pink-600 rounded-xl flex items-center justify-center text-white font-black text-sm shadow-sm">
              AK
            </div>
            <div>
              <p class="font-semibold text-gray-900">{article.author}</p>
              <p class="text-xs text-gray-500">Full Stack Developer</p>
            </div>
          </div>
          <span class="hidden md:inline text-gray-300">|</span>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
            </svg>
            <time datetime={publishedDate.toISOString()}>
              {publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <span class="hidden md:inline text-gray-300">|</span>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            <span>{article.readingTime} min read</span>
          </div>
        </div>
        
        <!-- Featured Image -->
        <figure class="mb-10 -mx-4 md:mx-0">
          <img 
            src={article.featuredImage} 
            alt={article.title}
            class="w-full rounded-none md:rounded-2xl shadow-2xl"
          />
        </figure>
        
        <!-- Article Excerpt -->
        <div class="bg-gradient-to-r from-red-50 to-orange-50 border-l-4 border-red-600 p-6 md:p-8 mb-10 rounded-r-xl">
          <p class="text-xl md:text-2xl text-gray-800 font-medium leading-relaxed italic">
            {article.excerpt}
          </p>
        </div>
        
        <!-- Article Content -->
        <div class="prose prose-lg md:prose-xl max-w-none mb-12">
          <div 
            set:html={article.content} 
            class="article-content text-gray-800 leading-relaxed"
          />
        </div>
        
        <!-- Author Card -->
        <div class="mb-10 p-6 bg-white rounded-2xl border border-gray-100 shadow-sm flex flex-col sm:flex-row items-start gap-5">
          <div class="flex-shrink-0">
            <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-rose-500 to-pink-600 flex items-center justify-center shadow-md">
              <span class="text-2xl font-black text-white">AK</span>
            </div>
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <p class="font-bold text-gray-900">Archit Karmakar</p>
              <span class="text-xs bg-rose-100 text-rose-700 px-2 py-0.5 rounded-full font-medium">Author</span>
            </div>
            <p class="text-xs text-gray-500 mb-2">Full Stack Developer · Tech Enthusiast</p>
            <p class="text-sm text-gray-600 leading-relaxed">
              I build things for the web and write about what I learn. Mershal is my personal space for tutorials, deep dives, and honest takes on tech.
            </p>
            <a href="/about" class="inline-block mt-3 text-xs font-semibold text-rose-600 hover:text-rose-700 transition">
              More about me →
            </a>
          </div>
        </div>

        <!-- Tags -->
        {article.tags && article.tags.length > 0 && (
          <div class="mb-10 pb-10 border-b border-gray-200">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Topics</h3>
            <div class="flex flex-wrap gap-2">
              {article.tags.map((tag: string) => (
                <a 
                  href={`/search?q=${tag}`}
                  class="px-4 py-2 bg-white border border-gray-200 text-gray-700 rounded-full text-sm hover:border-red-600 hover:text-red-600 transition"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}
        
        <!-- Share Section -->
        <div class="mb-12 pb-10 border-b border-gray-200">
          <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Share This Article</h3>
          <div class="flex flex-wrap gap-2 sm:gap-3">
            <button class="flex items-center gap-1 sm:gap-2 px-3 sm:px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm sm:text-base">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              <span class="hidden xs:inline">Facebook</span>
            </button>
            <button class="flex items-center gap-1 sm:gap-2 px-3 sm:px-4 py-2 bg-sky-500 text-white rounded-lg hover:bg-sky-600 transition text-sm sm:text-base">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
              <span class="hidden xs:inline">Twitter</span>
            </button>
            <button class="flex items-center gap-1 sm:gap-2 px-3 sm:px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition text-sm sm:text-base">
              <svg class="w-4 h-4 sm:w-5 sm:h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              <span class="hidden xs:inline">WhatsApp</span>
            </button>
          </div>
        </div>
        
        <!-- Related Articles -->
        {relatedArticles.length > 0 && (
          <section>
            <h2 class="text-3xl font-bold mb-8 text-gray-900">Related Articles</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {relatedArticles.map(related => (
                <a href={`/news/${related.slug}`} class="group bg-white rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300">
                  <div class="relative overflow-hidden">
                    <img 
                      src={related.featuredImage} 
                      alt={related.title} 
                      class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                    <div class="absolute top-3 left-3">
                      <span class="bg-red-600 text-white px-3 py-1 text-xs font-bold uppercase rounded">
                        {related.category}
                      </span>
                    </div>
                  </div>
                  <div class="p-5">
                    <h3 class="font-bold text-lg text-gray-900 line-clamp-2 group-hover:text-red-600 transition mb-2">
                      {related.title}
                    </h3>
                    <p class="text-sm text-gray-600 line-clamp-2 mb-3">{related.excerpt}</p>
                    <div class="flex items-center text-xs text-gray-500">
                      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                      </svg>
                      {related.readingTime} min read
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </article>
  </main>
  
  <Footer />
  <BottomNav />
</Layout>

<script>
  // Add copy button to code blocks
  document.addEventListener('DOMContentLoaded', () => {
    const codeBlocks = document.querySelectorAll('.article-content pre');
    
    codeBlocks.forEach((block) => {
      // Create copy button
      const copyButton = document.createElement('button');
      copyButton.className = 'copy-code-btn';
      copyButton.innerHTML = `
        <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span class="copy-text">Copy</span>
      `;
      
      copyButton.addEventListener('click', async () => {
        const code = block.querySelector('code');
        const text = code?.textContent || '';
        
        try {
          await navigator.clipboard.writeText(text);
          copyButton.innerHTML = `
            <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span class="copy-text">Copied!</span>
          `;
          copyButton.classList.add('copied');
          
          setTimeout(() => {
            copyButton.innerHTML = `
              <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <span class="copy-text">Copy</span>
            `;
            copyButton.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
      
      if (block instanceof HTMLElement) {
        block.style.position = 'relative';
      }
      block.appendChild(copyButton);
    });
  });
</script>

<style>
  /* Modern Professional Article Styles */
  .article-content {
    font-size: 1.125rem;
    line-height: 1.9;
    color: #1f2937;
    max-width: 70ch;
    margin: 0 auto;
  }
  
  .article-content h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: #111827;
    line-height: 1.4;
    letter-spacing: -0.02em;
    position: relative;
    padding-bottom: 0.75rem;
  }
  
  .article-content h2::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, #dc2626, #f87171);
    border-radius: 2px;
  }
  
  .article-content h3 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #1f2937;
    line-height: 1.4;
  }
  
  .article-content p {
    margin-bottom: 1.75rem;
    color: #374151;
    font-size: 1.125rem;
    line-height: 1.9;
  }
  
  .article-content ul,
  .article-content ol {
    margin-bottom: 1.75rem;
    padding-left: 1.5rem;
  }
  
  .article-content li {
    margin-bottom: 0.75rem;
    color: #4b5563;
    font-size: 1.0625rem;
    line-height: 1.7;
    padding-left: 0.5rem;
  }
  
  .article-content li::marker {
    color: #dc2626;
  }
  
  .article-content a {
    color: #dc2626;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  
  .article-content a:hover {
    color: #b91c1c;
    background: #fef2f2;
  }
  
  .article-content blockquote {
    border: none;
    margin: 2.5rem 0;
    padding: 2rem;
    background: linear-gradient(135deg, #fef2f2 0%, #fff 100%);
    border-radius: 1rem;
    position: relative;
  }
  
  .article-content blockquote::before {
    content: '"';
    position: absolute;
    top: -0.5rem;
    left: 1rem;
    font-size: 5rem;
    color: #dc2626;
    opacity: 0.2;
    font-family: Georgia, serif;
    line-height: 1;
  }
  
  .article-content blockquote p {
    margin-bottom: 0;
    color: #4b5563;
    font-size: 1.125rem;
    line-height: 1.8;
    font-style: italic;
  }
  
  .article-content strong {
    font-weight: 600;
    color: #111827;
  }
  
  .article-content em {
    font-style: italic;
  }
  
  .article-content img {
    border-radius: 1rem;
    margin: 2.5rem 0;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    width: 100%;
    max-width: 100%;
  }
  
  .article-content hr {
    border: none;
    border-top: 2px solid #e5e7eb;
    margin: 3rem 0;
    position: relative;
  }
  
  .article-content hr::after {
    content: '';
    position: absolute;
    top: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 8px;
    background: #dc2626;
    border-radius: 4px;
  }
  
  /* Bold text emphasis */
  .article-content b,
  .article-content strong {
    font-weight: 700;
    color: #111827;
    background: linear-gradient(120deg, transparent 0%, transparent 0%, rgba(220, 38, 38, 0.1) 0%, rgba(220, 38, 38, 0.1) 100%);
    padding: 0.1rem 0.25rem;
    border-radius: 0.25rem;
  }
  
  /* Key point callout boxes */
  .article-content .key-point {
    background: linear-gradient(135deg, #f0fdf4 0%, #ecfccb 100%);
    border-left: 4px solid #22c55e;
    padding: 1.5rem 2rem;
    margin: 2rem 0;
    border-radius: 0 1rem 1rem 0;
  }
  
  .article-content .key-point p {
    margin-bottom: 0;
    color: #166534;
    font-weight: 600;
  }
  
  /* Warning/Important callout */
  .article-content .important {
    background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
    border-left: 4px solid #dc2626;
    padding: 1.5rem 2rem;
    margin: 2rem 0;
    border-radius: 0 1rem 1rem 0;
  }
  
  .article-content .important p {
    margin-bottom: 0;
    color: #991b1b;
    font-weight: 500;
  }
  
  /* Numbered highlights */
  .article-content .highlight-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: linear-gradient(135deg, #dc2626, #f87171);
    color: white;
    font-weight: 700;
    border-radius: 50%;
    margin-right: 0.75rem;
    font-size: 0.875rem;
    flex-shrink: 0;
  }
  
  /* Modern list items with bold starts */
  .article-content .modern-list li {
    display: flex;
    align-items: flex-start;
    margin-bottom: 1rem;
    padding: 0.75rem;
    background: #f9fafb;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }
  
  .article-content .modern-list li:hover {
    background: #f3f4f6;
    transform: translateX(0.25rem);
  }
  
  /* Stats box */
  .article-content .stats-box {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
    padding: 1.5rem;
    background: linear-gradient(135deg, #1f2937 0%, #374151 100%);
    border-radius: 1rem;
  }
  
  .article-content .stats-box .stat {
    text-align: center;
    color: white;
  }
  
  .article-content .stats-box .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: #f87171;
    line-height: 1;
  }
  
  .article-content .stats-box .stat-label {
    font-size: 0.875rem;
    color: #9ca3af;
    margin-top: 0.5rem;
  }
  
  /* Code blocks and pre-formatted text - Clean Professional Style */
  .article-content pre {
    position: relative;
    background: #0d1117;
    color: #e6edf3;
    padding: 1.25rem;
    border-radius: 0.5rem;
