---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BottomNav from '../../components/BottomNav.astro';
import { adminDb } from '../../lib/firebase-admin';

const { slug } = Astro.params;

let article: any = null;
let relatedArticles: any[] = [];

if (adminDb && slug) {
  try {
    const snapshot = await adminDb.collection('posts')
      .where('slug', '==', slug)
      .where('status', '==', 'published')
      .limit(1)
      .get();
    
    if (!snapshot.empty) {
      const doc = snapshot.docs[0];
      article = { id: doc.id, ...doc.data() };
      
      // Fetch related articles
      const relatedSnapshot = await adminDb.collection('posts')
        .where('category', '==', article.category)
        .where('status', '==', 'published')
        .limit(4)
        .get();
      
      relatedArticles = relatedSnapshot.docs
        .filter(d => d.id !== doc.id)
        .map(d => ({ id: d.id, ...d.data() }));
    }
  } catch (error) {
    console.error('Error fetching article:', error);
  }
}

if (!article) {
  return Astro.redirect('/404');
}

const publishedDate = article.publishedAt?.toDate?.() || new Date();
---

<Layout title={article.seoTitle || article.title} description={article.seoDescription || article.excerpt}>
  <Header />
  
  <main class="bg-gray-50">
    <!-- Article Container -->
    <article class="container mx-auto px-4 py-8 pb-20 md:pb-8">
      <div class="max-w-4xl mx-auto">
        <!-- Breadcrumb -->
        <nav class="mb-6 text-sm">
          <ol class="flex items-center gap-2 text-gray-600">
            <li><a href="/" class="hover:text-red-600 transition">Home</a></li>
            <li>›</li>
            <li><a href={`/category/${article.category}`} class="hover:text-red-600 transition capitalize">{article.category}</a></li>
            <li>›</li>
            <li class="text-gray-400 truncate">{article.title}</li>
          </ol>
        </nav>

        <!-- Category Badge -->
        <div class="mb-4">
          <a href={`/category/${article.category}`} class="inline-block bg-red-600 text-white px-4 py-1.5 text-xs font-bold uppercase tracking-wider rounded hover:bg-red-700 transition">
            {article.category}
          </a>
        </div>
        
        <!-- Article Title -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
          {article.title}
        </h1>
        
        <!-- Article Meta -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 mb-8 pb-6 border-b border-gray-200">
          <div class="flex items-center gap-2">
            <div class="w-10 h-10 bg-red-600 rounded-full flex items-center justify-center text-white font-bold">
              {article.author.charAt(0)}
            </div>
            <div>
              <p class="font-semibold text-gray-900">{article.author}</p>
              <p class="text-xs text-gray-500">Staff Writer</p>
            </div>
          </div>
          <span class="hidden md:inline text-gray-300">|</span>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
            </svg>
            <time datetime={publishedDate.toISOString()}>
              {publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <span class="hidden md:inline text-gray-300">|</span>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            <span>{article.readingTime} min read</span>
          </div>
        </div>
        
        <!-- Featured Image -->
        <figure class="mb-10 -mx-4 md:mx-0">
          <img 
            src={article.featuredImage} 
            alt={article.title}
            class="w-full rounded-none md:rounded-2xl shadow-2xl"
          />
        </figure>
        
        <!-- Article Excerpt -->
        <div class="bg-gradient-to-r from-red-50 to-orange-50 border-l-4 border-red-600 p-6 md:p-8 mb-10 rounded-r-xl">
          <p class="text-xl md:text-2xl text-gray-800 font-medium leading-relaxed italic">
            {article.excerpt}
          </p>
        </div>
        
        <!-- Article Content -->
        <div class="prose prose-lg md:prose-xl max-w-none mb-12">
          <div 
            set:html={article.content} 
            class="article-content text-gray-800 leading-relaxed"
          />
        </div>
        
        <!-- Tags -->
        {article.tags && article.tags.length > 0 && (
          <div class="mb-10 pb-10 border-b border-gray-200">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Topics</h3>
            <div class="flex flex-wrap gap-2">
              {article.tags.map((tag: string) => (
                <a 
                  href={`/search?q=${tag}`}
                  class="px-4 py-2 bg-white border border-gray-200 text-gray-700 rounded-full text-sm hover:border-red-600 hover:text-red-600 transition"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}
        
        <!-- Share Section -->
        <div class="mb-12 pb-10 border-b border-gray-200">
          <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Share This Article</h3>
          <div class="flex gap-3">
            <button class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </button>
            <button class="flex items-center gap-2 px-4 py-2 bg-sky-500 text-white rounded-lg hover:bg-sky-600 transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
              Twitter
            </button>
            <button class="flex items-center gap-2 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              WhatsApp
            </button>
          </div>
        </div>
        
        <!-- Related Articles -->
        {relatedArticles.length > 0 && (
          <section>
            <h2 class="text-3xl font-bold mb-8 text-gray-900">Related Articles</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {relatedArticles.map(related => (
                <a href={`/news/${related.slug}`} class="group bg-white rounded-xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300">
                  <div class="relative overflow-hidden">
                    <img 
                      src={related.featuredImage} 
                      alt={related.title} 
                      class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                    <div class="absolute top-3 left-3">
                      <span class="bg-red-600 text-white px-3 py-1 text-xs font-bold uppercase rounded">
                        {related.category}
                      </span>
                    </div>
                  </div>
                  <div class="p-5">
                    <h3 class="font-bold text-lg text-gray-900 line-clamp-2 group-hover:text-red-600 transition mb-2">
                      {related.title}
                    </h3>
                    <p class="text-sm text-gray-600 line-clamp-2 mb-3">{related.excerpt}</p>
                    <div class="flex items-center text-xs text-gray-500">
                      <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                      </svg>
                      {related.readingTime} min read
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </article>
  </main>
  
  <Footer />
  <BottomNav />
</Layout>

<style>
  /* Maximum Readability Article Styles */
  .article-content {
    font-size: 1.125rem;
    line-height: 1.9;
    color: #1f2937;
    max-width: 70ch;
    margin: 0 auto;
  }
  
  .article-content h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: #111827;
    line-height: 1.4;
    letter-spacing: -0.02em;
  }
  
  .article-content h3 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #1f2937;
    line-height: 1.4;
  }
  
  .article-content p {
    margin-bottom: 1.75rem;
    color: #374151;
    font-size: 1.125rem;
    line-height: 1.9;
  }
  
  .article-content ul,
  .article-content ol {
    margin-bottom: 1.75rem;
    padding-left: 1.5rem;
  }
  
  .article-content li {
    margin-bottom: 0.75rem;
    color: #4b5563;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  
  .article-content a {
    color: #dc2626;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  
  .article-content a:hover {
    color: #b91c1c;
  }
  
  .article-content blockquote {
    border-left: 4px solid #dc2626;
    margin: 2.5rem 0;
    padding: 1.5rem 2rem;
    font-style: italic;
    color: #4b5563;
    background: linear-gradient(to right, #fef2f2, #f9fafb);
    border-radius: 0 0.75rem 0.75rem 0;
    font-size: 1.125rem;
    line-height: 1.8;
  }
  
  .article-content blockquote p {
    margin-bottom: 0;
    color: #4b5563;
  }
  
  .article-content strong {
    font-weight: 600;
    color: #111827;
  }
  
  .article-content em {
    font-style: italic;
  }
  
  .article-content img {
    border-radius: 0.75rem;
    margin: 2.5rem 0;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    width: 100%;
    max-width: 100%;
  }
  
  .article-content hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 3rem 0;
  }
  
  .article-content .highlight {
    background: linear-gradient(120deg, #fef3c7 0%, #fef9c3 100%);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }
  
  .article-content .key-point {
    background: #f0fdf4;
    border-left: 4px solid #22c55e;
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  
  .article-content .key-point p {
    margin-bottom: 0;
    color: #166534;
    font-weight: 500;
  }
  
  /* Mobile responsiveness */
  @media (max-width: 768px) {
    .article-content {
      font-size: 1rem;
      line-height: 1.8;
    }
    
    .article-content h2 {
      font-size: 1.5rem;
      margin-top: 2rem;
    }
    
    .article-content h3 {
      font-size: 1.25rem;
      margin-top: 1.5rem;
    }
    
    .article-content p {
      font-size: 1rem;
      line-height: 1.8;
    }
    
    .article-content blockquote {
      padding: 1rem 1.25rem;
      font-size: 1rem;
    }
  }
</style>
