---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { adminDb } from '../../lib/firebase-admin';

const { slug } = Astro.params;

let article: any = null;
let authorData: any = null;
let relatedArticles: any[] = [];
let faqItems: any[] = [];

if (adminDb && slug) {
  try {
    // 1. Fetch article from articles collection, fallback to posts if needed
    let snapshot = await adminDb.collection('articles')
      .where('slug', '==', slug)
      .limit(1)
      .get();
      
    if (snapshot.empty) {
      // Legacy fallback
      snapshot = await adminDb.collection('posts')
        .where('slug', '==', slug)
        .limit(1)
        .get();
    }

    if (!snapshot.empty) {
      const doc = snapshot.docs[0];
      const d = doc.data();
      article = {
        id: doc.id,
        title: d.title || '',
        slug: d.slug || doc.id,
        excerpt: d.excerpt || '',
        content: d.content || '',
        metaTitle: d.meta_title || d.seoTitle || d.title,
        metaDescription: d.meta_description || d.seoDescription || d.excerpt,
        featuredImage: d.featured_image || d.featuredImage || 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200',
        category: d.category || 'AI Tools',
        categorySlug: (d.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
        author: d.author || 'Mershal Editorial Team',
        publishDate: d.publish_date?.toDate?.() || d.publishedAt?.toDate?.() || new Date(),
        readingTime: d.readingTime || d.reading_time || 5,
        tags: d.tags || [],
      };
      
      faqItems = d.faq_items || [];

      // 2. Fetch author info from authors collection
      if (d.author_id) {
        const authDoc = await adminDb.collection('authors').doc(d.author_id).get();
        if (authDoc.exists) {
          authorData = { id: authDoc.id, ...authDoc.data() };
        }
      }
      
      // Author fallback details if collection not set up
      if (!authorData) {
        authorData = {
          name: article.author,
          role: 'Expert Contributor',
          bio: 'Contributor covering business operations, AI implementation, and productivity tool stack optimizations.'
        };
      }

      // 3. Fetch related articles from same category
      let relatedSnapshot = await adminDb.collection('articles')
        .where('category', '==', article.category)
        .where('status', '==', 'published')
        .limit(4)
        .get();
        
      if (relatedSnapshot.empty) {
        relatedSnapshot = await adminDb.collection('posts')
          .where('category', '==', article.category)
          .where('status', '==', 'published')
          .limit(4)
          .get();
      }
      
      relatedArticles = relatedSnapshot.docs
        .filter(doc => doc.id !== article.id)
        .map(doc => {
          const d = doc.data();
          return {
            id: doc.id,
            slug: d.slug || doc.id,
            title: d.title || '',
            category: d.category || 'AI Tools',
            featuredImage: d.featured_image || d.featuredImage || 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=200',
          };
        })
        .slice(0, 3);
    }
  } catch (e) {
    console.error('Error fetching article details:', e);
  }
}

if (!article) return Astro.redirect('/404');

// In-content Ad Injection mechanic
function injectAdsIntoHtml(contentHtml: string) {
  return contentHtml;
}

const adInjectedContent = injectAdsIntoHtml(article.content);
const shortDate = article.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<Layout
  title={article.metaTitle}
  description={article.metaDescription}
  image={article.featuredImage}
  type="article"
  author={article.author}
  publishedAt={article.publishDate.toISOString()}
>
  <!-- SEO JSON-LD Rich Schema Tags -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": article.title,
      "description": article.excerpt,
      "image": [article.featuredImage],
      "datePublished": article.publishDate.toISOString(),
      "dateModified": article.publishDate.toISOString(),
      "author": [{ "@type": "Person", "name": article.author }],
      "publisher": {
        "@type": "Organization",
        "name": "Mershal",
        "logo": { "@type": "ImageObject", "url": "https://mershal.in/logo.png" }
      },
      "mainEntityOfPage": { "@type": "WebPage", "@id": `https://mershal.in/articles/${article.slug}` }
    })} />
    
    <!-- FAQ Schema if FAQ items exist -->
    {faqItems && faqItems.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqItems.map(f => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.answer
          }
        }))
      })} />
    )}
  </Fragment>

  <Header />

  <!-- Top Leaderboard Ad Unit -->
  <div class="container mx-auto px-4 max-w-7xl">
    <AdUnit type="header" />
  </div>

  <main class="bg-white min-h-screen pb-16 font-sans">
    
    <!-- Breadcrumb Header -->
    <div class="border-b border-slate-100 bg-slate-50/50">
      <div class="container mx-auto px-4 max-w-6xl">
        <Breadcrumbs category={article.category} categorySlug={article.categorySlug} title={article.title} />
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-6xl py-8 md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10">
        
        <!-- Left: Main Article Content -->
        <article class="min-w-0">
          
          <!-- Headers -->
          <header class="mb-8">
            <h1 class="text-3xl md:text-4xl lg:text-[2.5rem] font-serif font-black text-slate-900 leading-[1.15] mb-5 tracking-tight">
              {article.title}
            </h1>
            
            <p class="text-lg md:text-xl text-slate-500 leading-relaxed font-light mb-6">
              {article.excerpt}
            </p>
            
            <!-- Metadata line -->
            <div class="flex flex-wrap items-center gap-4 py-4 border-y border-slate-100 text-xs text-slate-500 font-sans">
              <span class="font-bold text-slate-800">{article.author}</span>
              <span class="text-slate-200">|</span>
              <time datetime={article.publishDate.toISOString()}>{shortDate}</time>
              <span class="text-slate-200">|</span>
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-slate-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                {article.readingTime} min read
              </span>
              
              <!-- Social sharing triggers -->
              <div class="sm:ml-auto flex items-center gap-2 pt-2 sm:pt-0">
                <button id="share-twitter-btn" class="px-3 py-1.5 bg-slate-900 hover:bg-slate-800 text-white rounded-lg text-[10px] font-black uppercase tracking-wider transition">
                  Share
                </button>
                <button id="copy-url-btn" class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg text-[10px] font-black uppercase tracking-wider transition">
                  Copy URL
                </button>
              </div>
            </div>
          </header>

          <!-- Featured cover photo -->
          <div class="mb-10 overflow-hidden rounded-2xl border border-slate-100 shadow-sm aspect-video max-h-[460px]">
            <img
              src={article.featuredImage}
              alt={article.title}
              class="w-full h-full object-cover"
              fetchpriority="high"
            />
          </div>

          <!-- Structured Content Body -->
          <div class="article-content" set:html={adInjectedContent} />

          <!-- Tags list -->
          {article.tags && article.tags.length > 0 && (
            <div class="mt-10 pt-6 border-t border-slate-100">
              <div class="flex flex-wrap gap-2">
                {article.tags.map((tag: string) => (
                  <span class="px-3 py-1 bg-slate-50 border border-slate-100 rounded-lg text-slate-600 text-xs font-semibold hover:border-primary-crimson/30 hover:text-primary-crimson transition cursor-default">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Author Biography -->
          <AuthorCard name={authorData.name} role={authorData.role} bio={authorData.bio} avatar={authorData.avatar} />

          <!-- FAQ Accordions -->
          <FAQAccordion items={faqItems} />

          <!-- Related Posts Cluster -->
          {relatedArticles.length > 0 && (
            <section class="mt-14 pt-8 border-t-2 border-slate-900">
              <h3 class="text-lg font-black font-serif text-slate-900 uppercase tracking-wide mb-6">Related Guides & Reviews</h3>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                {relatedArticles.map((rel: any) => (
                  <a href={`/articles/${rel.slug}`} class="group space-y-2 block">
                    <div class="aspect-video overflow-hidden rounded-xl border border-slate-100 shadow-sm">
                      <img src={rel.featuredImage} alt={rel.title} class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-300" loading="lazy" />
                    </div>
                    <span class="text-[10px] uppercase font-black tracking-wider text-primary-crimson">{rel.category}</span>
                    <h4 class="text-sm font-bold text-slate-800 line-clamp-2 leading-snug group-hover:text-primary-crimson transition">{rel.title}</h4>
                  </a>
                ))}
              </div>
            </section>
          )}

        </article>

        <!-- Right: Sticky Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-24 space-y-8">
            
            <!-- Sticky Sidebar Ad Slot -->
            <AdUnit type="sidebar" />
            
            <!-- Dynamic Sidebar Table of Contents (TOC) -->
            <div id="toc-box" class="bg-slate-50 rounded-2xl p-5 border border-slate-100 shadow-sm hidden">
              <h3 class="text-xs uppercase tracking-widest font-black text-slate-900 mb-4 font-sans">Table of Contents</h3>
              <nav id="toc-nav" class="space-y-2 text-xs font-semibold text-slate-500"></nav>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Dynamic Table of Contents builder
  const headings = document.querySelectorAll('.article-content h2, .article-content h3');
  if (headings.length > 1) {
    const tocBox = document.getElementById('toc-box');
    const tocNav = document.getElementById('toc-nav');
    
    if (tocBox && tocNav) {
      tocBox.classList.remove('hidden');
      headings.forEach((heading, idx) => {
        const id = `heading-anchor-${idx}`;
        heading.id = id;

        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = heading.textContent;
        a.className = heading.tagName === 'H2' 
          ? 'block text-slate-700 hover:text-primary-crimson hover:translate-x-0.5 transition-all'
          : 'block pl-3 text-slate-400 hover:text-primary-crimson hover:translate-x-0.5 transition-all text-[11px]';
        tocNav.appendChild(a);
      });
    }
  }

  // Social actions
  const url = window.location.href;
  const title = document.title;

  document.getElementById('share-twitter-btn')?.addEventListener('click', () => {
    window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`, '_blank');
  });

  document.getElementById('copy-url-btn')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(url);
    const btn = document.getElementById('copy-url-btn') as HTMLButtonElement;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy URL'; }, 1500);
  });
</script>

<style is:global>
  /* Premium SaaS Blog typography styles */
  .article-content {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.85;
    color: #334155;
  }
  .article-content > * + * {
    margin-top: 1.5rem;
  }
  .article-content h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 900;
    color: #0f172a;
    line-height: 1.25;
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .article-content h3 {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 900;
    color: #0f172a;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.015em;
  }
  .article-content p {
    margin-bottom: 1.25rem;
    color: #334155;
  }
  .article-content blockquote {
    border-left: 4px solid #c29b38;
    background-color: #f8fafc;
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #475569;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .article-content ul, .article-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .article-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .article-content a {
    color: #8b0222;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 600;
  }
  .article-content a:hover {
    color: #ab173b;
  }
</style>
