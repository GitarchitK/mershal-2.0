---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { Image } from 'astro:assets';
import { adminDb } from '../../lib/firebase-admin';

const { slug } = Astro.params;

let article: any = null;
let authorData: any = null;
let relatedArticles: any[] = [];
let faqItems: any[] = [];

if (adminDb && slug) {
  try {
    // 1. Fetch article from articles collection, fallback to posts if needed
    let snapshot = await adminDb.collection('articles')
      .where('slug', '==', slug)
      .limit(1)
      .get();
      
    if (snapshot.empty) {
      // Legacy fallback
      snapshot = await adminDb.collection('posts')
        .where('slug', '==', slug)
        .limit(1)
        .get();
    }

    if (!snapshot.empty) {
      const doc = snapshot.docs[0];
      const d = doc.data();
      article = {
        id: doc.id,
        title: d.title || '',
        slug: d.slug || doc.id,
        excerpt: d.excerpt || '',
        content: d.content || '',
        metaTitle: d.meta_title || d.seoTitle || d.title,
        metaDescription: d.meta_description || d.seoDescription || d.excerpt,
        featuredImage: d.featured_image || d.featuredImage || 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200',
        category: d.category || 'AI Tools',
        categorySlug: (d.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
        author: d.author || 'Mershal Editorial Team',
        publishDate: d.publish_date?.toDate?.() || d.publishedAt?.toDate?.() || new Date(),
        readingTime: d.readingTime || d.reading_time || 5,
        tags: d.tags || [],
      };
      
      faqItems = d.faq_items || [];

      // 2. Fetch author info from authors collection
      if (d.author_id) {
        const authDoc = await adminDb.collection('authors').doc(d.author_id).get();
        if (authDoc.exists) {
          authorData = { id: authDoc.id, ...authDoc.data() };
        }
      }
      
      // Author fallback details if collection not set up
      if (!authorData) {
        authorData = {
          name: article.author,
          role: 'Expert Contributor',
          bio: 'Contributor covering business operations, AI implementation, and productivity tool stack optimizations.'
        };
      }

      // 3. Fetch related articles from same category
      let relatedSnapshot = await adminDb.collection('articles')
        .where('category', '==', article.category)
        .where('status', '==', 'published')
        .limit(4)
        .get();
        
      if (relatedSnapshot.empty) {
        relatedSnapshot = await adminDb.collection('posts')
          .where('category', '==', article.category)
          .where('status', '==', 'published')
          .limit(4)
          .get();
      }
      
      relatedArticles = relatedSnapshot.docs
        .filter(doc => doc.id !== article.id)
        .map(doc => {
          const d = doc.data();
          return {
            id: doc.id,
            slug: d.slug || doc.id,
            title: d.title || '',
            category: d.category || 'AI Tools',
            featuredImage: d.featured_image || d.featuredImage || 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=200',
            readingTime: d.readingTime || d.reading_time || 5,
          };
        })
        .slice(0, 3);
    }
  } catch (e) {
    console.error('Error fetching article details:', e);
  }
}

if (!article) return Astro.redirect('/404');

// In-content Ad Injection mechanic
function injectAdsIntoHtml(contentHtml: string) {
  return contentHtml;
}

const adInjectedContent = injectAdsIntoHtml(article.content);
const shortDate = article.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<Layout
  title={article.metaTitle}
  description={article.metaDescription}
  image={article.featuredImage}
  type="article"
  author={article.author}
  publishedAt={article.publishDate.toISOString()}
>
  <!-- SEO JSON-LD Rich Schema Tags -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": article.title,
      "description": article.excerpt,
      "image": [article.featuredImage],
      "datePublished": article.publishDate.toISOString(),
      "dateModified": article.publishDate.toISOString(),
      "author": [{ "@type": "Person", "name": article.author }],
      "publisher": {
        "@type": "Organization",
        "name": "Mershal",
        "logo": { "@type": "ImageObject", "url": "https://mershal.in/logo.png" }
      },
      "mainEntityOfPage": { "@type": "WebPage", "@id": `https://mershal.in/articles/${article.slug}` }
    })} />
    
    <!-- FAQ Schema if FAQ items exist -->
    {faqItems && faqItems.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqItems.map(f => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.answer
          }
        }))
      })} />
    )}
  </Fragment>

  <Header />

  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-[3px] bg-primary-crimson w-0 z-[9999] transition-[width] duration-75 ease-out"></div>

  <!-- Top Leaderboard Ad Unit -->
  <div class="container mx-auto px-4 max-w-7xl">
    <AdUnit type="header" />
  </div>



  <main class="bg-white min-h-screen pb-16 font-sans">
    
    <!-- Breadcrumb Header -->
    <div class="border-b border-slate-100 bg-slate-50/50">
      <div class="container mx-auto px-4 max-w-6xl">
        <Breadcrumbs category={article.category} categorySlug={article.categorySlug} title={article.title} />
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-6xl py-8 md:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10">
        
        <!-- Left: Main Article Content (Prose Width Constrained) -->
        <div class="relative max-w-[680px] mx-auto w-full">
          <!-- Floating Share Sidebar (Desktop Only) -->
          <div class="absolute right-full top-0 h-full mr-8 hidden xl:block">
            <div class="sticky top-40 flex flex-col gap-3">
              <!-- Twitter -->
              <a
                id="share-float-twitter"
                href="#"
                target="_blank"
                class="share-btn w-9 h-9 rounded-full border border-slate-200 bg-white text-slate-500 hover:text-primary-crimson hover:border-primary-crimson flex items-center justify-center transition-all shadow-sm group relative animate-in slide-in-from-left-4 duration-300"
                title="Share on X"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                <span class="tooltip absolute left-full ml-3 px-2 py-1.5 bg-slate-950 text-white text-[10px] rounded-lg opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity duration-150 whitespace-nowrap shadow font-bold">Share on X</span>
              </a>
              <!-- LinkedIn -->
              <a
                id="share-float-linkedin"
                href="#"
                target="_blank"
                class="share-btn w-9 h-9 rounded-full border border-slate-200 bg-white text-slate-500 hover:text-primary-crimson hover:border-primary-crimson flex items-center justify-center transition-all shadow-sm group relative"
                title="Share on LinkedIn"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
                <span class="tooltip absolute left-full ml-3 px-2 py-1.5 bg-slate-950 text-white text-[10px] rounded-lg opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity duration-150 whitespace-nowrap shadow font-bold">Share on LinkedIn</span>
              </a>
              <!-- Copy Link -->
              <button
                id="share-float-copy"
                class="share-btn w-9 h-9 rounded-full border border-slate-200 bg-white text-slate-500 hover:text-primary-crimson hover:border-primary-crimson flex items-center justify-center transition-all shadow-sm group relative cursor-pointer"
                title="Copy Link"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
                <span id="float-copy-tooltip" class="tooltip absolute left-full ml-3 px-2 py-1.5 bg-slate-950 text-white text-[10px] rounded-lg opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity duration-150 whitespace-nowrap shadow font-bold">Copy Link</span>
              </button>
            </div>
          </div>

          <article class="min-w-0 w-full px-5 md:px-0">
          
          <!-- Headers -->
          <header class="mb-8">
            <h1 class="text-3xl md:text-4xl lg:text-[2.5rem] font-serif font-black text-slate-900 leading-[1.15] mb-5 tracking-tight animate-in fade-in duration-300">
              {article.title}
            </h1>
            
            <p class="text-lg md:text-xl text-slate-500 leading-relaxed font-light mb-6">
              {article.excerpt}
            </p>
            
            <!-- Inline Author Byline Row -->
            <div class="flex flex-wrap items-center gap-3 py-4 border-y border-slate-150 text-[14px] text-slate-500 font-sans">
              <!-- Author Avatar -->
              {authorData?.avatar ? (
                <Image src={authorData.avatar} alt={article.author} width={80} height={80} class="w-10 h-10 rounded-full object-cover border border-slate-200" />
              ) : (
                <div class="w-10 h-10 rounded-full bg-primary-crimson/10 text-primary-crimson flex items-center justify-center font-black text-sm tracking-wider uppercase border border-primary-crimson/20">
                  {article.author.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
                </div>
              )}
              
              <div class="flex flex-wrap items-center gap-x-2 gap-y-1 ml-1">
                <span class="font-bold text-slate-800">{article.author}</span>
                <span class="text-slate-350 select-none">·</span>
                <time datetime={article.publishDate.toISOString()}>{shortDate}</time>
                <span class="text-slate-350 select-none">·</span>
                <span class="flex items-center gap-1.5 font-medium">
                  <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {article.readingTime} min read
                </span>
              </div>
              
              <!-- Social sharing triggers -->
              <div class="sm:ml-auto flex items-center gap-2 pt-2 sm:pt-0">
                <button id="share-twitter-btn" class="px-3.5 py-1.5 bg-slate-900 hover:bg-slate-800 text-white rounded-lg text-[10px] font-black uppercase tracking-wider transition shadow-sm cursor-pointer">
                  Share
                </button>
                <button id="copy-url-btn" class="px-3.5 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg text-[10px] font-black uppercase tracking-wider transition border border-slate-200/50 cursor-pointer">
                  Copy URL
                </button>
              </div>
            </div>
          </header>

          <!-- Mobile TOC Toggle (visible below lg) -->
          <div id="mobile-toc-box" class="lg:hidden mb-8 bg-slate-50 border border-slate-100 rounded-2xl overflow-hidden hidden shadow-sm">
            <button id="mobile-toc-toggle" class="w-full flex items-center justify-between px-5 py-4 font-bold text-slate-800 text-sm hover:bg-slate-100/50 transition">
              <span>Table of Contents</span>
              <svg id="mobile-toc-arrow" class="w-4 h-4 text-slate-500 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id="mobile-toc-content" class="px-5 pb-4 hidden border-t border-slate-150 pt-3">
              <nav id="mobile-toc-nav" class="space-y-2 text-xs font-semibold text-slate-500"></nav>
            </div>
          </div>

          <!-- Featured cover photo (Cinematic layout with Category Badge) -->
          <div class="mb-10 relative rounded-[12px] overflow-hidden border border-slate-100 shadow-sm aspect-[16/9] md:aspect-[21/9]">
            <Image
              src={article.featuredImage}
              alt={article.title}
              width={1200}
              height={675}
              class="w-full h-full object-cover"
              loading="eager"
              fetchpriority="high"
            />
            <!-- Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"></div>
            <!-- Category Badge bottom-left -->
            <div class="absolute bottom-4 left-4 z-10 select-none">
              <span class="inline-block bg-slate-950/75 backdrop-blur-sm text-white text-[12px] font-black uppercase tracking-wider px-3 py-1.5 rounded-full shadow-sm">
                {article.category}
              </span>
            </div>
          </div>

          <!-- Structured Content Body -->
          <div class="article-content" set:html={adInjectedContent} />

          <!-- Tags list (pill chips) -->
          {article.tags && article.tags.length > 0 && (
            <div class="mt-10 pt-6 border-t border-slate-150 flex flex-wrap items-center gap-2">
              <span class="text-xs font-black uppercase tracking-wider text-slate-400 mr-2 select-none">Tags:</span>
              <div class="flex flex-wrap gap-2">
                {article.tags.map((tag: string) => (
                  <span class="px-3.5 py-1 bg-slate-100 text-slate-500 text-[13px] rounded-full border border-slate-200/60 hover:bg-slate-200/85 hover:text-primary-crimson transition-all cursor-default font-medium">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Author Biography -->
          <AuthorCard name={authorData.name} role={authorData.role} bio={authorData.bio} avatar={authorData.avatar} />

          <!-- FAQ Accordions -->
          <FAQAccordion items={faqItems} />

          <!-- Related Posts Cluster Redesign -->
          {relatedArticles.length > 0 && (
            <section class="mt-14 pt-8 border-t-2 border-slate-900 animate-in fade-in duration-300">
              <h3 class="text-lg font-black font-serif text-slate-900 uppercase tracking-wide mb-6">Related Guides & Reviews</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {relatedArticles.map((rel: any) => (
                  <a href={`/articles/${rel.slug}`} class="group flex flex-col bg-white rounded-xl border border-slate-200/80 overflow-hidden shadow-sm hover:border-primary-crimson/50 hover:-translate-y-0.5 transition-all duration-205">
                    <div class="aspect-[16/9] w-full overflow-hidden border-b border-slate-100">
                      <Image src={rel.featuredImage} alt={rel.title} width={400} height={225} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" loading="lazy" />
                    </div>
                    <div class="p-4 flex flex-col flex-1 justify-between gap-3">
                      <div>
                        <span class="inline-block text-[11px] font-black uppercase tracking-wider text-primary-crimson mb-1.5">{rel.category}</span>
                        <h4 class="text-[15px] font-medium text-slate-800 line-clamp-2 leading-[1.4] group-hover:text-primary-crimson transition-colors duration-200">{rel.title}</h4>
                      </div>
                      <div class="flex items-center gap-1.5 text-xs text-slate-400 font-medium">
                        <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>{rel.readingTime} min read</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}

        </article>
      </div>

        <!-- Right: Sticky Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-24 space-y-8">
            
            <!-- Sticky Sidebar Ad Slot -->
            <AdUnit type="sidebar" />
            
            <!-- Dynamic Sidebar Table of Contents (TOC) -->
            <div id="toc-box" class="bg-slate-50 rounded-2xl p-5 border border-slate-100 shadow-sm hidden sticky top-8 max-h-[calc(100vh-4rem)] overflow-y-auto">
              <h3 class="text-xs uppercase tracking-widest font-black text-slate-900 mb-4 font-sans">Table of Contents</h3>
              <nav id="toc-nav" class="space-y-2 text-xs font-semibold text-slate-500"></nav>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Dynamic Table of Contents builder (Desktop + Mobile)
  const headings = document.querySelectorAll('.article-content h2, .article-content h3');
  const headingsArray = Array.from(headings);
  
  if (headingsArray.length > 1) {
    const tocBox = document.getElementById('toc-box');
    const tocNav = document.getElementById('toc-nav');
    const mobileTocBox = document.getElementById('mobile-toc-box');
    const mobileTocNav = document.getElementById('mobile-toc-nav');
    const mobileTocToggle = document.getElementById('mobile-toc-toggle');
    const mobileTocContent = document.getElementById('mobile-toc-content');
    const mobileTocArrow = document.getElementById('mobile-toc-arrow');

    if (tocBox && tocNav) {
      tocBox.classList.remove('hidden');
    }
    if (mobileTocBox && mobileTocNav) {
      mobileTocBox.classList.remove('hidden');
    }

    headingsArray.forEach((heading, idx) => {
      const id = heading.id || `heading-anchor-${idx}`;
      heading.id = id;

      // Create Desktop Link
      if (tocNav) {
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = heading.textContent;
        a.className = heading.tagName === 'H2' 
          ? 'block text-slate-500 hover:text-primary-crimson hover:translate-x-0.5 transition-all text-xs font-semibold'
          : 'block pl-3 text-slate-400 hover:text-primary-crimson hover:translate-x-0.5 transition-all text-[11px] font-semibold';
        tocNav.appendChild(a);
      }

      // Create Mobile Link
      if (mobileTocNav) {
        const aMobile = document.createElement('a');
        aMobile.href = `#${id}`;
        aMobile.textContent = heading.textContent;
        aMobile.className = heading.tagName === 'H2' 
          ? 'block text-slate-600 hover:text-primary-crimson py-1 text-xs font-semibold'
          : 'block pl-3 text-slate-400 hover:text-primary-crimson py-0.5 text-[11px] font-semibold';
        
        aMobile.addEventListener('click', () => {
          mobileTocContent?.classList.add('hidden');
          mobileTocArrow?.classList.remove('rotate-180');
        });
        mobileTocNav.appendChild(aMobile);
      }
    });

    // Mobile Toggle action
    mobileTocToggle?.addEventListener('click', () => {
      mobileTocContent?.classList.toggle('hidden');
      mobileTocArrow?.classList.toggle('rotate-180');
    });

    // IntersectionObserver for active link highlighting
    const observerOptions = {
      root: null,
      rootMargin: '-5% 0px -75% 0px',
      threshold: [0, 1]
    };

    const observer = new IntersectionObserver(() => {
      let currentActiveId = '';
      headingsArray.forEach(heading => {
        const rect = heading.getBoundingClientRect();
        if (rect.top < window.innerHeight * 0.3) {
          currentActiveId = heading.id;
        }
      });

      if (currentActiveId) {
        // Highlight active link in both Desktop & Mobile TOC
        const links = document.querySelectorAll('#toc-nav a, #mobile-toc-nav a');
        links.forEach(link => {
          if (link.getAttribute('href') === `#${currentActiveId}`) {
            link.classList.add('active');
          } else {
            link.classList.remove('active');
          }
        });
      }
    }, observerOptions);

    headingsArray.forEach(heading => observer.observe(heading));
  }

  // Social sharing logic
  const url = window.location.href;
  const title = document.title;

  // Header Twitter Share
  document.getElementById('share-twitter-btn')?.addEventListener('click', () => {
    window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`, '_blank');
  });

  // Floating Twitter Share
  const floatTwitter = document.getElementById('share-float-twitter');
  if (floatTwitter) {
    floatTwitter.setAttribute('href', `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`);
  }

  // Floating LinkedIn Share
  const floatLinkedIn = document.getElementById('share-float-linkedin');
  if (floatLinkedIn) {
    floatLinkedIn.setAttribute('href', `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`);
  }

  // Header Copy URL Button
  document.getElementById('copy-url-btn')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(url);
    const btn = document.getElementById('copy-url-btn') as HTMLButtonElement;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy URL'; }, 1500);
  });

  // Floating Copy URL Button
  document.getElementById('share-float-copy')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(url);
    const tooltip = document.getElementById('float-copy-tooltip');
    if (tooltip) {
      tooltip.textContent = 'Copied!';
      tooltip.style.opacity = '1';
      setTimeout(() => {
        tooltip.textContent = 'Copy Link';
        tooltip.style.opacity = '';
      }, 1500);
    }
  });

  // Reading Progress Bar handler
  const bar = document.getElementById('reading-progress');
  if (bar) {
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.body.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = progress + '%';
    });
  }
</script>

<style is:global>
  /* Premium SaaS Blog typography styles */
  .article-content {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.85;
    color: #334155;
  }
  .article-content > * + * {
    margin-top: 1.5rem;
  }
  .article-content h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 900;
    color: #0f172a;
    line-height: 1.25;
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .article-content h3 {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 900;
    color: #0f172a;
    margin-top: 2rem;
