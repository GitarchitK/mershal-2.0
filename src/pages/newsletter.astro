---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout
  title="Mershal Intel Newsletter — Subscribe Free"
  description="Join thousands of founders and developers receiving hand-picked AI tools, independent SaaS reviews, and operational automation guides every Thursday."
>
  <Header />

  <main class="bg-slate-50 pb-20 md:pb-8 font-sans text-slate-800">
    <!-- Hero Banner with Subtraction Shape Background -->
    <div class="relative bg-gradient-to-b from-slate-900 via-slate-900 to-slate-950 text-white py-16 md:py-24 overflow-hidden border-b border-slate-850">
      <!-- Glow Gradients -->
      <div class="absolute right-0 top-0 w-[400px] h-[400px] bg-primary-crimson/15 rounded-full blur-3xl"></div>
      <div class="absolute left-10 bottom-0 w-[300px] h-[300px] bg-primary-gold/10 rounded-full blur-3xl"></div>
      
      <div class="container mx-auto px-4 max-w-6xl relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          
          <!-- Column 1: Copy -->
          <div class="lg:col-span-7 space-y-6">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary-crimson/10 border border-primary-crimson/20 rounded-full text-xs font-black uppercase tracking-widest text-primary-crimson">
              <span class="w-1.5 h-1.5 rounded-full bg-primary-crimson animate-pulse"></span>
              Mershal Weekly Digest
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-black leading-tight text-white">
              Supercharge Your Workflow With <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-gold to-yellow-400">AI & Automation</span>
            </h1>
            <p class="text-slate-300 text-base md:text-lg max-w-xl leading-relaxed">
              Join 15,000+ startup founders, developers, and operators who receive hand-picked AI tools, independent software reviews, and automation playbooks every Thursday.
            </p>
            <div class="flex flex-wrap gap-4 text-xs text-slate-400 font-medium">
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-primary-gold" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Delivered Weekly (Thursdays)
              </div>
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-primary-gold" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                100% Free, Unsubscribe in 1-Click
              </div>
            </div>
          </div>
          
          <!-- Column 2: Subscription Card -->
          <div class="lg:col-span-5">
            <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-6 md:p-8 shadow-2xl relative overflow-hidden">
              <div class="absolute -right-8 -bottom-8 w-24 h-24 bg-primary-crimson/25 rounded-full blur-2xl"></div>
              
              <h3 class="text-lg font-serif font-bold text-white mb-2">Subscribe to Mershal Intel</h3>
              <p class="text-xs text-slate-400 mb-6">Enter your email below to get the next briefing delivered directly to your inbox.</p>
              
              <form id="newsletter-page-form" class="space-y-4">
                <div>
                  <label for="newsletter-page-email" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Email Address</label>
                  <input
                    type="email"
                    id="newsletter-page-email"
                    required
                    placeholder="you@company.com"
                    class="w-full bg-slate-900 border border-slate-750 text-white placeholder-slate-500 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary-crimson focus:ring-1 focus:ring-primary-crimson transition duration-150"
                  />
                </div>
                
                <div id="newsletter-page-status" class="hidden p-3 rounded-lg text-xs font-semibold"></div>
                
                <button
                  type="submit"
                  id="newsletter-page-submit"
                  class="w-full bg-primary-crimson hover:bg-primary-crimson/95 text-white font-bold py-3.5 rounded-lg text-xs uppercase tracking-widest transition shadow-lg hover:shadow-primary-crimson/20 active:scale-98"
                >
                  Join Free Briefing
                </button>
              </form>
              <p class="text-[10px] text-center text-slate-500 mt-4 leading-relaxed">
                By subscribing, you agree to receive weekly updates. Your data is protected under our <a href="/privacy" target="_blank" class="hover:text-primary-gold underline">Privacy Policy</a>.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Inside the newsletter Preview Box & Key Topics -->
    <div class="container mx-auto px-4 max-w-5xl py-16">
      
      <!-- Key Features Section -->
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-xs uppercase tracking-widest font-black text-primary-crimson">What to Expect</span>
        <h2 class="text-3xl font-serif font-black text-slate-900 mt-2 mb-4">Inside Every Weekly Edition</h2>
        <p class="text-slate-500 text-sm leading-relaxed">
          We research and test software so you don't have to. Here is a breakdown of what you'll find in your mailbox every Thursday morning.
        </p>
      </div>

      <!-- Feature Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        {[
          {
            icon: '🤖',
            title: 'Curated AI & Dev Tools',
            desc: 'Weekly digests of newly-released AI utilities, frameworks, and developer helpers, complete with implementation test cases and ROI assessments.'
          },
          {
            icon: '📊',
            title: 'SaaS Deep-Dive Comparisons',
            desc: 'Independent reviews contrasting pricing configurations, performance scores, and user limitations of mainstream software competitors.'
          },
          {
            icon: '⚡',
            title: 'No-Code Automation Guides',
            desc: 'Practical, step-by-step blueprints showing you how to wire APIs, CRMs, and email databases to automate business workflows.'
          }
        ].map(feat => (
          <div class="bg-white rounded-2xl border border-slate-150 p-6 shadow-sm hover:shadow-md hover:border-slate-300 transition duration-200 flex flex-col justify-between">
            <div>
              <span class="text-4xl block mb-4 select-none">{feat.icon}</span>
              <h3 class="font-serif font-black text-slate-950 text-lg mb-2">{feat.title}</h3>
              <p class="text-xs text-slate-500 leading-relaxed">{feat.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Mock Newsletter Preview (Lg Column 7) -->
        <div class="lg:col-span-7 space-y-6">
          <h3 class="text-xl font-serif font-black text-slate-900 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-crimson" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 0h18a2.25 2.25 0 002.25-2.25V5.25A2.25 2.25 0 0019.5 3h-15A2.25 2.25 0 002 5.25v6a2.25 2.25 0 002.25 2.25z" />
            </svg>
            Briefing Sneak-Peek
          </h3>
          
          <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden text-sm">
            <!-- Simulated Mail Header -->
            <div class="bg-slate-100/60 p-4 border-b border-slate-200/80 space-y-1 text-slate-500 text-xs">
              <div><strong class="text-slate-700">From:</strong> Mershal Intel &lt;intel@mershal.in&gt;</div>
              <div><strong class="text-slate-700">Subject:</strong> ⚡ How we built a customer loop using AI + webhook nodes</div>
              <div><strong class="text-slate-700">Date:</strong> Thursday, 08:30 AM EST</div>
            </div>
            
            <!-- Simulated Mail Content -->
            <div class="p-6 md:p-8 space-y-5 text-slate-600 leading-relaxed">
              <div class="w-8 h-8 rounded-lg bg-primary-crimson flex items-center justify-center text-white font-black select-none text-xs">M</div>
              
              <p>Hey operators,</p>
              
              <p>
                Finding new software options is easy, but wiring them together to deliver reliable business output is where most founders get stuck. Today, we're sharing our full setup diagram detailing how we automated 90% of lead routing without writing a single line of backend code.
              </p>
              
              <div class="p-4 bg-slate-50 rounded-xl border border-slate-150 space-y-2">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-400 block">Highlights this week:</span>
                <ul class="space-y-1.5 text-xs text-slate-700 font-medium">
                  <li>🚀 <span class="text-slate-900 font-bold">Tool of the week:</span> We stress-test a new open-source vector search module</li>
                  <li>📊 <span class="text-slate-900 font-bold">CRM Comparisons:</span> HubSpot vs. Pipedrive for small scaling agencies</li>
                  <li>💡 <span class="text-slate-900 font-bold">Automation node:</span> A simple Node-RED structure to parse PDF receipts</li>
                </ul>
              </div>
              
              <p>
                We spent over 12 hours comparing visual logic engines and running performance queries to extract these metrics. Hope this saves you from spending thousands on unnecessary trial subscriptions.
              </p>
              
              <p class="font-serif font-bold text-slate-900">
                — Archit and the Mershal Editorial Team
              </p>
            </div>
          </div>
        </div>

        <!-- FAQs (Lg Column 5) -->
        <div class="lg:col-span-5 space-y-6">
          <h3 class="text-xl font-serif font-black text-slate-900 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-crimson" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
            </svg>
            Frequently Asked Questions
          </h3>

          <div class="space-y-4">
            {[
              {
                q: 'Is it truly free?',
                a: 'Yes, Mershal Intel is 100% free. There are no paywalls or secret tiers. We sustain operations through optional sponsorships and native ad banners in our posts.'
              },
              {
                q: 'How often will I get mail?',
                a: 'Exactly once a week, every Thursday morning. We respect your attention span and never send mid-week updates or promotional notifications.'
              },
              {
                q: 'Can I unsubscribe later?',
                a: 'Of course. Every email contains a clear, single-click unsubscribe link at the footer. We process removals immediately without asking questions.'
              },
              {
                q: 'How do I sponsor an edition?',
                a: 'If you want to promote your SaaS, AI API, or agency service to thousands of developers and decision-makers, please check out our Advertise page or contact us at advertise@mershal.in.'
              }
            ].map((faq, index) => (
              <div class="bg-white rounded-xl border border-slate-150 p-5 shadow-sm">
                <h4 class="font-bold text-slate-900 text-sm mb-1.5">{faq.q}</h4>
                <p class="text-xs text-slate-500 leading-relaxed">{faq.a}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>

<script>
  import { db } from '../lib/firebase';
  import { collection, addDoc, serverTimestamp } from 'firebase/firestore';

  const form = document.getElementById('newsletter-page-form') as HTMLFormElement;
  const emailInput = document.getElementById('newsletter-page-email') as HTMLInputElement;
  const submitBtn = document.getElementById('newsletter-page-submit') as HTMLButtonElement;
  const statusEl = document.getElementById('newsletter-page-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Joining...';
    
    statusEl.classList.add('hidden');

    try {
      // Save subscription doc directly to Firestore collection
      await addDoc(collection(db, 'newsletter_subscribers'), {
        email: email,
        subscribed_at: serverTimestamp(),
        status: 'active'
      });

      statusEl.textContent = '✓ Welcome to Mershal! Please check your inbox for updates.';
      statusEl.className = 'p-3 rounded-lg text-xs font-semibold bg-emerald-950/15 border border-emerald-700/20 text-emerald-800 mb-4 block';
      statusEl.classList.remove('hidden');
      form.reset();
    } catch (error: any) {
      console.error('Newsletter subscription error:', error);
      statusEl.textContent = '✗ Subscription failed. Please try again later.';
      statusEl.className = 'p-3 rounded-lg text-xs font-semibold bg-rose-950/15 border border-rose-700/20 text-rose-800 mb-4 block';
      statusEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
