---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { adminDb } from '../../lib/firebase-admin';

const { category } = Astro.params;

// New categories taxonomy
const validCategories = ['ai-tools', 'saas-reviews', 'productivity', 'freelancing', 'online-business', 'crm', 'marketing'];

if (!category || !validCategories.includes(category.toLowerCase())) {
  return Astro.redirect('/404');
}

const categorySlug = category.toLowerCase();

const categoryMeta: Record<string, { name: string; desc: string; icon: string }> = {
  'ai-tools': { name: 'AI Tools', desc: 'Reviews, comparison guides, and workflows for generative AI models and automation tools.', icon: '🤖' },
  'saas-reviews': { name: 'SaaS Reviews', desc: 'In-depth analyses, pricing updates, and features comparison of software platforms.', icon: '💻' },
  'productivity': { name: 'Productivity', desc: 'Apps, frameworks, and workflows to optimize daily outputs and scale operations.', icon: '📈' },
  'freelancing': { name: 'Freelancing', desc: 'Client acquisition, contract negotiation, pricing models, and gig scaling resources.', icon: '✍️' },
  'online-business': { name: 'Online Business', desc: 'Ecommerce strategy, remote agency models, and scaling digital assets.', icon: '💼' },
  'crm': { name: 'CRM Software', desc: 'Reviews and implementation guides for customer relationships pipelines and sales systems.', icon: '👥' },
  'marketing': { name: 'Digital Marketing', desc: 'SEO audits, conversions optimization, funnel setups, and email list marketing guides.', icon: '📣' },
};

const meta = categoryMeta[categorySlug] || { name: category, desc: `Articles about ${category}`, icon: '📄' };

let articles: any[] = [];

if (adminDb) {
  try {
    // Query articles in category
    let snapshot = await adminDb.collection('articles')
      .where('category', '==', meta.name)
      .where('status', '==', 'published')
      .limit(50)
      .get();
      
    if (snapshot.empty) {
      // Legacy fallback
      snapshot = await adminDb.collection('posts')
        .where('category', '==', categorySlug)
        .where('status', '==', 'published')
        .limit(50)
        .get();
    }

    articles = snapshot.docs.map(doc => {
      const d = doc.data();
      return {
        id: doc.id,
        slug: d.slug || doc.id,
        title: d.title || '',
        excerpt: d.excerpt || '',
        featuredImage: d.featured_image || d.featuredImage || 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=800',
        category: d.category || meta.name,
        categorySlug: categorySlug,
        author: d.author || 'Mershal Editorial Team',
        publishDate: d.publish_date?.toDate?.() || d.publishedAt?.toDate?.() || null,
        readingTime: d.readingTime || d.reading_time || 5,
      };
    }).sort((a, b) => {
      const aT = a.publishDate || new Date(0);
      const bT = b.publishDate || new Date(0);
      return bT.getTime() - aT.getTime();
    });
  } catch (e) {
    console.error(`Category fetch error for ${category}:`, e);
  }
}

const featured = articles[0] || null;
const rest = articles.slice(1);
---

<Layout
  title={`${meta.name} — Mershal`}
  description={meta.desc}
>
  <Header />

  <!-- AdSense Leaderboard Placement -->
  <div class="container mx-auto px-4 max-w-7xl">
    <AdUnit type="header" />
  </div>

  <main class="bg-slate-50 min-h-screen pb-16 font-sans">
    
    <!-- Hero Block -->
    <section class="bg-white border-b border-slate-100 py-10 md:py-14">
      <div class="container mx-auto px-4 max-w-6xl">
        <nav class="flex items-center gap-2 text-xs font-semibold text-slate-400 font-sans mb-4">
          <a href="/" class="hover:text-primary-crimson transition-colors">Home</a>
          <span>›</span>
          <span class="text-slate-700 capitalize">{meta.name}</span>
        </nav>
        
        <div class="flex items-start gap-5 mt-2">
          <span class="text-5xl md:text-6xl p-3 bg-slate-50 rounded-2xl border border-slate-100 flex-shrink-0">{meta.icon}</span>
          <div>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black font-serif text-slate-900 tracking-tight leading-none capitalize">{meta.name}</h1>
            <p class="text-slate-500 text-sm md:text-base mt-2 max-w-xl leading-relaxed">{meta.desc}</p>
          </div>
        </div>

        <!-- Tag pills -->
        <div class="flex flex-wrap gap-2.5 mt-8">
          {validCategories.map(cat => (
            <a
              href={`/category/${cat}`}
              class={`px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider border transition ${
                cat === categorySlug
                  ? 'bg-primary-crimson text-white border-primary-crimson shadow-md hover:bg-primary-crimson/95'
                  : 'bg-white text-slate-600 border-slate-200 hover:border-slate-300 hover:bg-slate-50'
              }`}
            >
              {categoryMeta[cat]?.name || cat}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Content Listing -->
    <div class="container mx-auto px-4 py-12 max-w-6xl">
      {articles.length === 0 ? (
        <div class="bg-white border border-slate-100 shadow-sm rounded-2xl p-16 text-center text-slate-500">
          <span class="text-6xl block mb-4">{meta.icon}</span>
          <h2 class="text-xl font-serif font-black text-slate-900 mb-2">No articles in {meta.name} yet</h2>
          <p class="text-slate-400 text-sm mb-6 max-w-md mx-auto">We are currently researching and writing in this category. Join the newsletter to get notified when articles launch.</p>
          <a href="/" class="inline-flex items-center justify-center bg-slate-900 text-white font-bold text-xs uppercase px-5 py-3 rounded-lg shadow-sm">← Back Home</a>
        </div>
      ) : (
        <div class="space-y-12">
          
          <!-- Hero Featured Card -->
          {featured && (
            <div class="space-y-4">
              <h2 class="text-xs uppercase tracking-widest font-black text-primary-gold">Featured Guide</h2>
              <ArticleCard
                id={featured.id}
                slug={featured.slug}
                title={featured.title}
                excerpt={featured.excerpt}
                imageUrl={featured.featuredImage}
                category={featured.category}
                categorySlug={featured.categorySlug}
                author={featured.author}
                publishDate={featured.publishDate}
                readingTime={featured.readingTime}
                featured={true}
              />
            </div>
          )}

          <!-- Sidebar listing -->
          {rest.length > 0 && (
            <div class="space-y-6 pt-6 border-t border-slate-200/60">
              <h3 class="text-xs uppercase tracking-widest font-black text-slate-900 mb-6">More Guides & Comparisons</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {rest.map(art => (
                  <ArticleCard
                    id={art.id}
                    slug={art.slug}
                    title={art.title}
                    excerpt={art.excerpt}
                    imageUrl={art.featuredImage}
                    category={art.category}
                    categorySlug={art.categorySlug}
                    author={art.author}
                    publishDate={art.publishDate}
                    readingTime={art.readingTime}
                  />
                ))}
              </div>
            </div>
          )}

        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
