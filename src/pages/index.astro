---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BreakingNews from '../components/BreakingNews.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import { adminDb } from '../lib/firebase-admin';

let articles: any[] = [];

if (adminDb) {
  try {
    const snapshot = await adminDb.collection('posts')
      .where('status', '==', 'published')
      .orderBy('publishedAt', 'desc')
      .limit(30)
      .get();

    articles = snapshot.docs.map(doc => {
      const d = doc.data();
      return {
        id: doc.id,
        slug: d.slug,
        title: d.title,
        excerpt: d.excerpt,
        featuredImage: d.featuredImage,
        category: d.category,
        author: d.author || 'Archit Karmakar',
        readingTime: d.readingTime || 0,
        publishedAt: d.publishedAt?.toDate?.() || null,
      };
    });
  } catch (e) {
    console.error('Homepage fetch error:', e);
  }
}

const categories = ['technology', 'programming', 'tutorials'];

// Group articles by category
const byCategory: Record<string, any[]> = {};
categories.forEach(cat => {
  byCategory[cat] = articles.filter(a => a.category === cat);
});

const featured = articles[0] || null;
const latest = articles.slice(0, 6);
---

<Layout title="Mershal — Tech Blog by Archit Karmakar" description="Programming tutorials, web development guides, and tech deep dives by Archit Karmakar.">
  <Header />
  <BreakingNews />

  <main class="bg-gray-50 min-h-screen pb-20 md:pb-8">
    <div class="container mx-auto px-4 py-8 max-w-6xl">

      {articles.length === 0 ? (
        <div class="text-center py-20 bg-white rounded-2xl border border-gray-100">
          <span class="text-5xl mb-4 block">✍️</span>
          <h2 class="text-2xl font-bold text-gray-900 mb-2">No posts yet</h2>
          <p class="text-gray-500 mb-4">Head to the <a href="/admin" class="text-rose-600 hover:underline">admin panel</a> to write your first post.</p>
        </div>
      ) : (
        <>
          {/* Hero featured post */}
          {featured && (
            <div class="mb-10">
              <a href={`/news/${featured.slug}`} class="group block relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300">
                <img
                  src={featured.featuredImage || 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=1200&h=500&fit=crop'}
                  alt={featured.title}
                  class="w-full h-80 md:h-[480px] object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 md:p-10">
                  <div class="flex items-center gap-3 mb-3">
                    <a
                      href={`/category/${featured.category}`}
                      class="bg-rose-600 text-white px-3 py-1 text-xs font-bold uppercase rounded-full hover:bg-rose-700 transition"
                      onclick="event.stopPropagation()"
                    >
                      {featured.category}
                    </a>
                    <span class="text-gray-300 text-xs">{featured.readingTime} min read</span>
                  </div>
                  <h2 class="text-2xl md:text-4xl font-black text-white mb-3 leading-tight max-w-3xl">
                    {featured.title}
                  </h2>
                  <p class="text-gray-300 line-clamp-2 max-w-2xl hidden md:block">{featured.excerpt}</p>
                  <div class="flex items-center gap-2 mt-4">
                    <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-rose-500 to-pink-600 flex items-center justify-center text-white text-xs font-black">AK</div>
                    <span class="text-gray-300 text-sm">{featured.author}</span>
                    {featured.publishedAt && (
                      <span class="text-gray-500 text-xs">· {featured.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                    )}
                  </div>
                </div>
              </a>
            </div>
          )}

          {/* Latest posts */}
          {latest.length > 1 && (
            <section class="mb-12">
              <div class="flex items-center justify-between mb-5">
                <h2 class="text-xl font-black text-gray-900 flex items-center gap-2">
                  <span class="w-1 h-6 bg-rose-600 rounded-full inline-block"></span>
                  Latest Posts
                </h2>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {latest.slice(1).map(article => (
                  <a href={`/news/${article.slug}`} class="group bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                    <div class="overflow-hidden">
                      <img
                        src={article.featuredImage || 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=600&h=340&fit=crop'}
                        alt={article.title}
                        class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                      <div class="flex items-center gap-2 mb-2">
                        <a
                          href={`/category/${article.category}`}
                          class="text-xs font-bold text-rose-600 uppercase hover:text-rose-700 transition capitalize"
                          onclick="event.stopPropagation()"
                        >
                          {article.category}
                        </a>
                        <span class="text-gray-300">·</span>
                        <span class="text-xs text-gray-400">{article.readingTime} min read</span>
                      </div>
                      <h3 class="font-bold text-gray-900 line-clamp-2 group-hover:text-rose-600 transition mb-2 flex-1">
                        {article.title}
                      </h3>
                      <p class="text-sm text-gray-500 line-clamp-2 mb-4">{article.excerpt}</p>
                      <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-50">
                        <span class="text-xs text-gray-400">
                          {article.publishedAt?.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) || ''}
                        </span>
                        <span class="text-xs font-semibold text-rose-600 group-hover:underline">Read →</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}

          {/* Per-category sections */}
          {categories.map(cat => byCategory[cat]?.length > 0 && (
            <section class="mb-12">
              <div class="flex items-center justify-between mb-5">
                <h2 class="text-xl font-black text-gray-900 flex items-center gap-2">
                  <span class="w-1 h-6 bg-rose-600 rounded-full inline-block"></span>
                  {cat.charAt(0).toUpperCase() + cat.slice(1)}
                </h2>
                <a href={`/category/${cat}`} class="text-sm font-semibold text-rose-600 hover:text-rose-700 transition flex items-center gap-1">
                  View all <span>→</span>
                </a>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {byCategory[cat].slice(0, 3).map((article: any) => (
                  <a href={`/news/${article.slug}`} class="group bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                    <div class="overflow-hidden">
                      <img
                        src={article.featuredImage || 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=600&h=340&fit=crop'}
                        alt={article.title}
                        class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="text-xs font-bold text-rose-600 uppercase capitalize">{article.category}</span>
                        <span class="text-gray-300">·</span>
                        <span class="text-xs text-gray-400">{article.readingTime} min read</span>
                      </div>
                      <h3 class="font-bold text-gray-900 line-clamp-2 group-hover:text-rose-600 transition mb-2 flex-1">
                        {article.title}
                      </h3>
                      <p class="text-sm text-gray-500 line-clamp-2 mb-4">{article.excerpt}</p>
                      <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-50">
                        <span class="text-xs text-gray-400">
                          {article.publishedAt?.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) || ''}
                        </span>
                        <span class="text-xs font-semibold text-rose-600 group-hover:underline">Read →</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </>
      )}
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>
