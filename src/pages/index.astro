---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdUnit from '../components/AdUnit.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterBox from '../components/NewsletterBox.astro';
import { Image } from 'astro:assets';
import { adminDb } from '../lib/firebase-admin';
import { getFeaturedImageUrl } from '../lib/utils';

let articles: any[] = [];
let heroArticles: any[] = [];
let latestArticles: any[] = [];

if (adminDb) {
  try {
    // Attempt to fetch from articles first, fallback to posts if collection not migrated yet
    let snapshot = await adminDb.collection('articles')
      .where('status', '==', 'published')
      .orderBy('publish_date', 'desc')
      .limit(15)
      .get();
      
    if (snapshot.empty) {
      // Fallback to legacy posts collection during migration transition
      snapshot = await adminDb.collection('posts')
        .where('status', '==', 'published')
        .orderBy('publishedAt', 'desc')
        .limit(15)
        .get();
    }

    articles = snapshot.docs.map(doc => {
      const d = doc.data();
      return {
        id: doc.id,
        slug: d.slug || doc.id,
        title: d.title || '',
        excerpt: d.excerpt || '',
        featuredImage: getFeaturedImageUrl(d.featured_image || d.featuredImage),
        category: d.category || 'AI Tools',
        categorySlug: (d.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
        author: d.author || 'Mershal Editorial Team',
        publishDate: d.publish_date?.toDate?.() || d.publishedAt?.toDate?.() || null,
        readingTime: d.readingTime || d.reading_time || 5,
        status: d.status || 'published'
      };
    });

    heroArticles = articles.slice(0, 6);
    latestArticles = articles.slice(6, 15);
  } catch (e) {
    console.error('Index page data fetch error:', e);
  }
}

const categoriesList = [
  { name: 'AI Tools', slug: 'ai-tools', desc: 'Reviews & workflows for generative AI models', icon: '🤖', color: 'from-blue-500/10 to-indigo-500/5' },
  { name: 'SaaS Reviews', slug: 'saas-reviews', desc: 'In-depth analyses of software platforms', icon: '💻', color: 'from-emerald-500/10 to-teal-500/5' },
  { name: 'Productivity', slug: 'productivity', desc: 'Apps and frameworks to boost output', icon: '📈', color: 'from-amber-500/10 to-orange-500/5' },
  { name: 'Freelancing', slug: 'freelancing', desc: 'Contracting, pricing models, and clients', icon: '✍️', color: 'from-purple-500/10 to-fuchsia-500/5' },
  { name: 'Online Business', slug: 'online-business', desc: 'Ecommerce, remote agencies, and growth', icon: '💼', color: 'from-rose-500/10 to-pink-500/5' },
  { name: 'CRM', slug: 'crm', desc: 'Customer pipeline and service automation', icon: '👥', color: 'from-cyan-500/10 to-sky-500/5' },
  { name: 'Marketing', slug: 'marketing', desc: 'SEO, conversions, and email newsletters', icon: '📣', color: 'from-violet-500/10 to-purple-500/5' },
];

const trendingGuides = [
  { title: 'Best AI Coding Assistants: Visual Studio & Cursor compared', slug: 'best-ai-coding-assistants' },
  { title: 'Top 10 CRM Platforms for Remote Agencies in 2026', slug: 'top-crm-platforms-remote-agencies' },
  { title: 'How to Build an Automated Lead Generation Machine with Zapier', slug: 'build-automated-lead-gen-zapier' },
];
---

<Layout title="Mershal — The Authority Resource for AI Tools & SaaS Reviews" description="Expert reviews, comparisons, and guides on AI Tools, SaaS platforms, Productivity Software, Freelancing, Online Business, CRM, and Digital Marketing.">
  <Header />

  <!-- Top AdSense Leaderboard Placement -->
  <div class="container mx-auto px-4 max-w-7xl">
    <AdUnit type="header" />
  </div>

  <main class="min-h-screen pb-16 font-sans">
    
    <!-- ── HERO BANNER SECTION (COMPACT 6 POSTS BENTO GRID) ── -->
    <section class="relative bg-gradient-to-b from-slate-900 via-slate-900 to-slate-950 text-white py-6 md:py-8 overflow-hidden border-b border-slate-850">
      <!-- Glow circles -->
      <div class="absolute right-0 top-0 w-[500px] h-[500px] bg-primary-crimson/10 rounded-full blur-3xl"></div>
      <div class="absolute left-1/4 bottom-0 w-[400px] h-[400px] bg-primary-gold/5 rounded-full blur-3xl"></div>
      
      <div class="container mx-auto px-4 max-w-7xl relative z-10">
        {heroArticles.length > 0 && (
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            
            <!-- TOP ROW LEFT: Main Featured Card (Post 1) - Spans 2 Cols, 2 Rows on Desktop -->
            {heroArticles[0] && (
              <a href={`/articles/${heroArticles[0].slug}`} class="lg:col-span-2 lg:row-span-2 group relative overflow-hidden rounded-2xl border border-slate-800/80 bg-slate-900/40 hover:border-primary-crimson/50 hover:shadow-[0_0_30px_rgba(139,2,34,0.3)] transition-all duration-300 flex flex-col justify-end min-h-[300px] lg:min-h-[350px]">
                <!-- Image Background with Gradient Overlay -->
                <div class="absolute inset-0 z-0">
                  <Image src={heroArticles[0].featuredImage} alt={heroArticles[0].title} width={680} height={383} class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-700 opacity-60 group-hover:opacity-75" loading="eager" fetchpriority="high" />
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/60 to-transparent"></div>
                </div>
                
                <!-- Card Details -->
                <div class="relative z-10 p-5 md:p-6 space-y-2">
                  <span class="inline-block px-2.5 py-0.5 bg-primary-crimson text-white text-[9px] font-black uppercase tracking-wider rounded">
                    {heroArticles[0].category}
                  </span>
                  <h2 class="text-xl md:text-2xl font-serif font-black text-white group-hover:text-primary-gold transition-colors leading-tight line-clamp-2">
                    {heroArticles[0].title}
                  </h2>
                  <p class="text-slate-300 text-xs line-clamp-2 max-w-2xl leading-relaxed">
                    {heroArticles[0].excerpt}
                  </p>
                  <div class="flex items-center gap-2 pt-1 text-[10px] text-slate-400 font-mono">
                    <span>By {heroArticles[0].author}</span>
                    <span>•</span>
                    <span>{heroArticles[0].readingTime} min read</span>
                  </div>
                </div>
              </a>
            )}

            <!-- TOP ROW RIGHT: Side Cards (Post 2 & 3) stacked vertically -->
            <div class="flex flex-col gap-4 lg:row-span-2 justify-between">
              
              <!-- Post 2 -->
              {heroArticles[1] && (
                <a href={`/articles/${heroArticles[1].slug}`} class="flex-1 group flex gap-3 p-3.5 rounded-2xl border border-slate-800/80 bg-slate-900/30 hover:bg-slate-900/50 hover:border-primary-crimson/50 transition duration-300 items-center">
                  <div class="w-20 h-20 shrink-0 overflow-hidden rounded-xl relative bg-slate-950">
                    <Image src={heroArticles[1].featuredImage} alt={heroArticles[1].title} width={160} height={160} class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500" loading="lazy" />
                  </div>
                  <div class="flex flex-col justify-between py-1 min-w-0 flex-1">
                    <div class="space-y-1">
                      <span class="text-[9px] font-black uppercase tracking-wider text-primary-gold block">
                        {heroArticles[1].category}
                      </span>
                      <h3 class="font-bold text-xs text-slate-100 group-hover:text-primary-gold transition leading-snug line-clamp-2">
                        {heroArticles[1].title}
                      </h3>
                    </div>
                    <div class="flex items-center gap-2 mt-1.5 text-[9px] text-slate-400 font-mono">
                      <span>{heroArticles[1].readingTime} min read</span>
                    </div>
                  </div>
                </a>
              )}

              <!-- Post 3 -->
              {heroArticles[2] && (
                <a href={`/articles/${heroArticles[2].slug}`} class="flex-1 group flex gap-3 p-3.5 rounded-2xl border border-slate-800/80 bg-slate-900/30 hover:bg-slate-900/50 hover:border-primary-crimson/50 transition duration-300 items-center">
                  <div class="w-20 h-20 shrink-0 overflow-hidden rounded-xl relative bg-slate-950">
                    <Image src={heroArticles[2].featuredImage} alt={heroArticles[2].title} width={160} height={160} class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500" loading="lazy" />
                  </div>
                  <div class="flex flex-col justify-between py-1 min-w-0 flex-1">
                    <div class="space-y-1">
                      <span class="text-[9px] font-black uppercase tracking-wider text-primary-gold block">
                        {heroArticles[2].category}
                      </span>
                      <h3 class="font-bold text-xs text-slate-100 group-hover:text-primary-gold transition leading-snug line-clamp-2">
                        {heroArticles[2].title}
                      </h3>
                    </div>
                    <div class="flex items-center gap-2 mt-1.5 text-[9px] text-slate-400 font-mono">
                      <span>{heroArticles[2].readingTime} min read</span>
                    </div>
                  </div>
                </a>
              )}

            </div>

            <!-- BOTTOM ROW: Posts 4, 5, 6 (Grid of 3 columns) -->
            <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4">
              
              <!-- Post 4 -->
              {heroArticles[3] && (
                <a href={`/articles/${heroArticles[3].slug}`} class="group flex gap-3 p-3 rounded-2xl border border-slate-800/80 bg-slate-900/30 hover:bg-slate-900/50 hover:border-primary-crimson/50 transition duration-300 items-center">
                  <div class="w-16 h-12 shrink-0 overflow-hidden rounded-lg relative bg-slate-950">
                    <Image src={heroArticles[3].featuredImage} alt={heroArticles[3].title} width={128} height={96} class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500" loading="lazy" />
                  </div>
                  <div class="flex flex-col justify-center min-w-0 flex-1">
                    <span class="text-[8px] font-black uppercase tracking-wider text-primary-gold block">
                      {heroArticles[3].category}
                    </span>
                    <h3 class="font-bold text-xs text-slate-150 group-hover:text-primary-gold transition leading-snug line-clamp-1">
                      {heroArticles[3].title}
                    </h3>
                    <div class="text-[8px] text-slate-400 font-mono mt-0.5">
                      <span>{heroArticles[3].readingTime} min read</span>
                    </div>
                  </div>
                </a>
              )}

              <!-- Post 5 -->
              {heroArticles[4] && (
                <a href={`/articles/${heroArticles[4].slug}`} class="group flex gap-3 p-3 rounded-2xl border border-slate-800/80 bg-slate-900/30 hover:bg-slate-900/50 hover:border-primary-crimson/50 transition duration-300 items-center">
                  <div class="w-16 h-12 shrink-0 overflow-hidden rounded-lg relative bg-slate-950">
                    <Image src={heroArticles[4].featuredImage} alt={heroArticles[4].title} width={128} height={96} class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500" loading="lazy" />
                  </div>
                  <div class="flex flex-col justify-center min-w-0 flex-1">
                    <span class="text-[8px] font-black uppercase tracking-wider text-primary-gold block">
                      {heroArticles[4].category}
                    </span>
                    <h3 class="font-bold text-xs text-slate-155 group-hover:text-primary-gold transition leading-snug line-clamp-1">
                      {heroArticles[4].title}
                    </h3>
                    <div class="text-[8px] text-slate-400 font-mono mt-0.5">
                      <span>{heroArticles[4].readingTime} min read</span>
                    </div>
                  </div>
                </a>
              )}

              <!-- Post 6 -->
              {heroArticles[5] && (
                <a href={`/articles/${heroArticles[5].slug}`} class="group flex gap-3 p-3 rounded-2xl border border-slate-800/80 bg-slate-900/30 hover:bg-slate-900/50 hover:border-primary-crimson/50 transition duration-300 items-center">
                  <div class="w-16 h-12 shrink-0 overflow-hidden rounded-lg relative bg-slate-950">
                    <Image src={heroArticles[5].featuredImage} alt={heroArticles[5].title} width={128} height={96} class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500" loading="lazy" />
                  </div>
                  <div class="flex flex-col justify-center min-w-0 flex-1">
                    <span class="text-[8px] font-black uppercase tracking-wider text-primary-gold block">
                      {heroArticles[5].category}
                    </span>
                    <h3 class="font-bold text-xs text-slate-155 group-hover:text-primary-gold transition leading-snug line-clamp-1">
                      {heroArticles[5].title}
                    </h3>
                    <div class="text-[8px] text-slate-400 font-mono mt-0.5">
                      <span>{heroArticles[5].readingTime} min read</span>
                    </div>
                  </div>
                </a>
              )}

            </div>
          </div>
        )}
      </div>
    </section>

    <!-- ── POPULAR CATEGORIES GRID ── -->
    <section class="container mx-auto px-4 max-w-7xl py-12">
      <div class="text-center mb-8">
        <h2 class="text-xs uppercase tracking-widest font-black text-primary-crimson">Explore Topics</h2>
        <h3 class="text-2xl font-black font-serif text-slate-900 mt-1">Popular Content Categories</h3>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-7 gap-4">
        {categoriesList.map(cat => (
          <a
            href={`/category/${cat.slug}`}
            class={`group relative rounded-xl p-5 border border-slate-100 bg-white shadow-sm hover:shadow-md transition-all duration-300 flex flex-col items-center text-center`}
          >
            <span class="text-3xl mb-3 transform group-hover:scale-110 transition-transform duration-300">{cat.icon}</span>
            <span class="text-xs font-black uppercase tracking-wider text-slate-800 group-hover:text-primary-crimson transition-colors">{cat.name}</span>
          </a>
        ))}
      </div>
    </section>


    <!-- ── LATEST & SIDEBAR SECTION ── -->
    <section class="container mx-auto px-4 max-w-7xl py-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-8">
        
        <!-- Left: Latest Articles List -->
        <div>
          <div class="border-b border-slate-200 pb-4 mb-6">
            <h2 class="text-lg font-black font-serif text-slate-900 flex items-center gap-2">
              <span class="w-1 h-5 bg-primary-gold rounded-full inline-block"></span>
              Latest Guides & Reviews
            </h2>
          </div>
          
          {latestArticles.length === 0 ? (
            <div class="bg-white rounded-2xl border border-slate-100 p-12 text-center text-slate-500">
              <p class="text-sm font-semibold mb-2">No articles published yet.</p>
              <a href="/admin/articles/new" class="text-primary-crimson font-bold text-xs uppercase hover:underline">Write one now →</a>
            </div>
          ) : (
            <div class="space-y-6">
              {latestArticles.map(art => (
                <ArticleCard
                  id={art.id}
                  slug={art.slug}
                  title={art.title}
                  excerpt={art.excerpt}
                  imageUrl={art.featuredImage}
                  category={art.category}
                  categorySlug={art.categorySlug}
                  author={art.author}
                  publishDate={art.publishDate}
                  readingTime={art.readingTime}
                />
              ))}
            </div>
          )}
        </div>

        <!-- Right Sidebar -->
        <aside class="space-y-8">
          
          <!-- Sticky Sidebar Ad Slot -->
          <div class="sticky top-24 space-y-6">
            <AdUnit type="sidebar" />
            
            <!-- Trending Guides Box -->
            <div class="bg-white rounded-xl p-5 border border-slate-100 shadow-sm">
              <h3 class="text-xs uppercase tracking-widest font-black text-primary-crimson mb-4">Trending Guides</h3>
              <ul class="space-y-4">
                {trendingGuides.map((guide, idx) => (
                  <li class="flex items-start gap-2.5">
                    <span class="text-slate-300 font-serif font-black text-xl mt-[-3px]">0{idx + 1}</span>
                    <a href={`/articles/${guide.slug}`} class="text-sm font-bold text-slate-700 hover:text-primary-crimson transition leading-snug line-clamp-2">
                      {guide.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
            
            <!-- Category Hub Links -->
            <div class="bg-white rounded-xl p-5 border border-slate-100 shadow-sm">
              <h3 class="text-xs uppercase tracking-widest font-black text-primary-gold mb-3">Topic Clusters</h3>
              <div class="divide-y divide-slate-50">
                {categoriesList.slice(0, 5).map(cat => (
                  <a href={`/category/${cat.slug}`} class="flex items-center justify-between py-2.5 text-xs text-slate-600 hover:text-primary-crimson transition font-semibold">
                    <span>{cat.name}</span>
                    <svg class="w-3.5 h-3.5 text-slate-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- ── NEWSLETTER BOX SECTION ── -->
    <section class="container mx-auto px-4 max-w-7xl py-6">
      <NewsletterBox />
    </section>
  </main>

  <Footer />
</Layout>


<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-none {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
