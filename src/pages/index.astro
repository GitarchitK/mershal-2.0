---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BreakingNews from '../components/BreakingNews.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import { adminDb } from '../lib/firebase-admin';

let articles: any[] = [];

if (adminDb) {
  try {
    const snapshot = await adminDb.collection('posts')
      .where('status', '==', 'published')
      .orderBy('publishedAt', 'desc')
      .limit(100)
      .get();
    articles = snapshot.docs.map(doc => {
      const d = doc.data();
      return {
        id: doc.id, slug: d.slug, title: d.title,
        excerpt: d.excerpt, featuredImage: d.featuredImage,
        category: d.category, readingTime: d.readingTime || 0,
        publishedAt: d.publishedAt?.toDate?.() || null,
      };
    });
  } catch (e) { console.error('Homepage fetch error:', e); }
}

const categories = ['world', 'politics', 'business', 'technology', 'sports', 'entertainment'];
const byCategory: Record<string, any[]> = {};
categories.forEach(cat => {
  byCategory[cat] = articles.filter(a => a.category?.toLowerCase() === cat);
});

// Hero: first article is big, next 3 are stacked right
const hero = articles[0] || null;
const heroStack = articles.slice(1, 5);
// Latest ticker: next 8
const latestTicker = articles.slice(5, 13);
// Sidebar: latest 12 for right sidebar
const sidebarArticles = articles.slice(0, 12);

function imgUrl(url: string, w: number, h: number) {
  if (!url) return `https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=${w}&h=${h}&fit=crop&auto=format&q=70`;
  return `${url.split('?')[0]}?w=${w}&h=${h}&fit=crop&auto=format&q=75`;
}

function timeAgo(date: Date | null) {
  if (!date) return '';
  const diff = Math.floor((Date.now() - date.getTime()) / 60000);
  if (diff < 60) return `${diff}m ago`;
  if (diff < 1440) return `${Math.floor(diff/60)}h ago`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<Layout title="Mershal — Breaking World News" description="Breaking news and comprehensive coverage of world events. Politics, business, technology, sports, and entertainment.">
  <Header />
  <BreakingNews />

  <main class="bg-gray-100 min-h-screen pb-20 md:pb-4">
    <div class="container mx-auto px-3 md:px-4 max-w-7xl py-4">

      {articles.length === 0 ? (
        <div class="text-center py-20 bg-white">
          <p class="text-gray-500 mb-2">No articles yet.</p>
          <a href="/admin" class="text-red-600 hover:underline text-sm font-semibold">Go to Admin Panel →</a>
        </div>
      ) : (
        <>
          {/* ── HERO SECTION ── */}
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-4 mb-4">

            {/* Left: Big featured story */}
            {hero && (
              <a href={`/news/${hero.slug}`} class="group relative block overflow-hidden bg-black">
                <img
                  src={imgUrl(hero.featuredImage, 900, 520)}
                  alt={hero.title}
                  width="900" height="520"
                  fetchpriority="high"
                  class="w-full h-[320px] md:h-[420px] object-cover opacity-90 group-hover:opacity-80 group-hover:scale-105 transition-all duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-4 md:p-6">
                  <span class="inline-block bg-red-600 text-white text-xs font-black uppercase px-2.5 py-1 mb-2 tracking-wider">
                    {hero.category}
                  </span>
                  <h2 class="text-white text-xl md:text-2xl lg:text-3xl font-black leading-tight line-clamp-3 group-hover:text-red-300 transition">
                    {hero.title}
                  </h2>
                  <p class="text-gray-300 text-sm mt-2 line-clamp-2 hidden md:block">{hero.excerpt}</p>
                  <p class="text-gray-400 text-xs mt-2">{timeAgo(hero.publishedAt)}</p>
                </div>
              </a>
            )}

            {/* Right: 3 stacked stories */}
            <div class="flex flex-col gap-3">
              {heroStack.map(a => (
                <a href={`/news/${a.slug}`} class="group flex gap-3 bg-white hover:bg-red-50 transition p-2.5 border-b border-gray-100">
                  <img
                    src={imgUrl(a.featuredImage, 200, 130)}
                    alt={a.title}
                    width="110" height="75"
                    loading="lazy"
                    class="w-28 h-20 object-cover flex-shrink-0"
                  />
                  <div class="flex-1 min-w-0">
                    <span class="text-xs font-black text-red-600 uppercase tracking-wide">{a.category}</span>
                    <h3 class="text-sm font-bold text-gray-900 line-clamp-3 leading-snug mt-0.5 group-hover:text-red-600 transition">{a.title}</h3>
                    <p class="text-xs text-gray-400 mt-1">{timeAgo(a.publishedAt)}</p>
                  </div>
                </a>
              ))}
              {/* Latest ticker box */}
              {latestTicker.length > 0 && (
                <div class="bg-white border-t-4 border-red-600 p-3 flex-1">
                  <p class="text-xs font-black text-red-600 uppercase tracking-widest mb-2">Latest</p>
                  <ul class="space-y-2">
                    {latestTicker.slice(0, 6).map(a => (
                      <li>
                        <a href={`/news/${a.slug}`} class="text-xs text-gray-800 hover:text-red-600 transition font-medium line-clamp-2 leading-snug block">
                          › {a.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>

          {/* ── ELECTION RESULTS WIDGET ── */}
          <div class="mb-4 bg-white border-t-4 border-red-600">
            <!-- Tab header -->
            <div class="flex items-center border-b border-gray-200">
              <div class="bg-red-600 text-white px-4 py-2.5 text-xs font-black uppercase tracking-widest flex-shrink-0">
                🗳️ Election Results 2026
              </div>
              <div class="flex overflow-x-auto scrollbar-hide">
                <button onclick="showElection('wb')" id="tab-wb"
                  class="election-tab active-tab px-5 py-2.5 text-xs font-bold uppercase tracking-wide whitespace-nowrap border-b-2 border-red-600 text-red-600">
                  West Bengal
                </button>
                <button onclick="showElection('tn')" id="tab-tn"
                  class="election-tab px-5 py-2.5 text-xs font-bold uppercase tracking-wide whitespace-nowrap border-b-2 border-transparent text-gray-500 hover:text-red-600 transition">
                  Tamil Nadu
                </button>
              </div>
            </div>

            <!-- West Bengal Results -->
            <div id="election-wb" class="election-panel p-4">
              <div class="flex items-center justify-between mb-3">
                <div>
                  <p class="text-xs text-gray-500 font-medium">West Bengal Assembly Elections 2026</p>
                  <p class="text-xs text-gray-400">Total Seats: 294 · Majority: 148 · Counted: 293</p>
                </div>
                <span class="text-xs bg-orange-100 text-orange-700 font-bold px-2 py-1 rounded">Results Declared</span>
              </div>
              <div class="space-y-2.5">
                {[
                  { party: 'BJP', name: 'Bharatiya Janata Party', color: '#f97316', won: 207, leading: 0, total: 207 },
                  { party: 'AITC', name: 'All India Trinamool Congress', color: '#1a56db', won: 80, leading: 0, total: 80 },
                  { party: 'INC', name: 'Indian National Congress', color: '#16a34a', won: 2, leading: 0, total: 2 },
                  { party: 'AJUP', name: 'Aam Janata Unnayan Party', color: '#7c3aed', won: 2, leading: 0, total: 2 },
                  { party: 'CPI(M)', name: 'Communist Party of India (Marxist)', color: '#dc2626', won: 1, leading: 0, total: 1 },
                  { party: 'AISF', name: 'All India Secular Front', color: '#0891b2', won: 1, leading: 0, total: 1 },
                ].map(p => (
                  <div class="flex items-center gap-3">
                    <div class="w-14 text-xs font-black text-center py-1 text-white rounded-sm flex-shrink-0 truncate px-1" style={`background:${p.color}`}>{p.party}</div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between mb-0.5">
                        <span class="text-xs text-gray-600 font-medium truncate max-w-[160px]">{p.name}</span>
                        <span class="text-xs font-black text-gray-900 ml-2 flex-shrink-0">
                          <span class="text-green-700">{p.won}</span>
                          {p.leading > 0 && <span class="text-yellow-600"> +{p.leading}</span>}
                        </span>
                      </div>
                      <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                        <div class="h-full rounded-full" style={`width:${Math.max(Math.round((p.total/294)*100), p.total > 0 ? 1 : 0)}%; background:${p.color}`}></div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-3 pt-2 border-t border-gray-100 flex items-center justify-between">
                <p class="text-xs text-gray-400">BJP wins majority · 293/294 seats counted</p>
                <span class="text-xs font-bold text-orange-600">BJP WINS 🏆</span>
              </div>
            </div>

            <!-- Tamil Nadu Results -->
            <div id="election-tn" class="election-panel hidden p-4">
              <div class="flex items-center justify-between mb-3">
                <div>
                  <p class="text-xs text-gray-500 font-medium">Tamil Nadu Assembly Elections 2026</p>
                  <p class="text-xs text-gray-400">Total Seats: 234 · Majority: 118</p>
                </div>
                <span class="text-xs bg-green-100 text-green-700 font-bold px-2 py-1 rounded">Counting Live</span>
              </div>
              <div class="space-y-2.5">
                {[
                  { party: 'DMK', name: 'Dravida Munnetra Kazhagam', color: '#dc2626', seats: 128, leading: 14, total: 142 },
                  { party: 'AIADMK', name: 'All India Anna DMK', color: '#16a34a', seats: 62, leading: 8, total: 70 },
                  { party: 'BJP', name: 'Bharatiya Janata Party', color: '#f97316', seats: 8, leading: 2, total: 10 },
                  { party: 'Others', name: 'Others', color: '#6b7280', seats: 8, leading: 4, total: 12 },
                ].map(p => (
                  <div class="flex items-center gap-3">
                    <div class="w-12 text-xs font-black text-center py-1 text-white rounded-sm flex-shrink-0" style={`background:${p.color}`}>{p.party}</div>
                    <div class="flex-1">
                      <div class="flex items-center justify-between mb-0.5">
                        <span class="text-xs text-gray-600 font-medium truncate max-w-[140px]">{p.name}</span>
                        <span class="text-xs font-black text-gray-900 ml-2">{p.total} <span class="text-gray-400 font-normal">(W:{p.seats} L:{p.leading})</span></span>
                      </div>
                      <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                        <div class="h-full rounded-full" style={`width:${Math.round((p.total/234)*100)}%; background:${p.color}`}></div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              <p class="text-xs text-gray-400 mt-3">* Indicative data. Updated manually. W = Won, L = Leading</p>
            </div>
          </div>

          {/* ── MAIN CONTENT + SIDEBAR ── */}
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-4">

            {/* Main column */}
            <div class="space-y-6">

              {categories.map(cat => byCategory[cat]?.length > 0 && (
                <section>
                  {/* Category header bar */}
                  <div class="flex items-center justify-between bg-red-600 text-white px-3 py-2 mb-3">
                    <h2 class="text-sm font-black uppercase tracking-widest">{cat.charAt(0).toUpperCase() + cat.slice(1)}</h2>
                    <a href={`/category/${cat}`} class="text-xs text-red-200 hover:text-white transition font-semibold uppercase tracking-wide">
                      More →
                    </a>
                  </div>

                  {/* First article: large left + 2 small right */}
                  {byCategory[cat].length >= 1 && (
                    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-3 mb-3">
                      {/* Big card */}
                      <a href={`/news/${byCategory[cat][0].slug}`} class="group relative block overflow-hidden bg-black">
                        <img
                          src={imgUrl(byCategory[cat][0].featuredImage, 600, 360)}
                          alt={byCategory[cat][0].title}
                          width="600" height="360"
                          loading="lazy"
                          class="w-full h-52 object-cover opacity-90 group-hover:opacity-80 group-hover:scale-105 transition-all duration-300"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
                        <div class="absolute bottom-0 left-0 right-0 p-3">
                          <h3 class="text-white text-sm md:text-base font-bold line-clamp-3 leading-snug group-hover:text-red-300 transition">
                            {byCategory[cat][0].title}
                          </h3>
                          <p class="text-gray-400 text-xs mt-1">{timeAgo(byCategory[cat][0].publishedAt)}</p>
                        </div>
                      </a>

                      {/* 2 small stacked */}
                      <div class="flex flex-col gap-3">
                        {byCategory[cat].slice(1, 3).map((a: any) => (
                          <a href={`/news/${a.slug}`} class="group flex gap-2.5 bg-white hover:bg-red-50 transition p-2 border-b border-gray-100">
                            <img
                              src={imgUrl(a.featuredImage, 180, 120)}
                              alt={a.title}
                              width="90" height="65"
                              loading="lazy"
                              class="w-24 h-16 object-cover flex-shrink-0"
                            />
                            <div class="flex-1 min-w-0">
                              <h4 class="text-xs font-bold text-gray-900 line-clamp-3 leading-snug group-hover:text-red-600 transition">{a.title}</h4>
                              <p class="text-xs text-gray-400 mt-1">{timeAgo(a.publishedAt)}</p>
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* Bottom row: up to 6 cards */}
                  {byCategory[cat].length > 3 && (
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                      {byCategory[cat].slice(3, 9).map((a: any) => (
                        <a href={`/news/${a.slug}`} class="group bg-white hover:shadow-md transition overflow-hidden">
                          <img
                            src={imgUrl(a.featuredImage, 400, 240)}
                            alt={a.title}
                            width="400" height="240"
                            loading="lazy"
                            class="w-full h-36 object-cover group-hover:opacity-90 transition"
                          />
                          <div class="p-2.5">
                            <h4 class="text-xs font-bold text-gray-900 line-clamp-2 leading-snug group-hover:text-red-600 transition">{a.title}</h4>
                            <p class="text-xs text-gray-400 mt-1">{timeAgo(a.publishedAt)}</p>
                          </div>
                        </a>
                      ))}
                    </div>
                  )}
                </section>
              ))}
            </div>

            {/* Sidebar */}
            <aside class="space-y-5">

              {/* Latest News list */}
              <div>
                <div class="bg-red-600 text-white px-3 py-2 mb-0">
                  <h3 class="text-sm font-black uppercase tracking-widest">Latest News</h3>
                </div>
                <div class="bg-white divide-y divide-gray-100">
                  {sidebarArticles.map(a => (
                    <a href={`/news/${a.slug}`} class="group flex gap-2.5 p-2.5 hover:bg-red-50 transition">
                      <img
                        src={imgUrl(a.featuredImage, 160, 100)}
                        alt={a.title}
                        width="70" height="50"
                        loading="lazy"
                        class="w-16 h-12 object-cover flex-shrink-0"
                      />
                      <div class="flex-1 min-w-0">
                        <span class="text-xs font-black text-red-600 uppercase">{a.category}</span>
                        <h4 class="text-xs font-semibold text-gray-900 line-clamp-2 leading-snug group-hover:text-red-600 transition mt-0.5">{a.title}</h4>
                        <p class="text-xs text-gray-400 mt-0.5">{timeAgo(a.publishedAt)}</p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>

              {/* Categories box */}
              <div>
                <div class="bg-gray-900 text-white px-3 py-2">
                  <h3 class="text-sm font-black uppercase tracking-widest">Browse Topics</h3>
                </div>
                <div class="bg-white divide-y divide-gray-100">
                  {categories.map(cat => (
                    <a href={`/category/${cat}`}
                       class="flex items-center justify-between px-3 py-2.5 text-sm text-gray-700 hover:text-red-600 hover:bg-red-50 transition font-medium">
                      <span class="capitalize">{cat}</span>
                      <svg class="w-3.5 h-3.5 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
                    </a>
                  ))}
                </div>
              </div>

            </aside>
          </div>
        </>
      )}
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>

<script>
  function showElection(state: string) {
    document.querySelectorAll('.election-panel').forEach(p => p.classList.add('hidden'));
    document.querySelectorAll('.election-tab').forEach(t => {
      t.classList.remove('active-tab', 'border-red-600', 'text-red-600');
      t.classList.add('border-transparent', 'text-gray-500');
    });
    document.getElementById(`election-${state}`)?.classList.remove('hidden');
    const tab = document.getElementById(`tab-${state}`);
    tab?.classList.add('active-tab', 'border-red-600', 'text-red-600');
    tab?.classList.remove('border-transparent', 'text-gray-500');
  }
  (window as any).showElection = showElection;
</script>
