---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout
  title="About Us — Mershal World News"
  description="Mershal is a digital news publication delivering breaking news and in-depth coverage of world events across politics, business, technology, sports, and entertainment."
>
  <Header />

  <main class="bg-white pb-20 md:pb-8">

    <!-- Page Header -->
    <div class="bg-red-600 text-white">
      <div class="container mx-auto px-4 max-w-5xl py-12">
        <p class="text-red-200 text-xs font-bold uppercase tracking-widest mb-2">Who We Are</p>
        <h1 class="text-4xl md:text-5xl font-black leading-tight mb-4">About Mershal</h1>
        <p class="text-red-100 text-lg max-w-2xl leading-relaxed">
          Delivering breaking news and in-depth coverage of world events — trusted, fast, and independent.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-10">

          <!-- Mission -->
          <section>
            <h2 class="text-2xl font-black text-gray-900 mb-1 pb-2 border-b-4 border-red-600 inline-block">Our Mission</h2>
            <div class="mt-5 space-y-4 text-gray-700 leading-relaxed text-[1.0625rem]">
              <p>
                Mershal was founded with a single purpose: to deliver accurate, timely, and comprehensive news coverage to readers around the world. In an era of information overload, we cut through the noise to bring you the stories that matter.
              </p>
              <p>
                We believe that access to reliable news is a fundamental right. Our editorial team works around the clock to ensure that every story we publish meets the highest standards of accuracy, fairness, and journalistic integrity.
              </p>
              <p>
                From breaking political developments to business trends, from technology breakthroughs to sports highlights — Mershal covers it all with depth, context, and clarity.
              </p>
            </div>
          </section>

          <!-- What We Cover -->
          <section>
            <h2 class="text-2xl font-black text-gray-900 mb-1 pb-2 border-b-4 border-red-600 inline-block">What We Cover</h2>
            <div class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { icon: '🌍', title: 'World News', desc: 'Breaking news and analysis of global events, international relations, and geopolitical developments.' },
                { icon: '🏛️', title: 'Politics', desc: 'Elections, government policy, legislative updates, and political analysis from every corner of the world.' },
                { icon: '💼', title: 'Business & Economy', desc: 'Markets, finance, corporate news, economic indicators, and business strategy.' },
                { icon: '💻', title: 'Technology', desc: 'Tech industry news, product launches, AI developments, and the digital economy.' },
                { icon: '⚽', title: 'Sports', desc: 'Live scores, match reports, transfer news, and analysis from major sports worldwide.' },
                { icon: '🎬', title: 'Entertainment', desc: 'Movies, music, celebrity news, streaming, and cultural events from around the globe.' },
              ].map(item => (
                <div class="flex gap-4 p-4 border border-gray-100 hover:border-red-200 hover:bg-red-50 transition">
                  <span class="text-2xl flex-shrink-0">{item.icon}</span>
                  <div>
                    <h3 class="font-bold text-gray-900 text-sm mb-1">{item.title}</h3>
                    <p class="text-xs text-gray-600 leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- Editorial Standards -->
          <section>
            <h2 class="text-2xl font-black text-gray-900 mb-1 pb-2 border-b-4 border-red-600 inline-block">Editorial Standards</h2>
            <div class="mt-5 space-y-4 text-gray-700 leading-relaxed text-[1.0625rem]">
              <p>
                Every article published on Mershal goes through a rigorous editorial process. We verify facts from multiple sources before publication, clearly distinguish between news reporting and opinion, and issue corrections promptly when errors occur.
              </p>
              <p>
                We are committed to editorial independence. Our news coverage is not influenced by advertisers, political affiliations, or commercial interests. We report the facts as they are.
              </p>
              <blockquote class="border-l-4 border-red-600 pl-4 my-6">
                <p class="text-lg italic text-gray-700 font-light">"Our commitment is to the truth — reported accurately, delivered quickly, and presented with the context readers need to understand the world."</p>
                <footer class="text-sm text-gray-500 mt-2 not-italic">— Mershal Editorial Team</footer>
              </blockquote>
            </div>
          </section>

        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">

          <!-- Quick Facts -->
          <div class="border border-gray-200">
            <div class="bg-gray-900 text-white px-4 py-3">
              <p class="text-xs font-black uppercase tracking-widest">Publication Info</p>
            </div>
            <div class="divide-y divide-gray-100">
              {[
                { label: 'Founded', value: '2026' },
                { label: 'Coverage', value: 'Global' },
                { label: 'Language', value: 'English' },
                { label: 'Format', value: 'Digital' },
                { label: 'Website', value: 'mershal.in' },
                { label: 'Email', value: 'contact@mershal.in' },
              ].map(item => (
                <div class="flex justify-between px-4 py-2.5 text-sm">
                  <span class="text-gray-500 font-medium">{item.label}</span>
                  <span class="text-gray-900 font-semibold">{item.value}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Categories -->
          <div class="border border-gray-200">
            <div class="bg-red-600 text-white px-4 py-3">
              <p class="text-xs font-black uppercase tracking-widest">Our Sections</p>
            </div>
            <div class="divide-y divide-gray-100">
              {['World', 'Politics', 'Business', 'Technology', 'Sports', 'Entertainment'].map(cat => (
                <a href={`/category/${cat.toLowerCase()}`}
                   class="flex items-center justify-between px-4 py-2.5 text-sm text-gray-700 hover:text-red-600 hover:bg-red-50 transition font-medium">
                  {cat}
                  <svg class="w-3.5 h-3.5 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
                </a>
              ))}
            </div>
          </div>

          <!-- Contact CTA -->
          <div class="bg-gray-900 text-white p-5">
            <h3 class="font-bold mb-2 text-sm uppercase tracking-wide">Get in Touch</h3>
            <p class="text-gray-400 text-sm mb-4 leading-relaxed">News tips, corrections, advertising enquiries, or general questions.</p>
            <a href="/contact" class="block text-center bg-red-600 hover:bg-red-700 text-white py-2.5 text-sm font-bold transition">
              Contact Us
            </a>
          </div>

        </aside>
      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>
