---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BreakingNews from '../components/BreakingNews.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="About Mershal - Tech Tutorials & Programming Blog" description="Learn programming, web development, and tech skills with Mershal - Your friendly tech blog by Archit Karmakar">
  <Header />
  <BreakingNews />
  
  <main class="container mx-auto px-4 py-8 pb-20 md:pb-8">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold mb-6">About Mershal</h1>
      
      <div class="prose prose-lg max-w-none">
        <p class="text-xl text-gray-600 mb-8">
          Welcome to <strong>Mershal</strong> - your go-to destination for programming tutorials, tech guides, and developer resources!
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Who Am I?</h2>
        <p class="mb-4">
          Hey! I'm <strong>Archit Karmakar</strong>, a full-stack developer and tech enthusiast from India. I started Mershal to share what I learn on my coding journey and help fellow developers level up their skills.
        </p>
        <p class="mb-4">
          With experience in JavaScript, Python, React, Node.js, and more, I write about real-world projects, practical tutorials, and stuff I actually use in my own work.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">What You'll Find Here</h2>
        <ul class="list-disc pl-6 mb-6 space-y-2">
          <li><strong>Programming Tutorials</strong> - Step-by-step guides for Python, JavaScript, React, and more</li>
          <li><strong>Web Development</strong> - Build modern websites with HTML, CSS, React, and Next.js</li>
          <li><strong>App Development</strong> - Create mobile apps with Flutter, React Native, and more</li>
          <li><strong>DevOps & Tools</strong> - Docker, Git, VS Code tips, and developer workflows</li>
          <li><strong>Career Advice</strong> - Job tips, interview prep, and freelance guidance</li>
          <li><strong>Tech Reviews</strong> - Honest opinions on tools, gadgets, and software</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">My Approach</h2>
        <p class="mb-4">
          I write the way I'd explain to a friend - casual, practical, and with real code examples. No fluff, just actionable content that actually helps you build things.
        </p>
        <p class="mb-4">
          Everything here is based on my personal experience building projects. I share what worked, what didn't, and what I'd do differently.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Let's Connect!</h2>
        <p class="mb-4">
          Got questions? Want to collaborate? Just want to say hi? Drop me a message on the <a href="/contact" class="text-red-600 hover:underline">contact page</a>!
        </p>
        <p class="mb-4">
          I read and reply to every message. Thanks for being part of this journey! 🚀
        </p>

        <div class="bg-gray-100 p-6 rounded-lg mt-8">
          <h3 class="text-xl font-bold mb-3">Tech Stack I Use</h3>
          <div class="flex flex-wrap gap-2">
            <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">JavaScript</span>
            <span class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-sm">Python</span>
            <span class="bg-cyan-100 text-cyan-800 px-3 py-1 rounded-full text-sm">React</span>
            <span class="bg-gray-800 text-white px-3 py-1 rounded-full text-sm">Node.js</span>
            <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm">TypeScript</span>
            <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm">MongoDB</span>
            <span class="bg-red-100 text-red-800 px-3 py-1 rounded-full text-sm">Firebase</span>
            <span class="bg-orange-100 text-orange-800 px-3 py-1 rounded-full text-sm">Docker</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>