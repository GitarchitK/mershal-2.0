---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout
  title="About Mershal — Breaking World News"
  description="Mershal is a world news publication delivering breaking news and in-depth coverage of global events."
>
  <Header />

  <main class="bg-gray-50 pb-20 md:pb-8">

    <!-- Hero -->
    <section class="bg-white border-b border-gray-100 py-16">
      <div class="container mx-auto px-4 max-w-4xl text-center">
        <div class="w-16 h-16 bg-rose-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
          <span class="text-2xl font-black text-white logo-font">M</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">About Mershal</h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed">
          Your trusted source for breaking news and global coverage
        </p>
      </div>
    </section>

    <div class="container mx-auto px-4 py-12 max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Main Content -->
        <div class="md:col-span-2 space-y-8">

          <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-gray-900 mb-5">What is Mershal?</h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>
                Mershal is a digital news publication delivering breaking news, in-depth analysis, and comprehensive coverage of world events. We cover politics, business, technology, sports, and entertainment from every corner of the globe.
              </p>
            </div>
          </section>

          <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">What We Cover</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex items-start gap-3 p-4 bg-rose-50 rounded-xl">
                <span class="text-2xl">🌍</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">World News</h3>
                  <p class="text-xs text-gray-600">Breaking news and in-depth coverage of global events and international affairs.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-4 bg-blue-50 rounded-xl">
                <span class="text-2xl">🏛️</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Politics</h3>
                  <p class="text-xs text-gray-600">Political news, elections, government policy, and analysis from around the world.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-4 bg-green-50 rounded-xl">
                <span class="text-2xl">💼</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Business & Economy</h3>
                  <p class="text-xs text-gray-600">Markets, economy, finance, startups, and business news from across the globe.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-4 bg-purple-50 rounded-xl">
                <span class="text-2xl">💻</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Technology</h3>
                  <p class="text-xs text-gray-600">Tech news, product launches, AI, and the latest from the world of technology.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-4 bg-yellow-50 rounded-xl">
                <span class="text-2xl">⚽</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Sports</h3>
                  <p class="text-xs text-gray-600">Sports news, scores, analysis, and coverage of major events worldwide.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-4 bg-pink-50 rounded-xl">
                <span class="text-2xl">🎬</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Entertainment</h3>
                  <p class="text-xs text-gray-600">Movies, music, celebrity news, and entertainment from around the world.</p>
                </div>
              </div>
            </div>
          </section>

          <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-gray-900 mb-5">Our Editorial Approach</h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>
                We report the facts, provide context, and deliver news that matters. Our coverage spans every continent and every major story.
              </p>
              <blockquote class="border-l-4 border-rose-500 pl-4 italic text-gray-700 my-4">
                "Accurate, timely, and comprehensive — news you can trust."
              </blockquote>
            </div>
          </section>

        </div>

        <!-- Sidebar -->
        <div class="space-y-6">

          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-4 text-sm uppercase tracking-wider">Publication Info</h3>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-center gap-2"><span>🌐</span> mershal.in</li>
              <li class="flex items-center gap-2"><span>📍</span> India</li>
              <li class="flex items-center gap-2"><span>🗓️</span> Est. 2026</li>
              <li class="flex items-center gap-2"><span>🎯</span> World News</li>
              <li class="flex items-center gap-2"><span>📧</span> contact@mershal.in</li>
            </ul>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-4 text-sm uppercase tracking-wider">Topics We Cover</h3>
            <div class="flex flex-wrap gap-2">
              {['World', 'Politics', 'Business', 'Technology', 'Sports', 'Entertainment', 'Breaking News', 'Analysis'].map(tag => (
                <span class="bg-gray-100 text-gray-700 px-2.5 py-1 rounded-lg text-xs font-medium">{tag}</span>
              ))}
            </div>
          </div>

          <div class="bg-gray-900 rounded-2xl p-6 text-white">
            <h3 class="font-bold mb-2">Work With Us</h3>
            <p class="text-gray-400 text-sm mb-4">Interested in advertising or sponsoring content on Mershal?</p>
            <a href="/advertise" class="block text-center bg-rose-600 hover:bg-rose-700 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition mb-2">
              Advertise
            </a>
            <a href="/contact" class="block text-center bg-gray-800 hover:bg-gray-700 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition">
              Contact Us
            </a>
          </div>

        </div>
      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>

<style>
  .logo-font {
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
  }
</style>
