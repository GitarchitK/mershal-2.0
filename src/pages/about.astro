---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="About Us">
  <Header />
  
  <main class="container mx-auto px-4 py-8 pb-20 md:pb-8">
    <div class="max-w-6xl mx-auto">
      <!-- Hero Section -->
      <div class="bg-gradient-to-r from-red-600 to-red-700 rounded-2xl p-12 mb-8 text-white shadow-2xl">
        <h1 class="text-5xl font-bold mb-4">About Mershal</h1>
        <p class="text-xl opacity-90">Your Trusted Source for News & Information</p>
      </div>
      
      <!-- Main Content Grid -->
      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <!-- Who We Are -->
        <div class="bg-white rounded-2xl shadow-lg p-8 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/>
            </svg>
          </div>
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Who We Are</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Mershal is a leading digital news platform dedicated to delivering accurate, timely, and comprehensive news coverage across India and beyond.
          </p>
          <p class="text-gray-700 leading-relaxed">
            Developed by <span class="text-red-600 font-semibold">Navroll Studio</span>, we are committed to journalistic excellence and providing our readers with trustworthy information.
          </p>
        </div>

        <!-- Our Mission -->
        <div class="bg-white rounded-2xl shadow-lg p-8 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
            </svg>
          </div>
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Mission</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            To keep you informed about the latest developments in politics, sports, technology, business, and entertainment.
          </p>
          <p class="text-gray-700 leading-relaxed">
            Special focus on regional news from Kolkata, Bangladesh, and the Indian subcontinent.
          </p>
        </div>
      </div>

      <!-- Coverage Areas -->
      <div class="bg-white rounded-2xl shadow-lg p-8 mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Our Coverage</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="text-center p-6 bg-gray-50 rounded-xl hover:bg-red-50 transition-all">
            <div class="text-4xl mb-4">📰</div>
            <h3 class="font-bold text-lg mb-2">Breaking News</h3>
            <p class="text-gray-600 text-sm">Real-time updates on major events</p>
          </div>
          <div class="text-center p-6 bg-gray-50 rounded-xl hover:bg-red-50 transition-all">
            <div class="text-4xl mb-4">🏏</div>
            <h3 class="font-bold text-lg mb-2">IPL Coverage</h3>
            <p class="text-gray-600 text-sm">Live scores & match analysis</p>
          </div>
          <div class="text-center p-6 bg-gray-50 rounded-xl hover:bg-red-50 transition-all">
            <div class="text-4xl mb-4">🌍</div>
            <h3 class="font-bold text-lg mb-2">Regional News</h3>
            <p class="text-gray-600 text-sm">Kolkata & Bangladesh coverage</p>
          </div>
          <div class="text-center p-6 bg-gray-50 rounded-xl hover:bg-red-50 transition-all">
            <div class="text-4xl mb-4">💻</div>
            <h3 class="font-bold text-lg mb-2">Technology</h3>
            <p class="text-gray-600 text-sm">Latest tech news & reviews</p>
          </div>
          <div class="text-center p-6 bg-gray-50 rounded-xl hover:bg-red-50 transition-all">
            <div class="text-4xl mb-4">💼</div>
            <h3 class="font-bold text-lg mb-2">Business</h3>
            <p class="text-gray-600 text-sm">Market updates & analysis</p>
          </div>
          <div class="text-center p-6 bg-gray-50 rounded-xl hover:bg-red-50 transition-all">
            <div class="text-4xl mb-4">🎬</div>
            <h3 class="font-bold text-lg mb-2">Entertainment</h3>
            <p class="text-gray-600 text-sm">Movies, music & culture</p>
          </div>
        </div>
      </div>

      <!-- Our Values -->
      <div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-2xl shadow-2xl p-8 mb-8 text-white">
        <h2 class="text-3xl font-bold mb-8 text-center">Our Core Values</h2>
        <div class="grid md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">✓</span>
            </div>
            <h3 class="text-xl font-bold mb-2">Accuracy</h3>
            <p class="text-gray-300 text-sm">Verified information before publication</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">⚖️</span>
            </div>
            <h3 class="text-xl font-bold mb-2">Integrity</h3>
            <p class="text-gray-300 text-sm">Editorial independence always</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">⚡</span>
            </div>
            <h3 class="text-xl font-bold mb-2">Timeliness</h3>
            <p class="text-gray-300 text-sm">Breaking news as it happens</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">👁️</span>
            </div>
            <h3 class="text-xl font-bold mb-2">Transparency</h3>
            <p class="text-gray-300 text-sm">Clear distinction of content types</p>
          </div>
        </div>
      </div>

      <!-- Contact CTA -->
      <div class="bg-white rounded-2xl shadow-lg p-8 text-center">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Get in Touch</h2>
        <p class="text-gray-700 mb-6">Have questions or feedback? We'd love to hear from you.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="px-8 py-3 bg-red-600 text-white rounded-full font-semibold hover:bg-red-700 transition shadow-lg">
            Contact Us
          </a>
          <a href="mailto:contact@mershal.in" class="px-8 py-3 bg-gray-200 text-gray-800 rounded-full font-semibold hover:bg-gray-300 transition">
            Email Us
          </a>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
  <BottomNav />
</Layout>
