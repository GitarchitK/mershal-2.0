---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout
  title="About Us — Mershal"
  description="Mershal is the ultimate intelligence resource for AI tools, SaaS reviews, and business automation workflows, helping founders and creators scale."
>
  <Header />

  <main class="bg-slate-50 pb-20 md:pb-8 font-sans text-slate-800">

    <!-- Page Header Hero Banner -->
    <div class="relative bg-gradient-to-b from-slate-900 via-slate-900 to-slate-950 text-white border-b border-slate-850 py-16 overflow-hidden">
      <div class="absolute right-0 top-0 w-[300px] h-[300px] bg-primary-crimson/10 rounded-full blur-3xl"></div>
      <div class="container mx-auto px-4 max-w-5xl relative z-10">
        <p class="text-primary-gold text-xs font-black uppercase tracking-widest mb-2 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-gold animate-pulse"></span>
          Our Mission
        </p>
        <h1 class="text-4xl md:text-5xl font-serif font-black leading-tight mb-4">About Mershal</h1>
        <p class="text-slate-300 text-lg max-w-2xl leading-relaxed">
          The ultimate intelligence resource for AI tools, SaaS reviews, and business automation workflows.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-10">

          <!-- Our Philosophy -->
          <section class="bg-white rounded-2xl border border-slate-100 p-6 md:p-8 shadow-sm">
            <h2 class="text-2xl font-serif font-black text-slate-900 mb-4 pb-2 border-b-2 border-primary-crimson inline-block">Our Story & Goal</h2>
            <div class="space-y-4 text-slate-600 leading-relaxed text-[1.0625rem]">
              <p>
                Mershal was founded to cut through the noise of the digital economy. In an era where new AI tools and software platforms are launched daily, finding the right tech stack to run your business can be overwhelming. We exist to provide objective, hands-on reviews and workflow guides that you can trust.
              </p>
              <p>
                We believe that access to clear, actionable technology intelligence is the ultimate unfair advantage. Our writers and editors spend hours researching, testing, and comparing software so you don't have to waste time and resources.
              </p>
              <p>
                From automating your CRM pipelines to finding the best AI coding assistant or scaling your freelancing business — Mershal delivers expert-level content designed to make operations smoother and more profitable.
              </p>
            </div>
          </section>

          <!-- What We Cover -->
          <section class="bg-white rounded-2xl border border-slate-100 p-6 md:p-8 shadow-sm">
            <h2 class="text-2xl font-serif font-black text-slate-900 mb-6 pb-2 border-b-2 border-primary-crimson inline-block">What We Cover</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { icon: '🤖', title: 'AI Tools', desc: 'Reviews and implementation guides for generative AI models, coding assistants, and workflows.' },
                { icon: '💻', title: 'SaaS Reviews', desc: 'Objective, deep-dive comparisons of popular software platforms and business tools.' },
                { icon: '📈', title: 'Productivity', desc: 'Software platforms, frameworks, and methodologies to optimize your working hours.' },
                { icon: '✍️', title: 'Freelancing & Agency', desc: 'Pricing blueprints, client acquisition techniques, and operational templates.' },
                { icon: '💼', title: 'Online Business', desc: 'Ecommerce growth strategies, scaling remote agencies, and business development.' },
                { icon: '👥', title: 'CRM Software', desc: 'Customer pipeline management, data enrichment, and sales automation systems.' },
              ].map(item => (
                <div class="flex gap-4 p-4 rounded-xl border border-slate-100 hover:border-primary-crimson/30 hover:bg-slate-50/50 transition duration-200">
                  <span class="text-3xl flex-shrink-0">{item.icon}</span>
                  <div>
                    <h3 class="font-bold text-slate-950 text-sm mb-1">{item.title}</h3>
                    <p class="text-xs text-slate-500 leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- Editorial Integrity -->
          <section class="bg-white rounded-2xl border border-slate-100 p-6 md:p-8 shadow-sm">
            <h2 class="text-2xl font-serif font-black text-slate-900 mb-4 pb-2 border-b-2 border-primary-crimson inline-block">Editorial Standards</h2>
            <div class="space-y-4 text-slate-600 leading-relaxed text-[1.0625rem]">
              <p>
                Every review on Mershal is written by actual operators who have tested the tool. We do not accept payment to bias our rankings or reviews. 
              </p>
              <p>
                We clearly label sponsored content or affiliate relations, and only endorse products we believe bring genuine value to digital businesses.
              </p>
              <blockquote class="border-l-4 border-primary-crimson pl-4 my-6 bg-slate-50 py-3 pr-3 rounded-r-lg">
                <p class="text-base italic text-slate-700 font-light">"Our commitment is to absolute transparency. We review software from the perspective of builders and business owners who care about efficiency and ROI."</p>
                <footer class="text-xs text-slate-400 mt-2 not-italic">— Mershal Editorial Team</footer>
              </blockquote>
            </div>
          </section>

        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">

          <!-- Quick Facts -->
          <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden shadow-sm">
            <div class="bg-slate-950 text-white px-4 py-3.5">
              <p class="text-xs font-black uppercase tracking-widest text-primary-gold">Publication Info</p>
            </div>
            <div class="divide-y divide-slate-100">
              {[
                { label: 'Founded', value: '2026' },
                { label: 'Focus', value: 'AI & SaaS' },
                { label: 'Language', value: 'English' },
                { label: 'Format', value: 'Digital Resource' },
                { label: 'Website', value: 'mershal.in' },
                { label: 'Email', value: 'contact@mershal.in' },
              ].map(item => (
                <div class="flex justify-between px-4 py-3 text-sm">
                  <span class="text-slate-400 font-medium">{item.label}</span>
                  <span class="text-slate-800 font-bold">{item.value}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Categories -->
          <div class="bg-white rounded-2xl border border-slate-100 overflow-hidden shadow-sm">
            <div class="bg-slate-950 text-white px-4 py-3.5 border-b border-slate-800">
              <p class="text-xs font-black uppercase tracking-widest text-primary-gold">Topics We Cover</p>
            </div>
            <div class="divide-y divide-slate-150">
              {[
                { name: 'AI Tools', slug: 'ai-tools' },
                { name: 'SaaS Reviews', slug: 'saas-reviews' },
                { name: 'Productivity', slug: 'productivity' },
                { name: 'Freelancing', slug: 'freelancing' },
                { name: 'Online Business', slug: 'online-business' },
                { name: 'CRM', slug: 'crm' },
                { name: 'Marketing', slug: 'marketing' }
              ].map(cat => (
                <a href={`/category/${cat.slug}`}
                   class="flex items-center justify-between px-4 py-3 text-sm text-slate-600 hover:text-primary-crimson hover:bg-slate-50 transition duration-150 font-bold">
                  {cat.name}
                  <svg class="w-3.5 h-3.5 text-slate-300" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
                </a>
              ))}
            </div>
          </div>

          <!-- Contact CTA -->
          <div class="bg-slate-900 text-white p-6 rounded-2xl border border-slate-850 shadow-sm relative overflow-hidden">
            <div class="absolute right-0 top-0 w-24 h-24 bg-primary-crimson/20 rounded-full blur-2xl"></div>
            <h3 class="font-serif font-black mb-2 text-sm uppercase tracking-wider text-primary-gold">Have Questions?</h3>
            <p class="text-slate-400 text-xs mb-4 leading-relaxed">Want us to review a specific software platform? Have partnerships or media requests?</p>
            <a href="/contact" class="block text-center bg-primary-crimson hover:bg-primary-crimson/95 text-white py-2.5 rounded-lg text-xs font-black uppercase tracking-wider transition">
              Get in Touch
            </a>
          </div>

        </aside>
      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>
