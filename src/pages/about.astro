---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout
  title="About Mershal — Vibe Coding & Web Development"
  description="Mershal is a web development and vibe coding publication. We publish tutorials, guides, and resources for developers who build for the love of it."
>
  <Header />

  <main class="bg-gray-50 pb-20 md:pb-8">

    <!-- Hero -->
    <section class="bg-white border-b border-gray-100 py-16">
      <div class="container mx-auto px-4 max-w-4xl text-center">
        <div class="w-16 h-16 bg-rose-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
          <span class="text-2xl font-black text-white logo-font">M</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">About Mershal</h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed">
          A web development and vibe coding publication for developers who build things on the internet.
        </p>
      </div>
    </section>

    <div class="container mx-auto px-4 py-12 max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Main Content -->
        <div class="md:col-span-2 space-y-8">

          <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-gray-900 mb-5">What is Mershal?</h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>
                Mershal is a web development and vibe coding publication focused on helping developers build better things, faster. We cover everything from frontend frameworks and backend architecture to AI-assisted coding workflows and developer tools.
              </p>
              <p>
                Our content is practical, code-first, and written by developers for developers. No fluff, no filler — just real tutorials, honest opinions, and actionable guides you can apply immediately.
              </p>
              <p>
                Whether you're building your first website or shipping production apps, Mershal has something for you.
              </p>
            </div>
          </section>

          <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">What We Cover</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex items-start gap-3 p-4 bg-rose-50 rounded-xl">
                <span class="text-2xl">🎧</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Vibe Coding</h3>
                  <p class="text-xs text-gray-600">AI-assisted development, creative coding, and building projects with modern tools like Cursor, Copilot, and Claude.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-4 bg-blue-50 rounded-xl">
                <span class="text-2xl">🌐</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Web Development</h3>
                  <p class="text-xs text-gray-600">React, Next.js, Astro, Node.js, databases, APIs — everything you need to build modern web applications.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-4 bg-green-50 rounded-xl">
                <span class="text-2xl">📖</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Tutorials</h3>
                  <p class="text-xs text-gray-600">Step-by-step guides with real code, real examples, and honest explanations of how things actually work.</p>
                </div>
              </div>
              <div class="flex items-start gap-3 p-4 bg-purple-50 rounded-xl">
                <span class="text-2xl">🛠️</span>
                <div>
                  <h3 class="font-bold text-gray-900 text-sm mb-1">Tools & Resources</h3>
                  <p class="text-xs text-gray-600">Reviews and guides for the best developer tools, extensions, libraries, and workflows.</p>
                </div>
              </div>
            </div>
          </section>

          <section class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-gray-900 mb-5">Our Editorial Approach</h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>
                Every article on Mershal is written to be immediately useful. We focus on practical, working examples over theoretical explanations. If a concept needs code, we show the actual code — not pseudocode.
              </p>
              <p>
                We're honest about tradeoffs. Every tool and framework has downsides, and we'd rather tell you when something is limited than pretend everything is perfect.
              </p>
              <blockquote class="border-l-4 border-rose-500 pl-4 italic text-gray-700 my-4">
                "The best tutorial is the one that actually helps you build something, not just understand a concept in theory."
              </blockquote>
            </div>
          </section>

        </div>

        <!-- Sidebar -->
        <div class="space-y-6">

          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-4 text-sm uppercase tracking-wider">Publication Info</h3>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-center gap-2"><span>🌐</span> mershal.in</li>
              <li class="flex items-center gap-2"><span>📍</span> India</li>
              <li class="flex items-center gap-2"><span>🗓️</span> Est. 2026</li>
              <li class="flex items-center gap-2"><span>🎯</span> Web Dev & Vibe Coding</li>
              <li class="flex items-center gap-2"><span>📧</span> contact@mershal.in</li>
            </ul>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-4 text-sm uppercase tracking-wider">Topics We Cover</h3>
            <div class="flex flex-wrap gap-2">
              {['JavaScript', 'TypeScript', 'React', 'Next.js', 'Astro', 'Node.js', 'Python', 'Tailwind CSS', 'Firebase', 'AI Tools', 'Git', 'Docker', 'APIs', 'CSS'].map(tag => (
                <span class="bg-gray-100 text-gray-700 px-2.5 py-1 rounded-lg text-xs font-medium">{tag}</span>
              ))}
            </div>
          </div>

          <div class="bg-gray-900 rounded-2xl p-6 text-white">
            <h3 class="font-bold mb-2">Work With Us</h3>
            <p class="text-gray-400 text-sm mb-4">Interested in advertising or sponsoring content on Mershal?</p>
            <a href="/advertise" class="block text-center bg-rose-600 hover:bg-rose-700 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition mb-2">
              Advertise
            </a>
            <a href="/contact" class="block text-center bg-gray-800 hover:bg-gray-700 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition">
              Contact Us
            </a>
          </div>

        </div>
      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>

<style>
  .logo-font {
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
  }
</style>
