---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
---

<AdminLayout title="Categories" activeNav="categories">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white">Categories</h1>
    <p class="text-gray-400 text-sm mt-1">Manage your blog categories</p>
  </div>

  <div id="alert" class="hidden mb-5 p-4 rounded-lg text-sm font-medium"></div>

  <div class="grid grid-cols-2 gap-6 max-w-3xl">
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
      <h2 class="text-sm font-semibold text-gray-300 mb-5">Add New Category</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-xs text-gray-400 mb-1.5">Name</label>
          <input id="cat-name" type="text" placeholder="e.g. Web Development" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-rose-500 placeholder-gray-600" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1.5">Slug</label>
          <input id="cat-slug" type="text" placeholder="e.g. web-development" class="w-full bg-gray-800 border border-gray-700 text-gray-400 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-rose-500 font-mono placeholder-gray-600" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1.5">Description (optional)</label>
          <textarea id="cat-desc" rows="2" placeholder="Brief description..." class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-rose-500 resize-none placeholder-gray-600"></textarea>
        </div>
        <button id="add-cat-btn" class="w-full bg-rose-600 hover:bg-rose-700 text-white py-2.5 rounded-lg text-sm font-semibold transition">Add Category</button>
      </div>
    </div>

    <div>
      <h2 class="text-sm font-semibold text-gray-300 mb-4">Existing Categories</h2>
      <div id="cat-list" class="space-y-3">
        <div class="text-gray-500 text-sm">Loading...</div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('cat-name')?.addEventListener('input', (e) => {
      (document.getElementById('cat-slug') as HTMLInputElement).value =
        (e.target as HTMLInputElement).value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    });

    function showAlert(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('alert')!;
      el.textContent = msg;
      el.className = `mb-5 p-4 rounded-lg text-sm font-medium ${type === 'success' ? 'bg-green-900/50 text-green-300 border border-green-700' : 'bg-red-900/50 text-red-300 border border-red-700'}`;
      el.classList.remove('hidden');
    }

    async function loadCategories() {
      const res = await fetch('/api/admin/categories');
      const cats = await res.json();
      const list = document.getElementById('cat-list')!;
      if (!cats.length) { list.innerHTML = '<div class="text-gray-500 text-sm">No categories yet.</div>'; return; }
      list.innerHTML = cats.map((c: any) => `
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-4 flex items-center justify-between">
          <div>
            <p class="text-sm font-semibold text-white">${c.name}</p>
            <p class="text-xs text-gray-500 font-mono mt-0.5">${c.slug}</p>
            <p class="text-xs text-gray-600 mt-1">${c.postCount || 0} posts</p>
          </div>
          <div class="flex gap-3">
            <a href="/category/${c.slug}" target="_blank" class="text-xs text-gray-500 hover:text-gray-300">View</a>
            <button onclick="deleteCategory('${c.id}', '${c.name}')" class="text-xs text-gray-600 hover:text-red-400 transition">Delete</button>
          </div>
        </div>
      `).join('');
    }

    document.getElementById('add-cat-btn')?.addEventListener('click', async () => {
      const name = (document.getElementById('cat-name') as HTMLInputElement).value.trim();
      const slug = (document.getElementById('cat-slug') as HTMLInputElement).value.trim();
      const description = (document.getElementById('cat-desc') as HTMLTextAreaElement).value.trim();
      if (!name || !slug) { showAlert('Name and slug are required', 'error'); return; }

      const btn = document.getElementById('add-cat-btn') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Adding...';

      const res = await fetch('/api/admin/categories', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, slug, description }) });
      const data = await res.json();
      if (res.ok) {
        showAlert('Category added!', 'success');
        (document.getElementById('cat-name') as HTMLInputElement).value = '';
        (document.getElementById('cat-slug') as HTMLInputElement).value = '';
        (document.getElementById('cat-desc') as HTMLTextAreaElement).value = '';
        loadCategories();
      } else showAlert(data.error || 'Failed', 'error');
      btn.disabled = false; btn.textContent = 'Add Category';
    });

    async function deleteCategory(id: string, name: string) {
      if (!confirm(`Delete "${name}"?`)) return;
      const res = await fetch(`/api/admin/categories?id=${id}`, { method: 'DELETE' });
      if (res.ok) { showAlert('Deleted', 'success'); loadCategories(); }
      else showAlert('Failed to delete', 'error');
    }

    loadCategories();
  </script>
</AdminLayout>
