---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
---

<AdminLayout title="Categories" activeNav="categories">
  <div class="mb-8">
    <h1 class="text-3xl font-black font-outfit text-white tracking-tight">Categories</h1>
    <p class="text-slate-450 text-sm mt-1 font-outfit">Manage your content clusters & tags</p>
  </div>

  <div id="alert" class="hidden mb-5 p-4 rounded-xl text-xs font-semibold font-outfit border animate-in fade-in duration-200"></div>

  <div class="grid grid-cols-1 md:grid-cols-5 gap-6 max-w-5xl">
    <!-- Left: Add New Form -->
    <div class="md:col-span-2 bg-slate-900/40 rounded-2xl border border-slate-850/60 p-6 shadow-xl backdrop-blur-sm h-fit">
      <h2 class="text-base font-bold text-white mb-5 font-outfit flex items-center gap-2">
        <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Add New Category
      </h2>
      <div class="space-y-4">
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-1.5">Name</label>
          <input id="cat-name" type="text" placeholder="e.g. Web Development" class="w-full bg-slate-950/40 border border-slate-800 text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-500/20 transition-all font-outfit placeholder-slate-650" />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-1.5">Slug</label>
          <input id="cat-slug" type="text" placeholder="e.g. web-development" class="w-full bg-slate-950/40 border border-slate-800 text-slate-400 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-500/20 transition-all font-mono placeholder-slate-650" />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-1.5">Description (optional)</label>
          <textarea id="cat-desc" rows="2" placeholder="Brief description..." class="w-full bg-slate-950/40 border border-slate-800 text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-500/20 transition-all font-outfit resize-none placeholder-slate-650"></textarea>
        </div>
        <button id="add-cat-btn" class="w-full bg-gradient-to-r from-rose-600 to-rose-700 hover:from-rose-550 hover:to-rose-650 hover:shadow-lg hover:shadow-rose-600/10 text-white py-3 rounded-xl text-sm font-bold font-outfit transition-all active:scale-[0.98] cursor-pointer">
          Add Category
        </button>
      </div>
    </div>

    <!-- Right: List Grid -->
    <div class="md:col-span-3">
      <h2 class="text-xs font-bold text-slate-500 uppercase tracking-widest font-outfit mb-4">Existing Categories</h2>
      <div id="cat-list" class="space-y-3">
        <div class="p-6 text-slate-550 text-sm flex items-center justify-center gap-3 bg-slate-900/40 border border-slate-850/60 rounded-2xl">
          <svg class="w-5 h-5 animate-spin text-rose-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          <span>Loading categories...</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('cat-name')?.addEventListener('input', (e) => {
      (document.getElementById('cat-slug') as HTMLInputElement).value =
        (e.target as HTMLInputElement).value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    });

    function showAlert(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('alert')!;
      el.textContent = msg;
      el.className = `mb-5 p-4 rounded-xl text-xs font-semibold font-outfit border animate-in fade-in duration-200 ${type === 'success' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 'bg-rose-500/10 text-rose-455 border-rose-500/20'}`;
      el.classList.remove('hidden');
    }

    async function loadCategories() {
      const res = await fetch('/api/admin/categories');
      const cats = await res.json();
      const list = document.getElementById('cat-list')!;
      if (!cats.length) { list.innerHTML = '<div class="p-8 bg-slate-900/40 border border-slate-850/60 rounded-2xl text-slate-500 text-sm text-center font-medium font-outfit">No categories yet.</div>'; return; }
      list.innerHTML = cats.map((c: any) => `
        <div class="bg-slate-900/40 rounded-xl border border-slate-850/60 p-4 flex items-center justify-between hover:bg-slate-900/60 transition-colors">
          <div>
            <div class="flex items-center gap-2">
              <p class="text-sm font-semibold text-slate-200">${c.name}</p>
              ${c.builtin ? '<span class="text-[9px] font-bold uppercase tracking-wider bg-slate-950 text-slate-500 border border-slate-850 px-1.5 py-0.5 rounded-md font-outfit">built-in</span>' : ''}
            </div>
            <p class="text-xs text-slate-500 font-mono mt-0.5">${c.slug}</p>
            <p class="text-xs text-slate-600 font-outfit mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              ${c.postCount || 0} posts
            </p>
          </div>
          <div class="flex items-center gap-3">
            <a href="/category/${c.slug}" target="_blank" class="text-xs font-bold text-slate-500 hover:text-slate-350 transition-colors">View</a>
            ${!c.builtin ? `<button onclick="window.deleteCategory('${c.id}', '${c.name}')" class="text-xs font-bold text-rose-455 hover:text-rose-400 transition-colors cursor-pointer">Delete</button>` : ''}
          </div>
        </div>
      `).join('');
    }

    document.getElementById('add-cat-btn')?.addEventListener('click', async () => {
      const name = (document.getElementById('cat-name') as HTMLInputElement).value.trim();
      const slug = (document.getElementById('cat-slug') as HTMLInputElement).value.trim();
      const description = (document.getElementById('cat-desc') as HTMLTextAreaElement).value.trim();
      if (!name || !slug) { showAlert('Name and slug are required', 'error'); return; }

      const btn = document.getElementById('add-cat-btn') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Adding...';

      const res = await fetch('/api/admin/categories', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, slug, description }) });
      const data = await res.json();
      if (res.ok) {
        showAlert('Category added!', 'success');
        (document.getElementById('cat-name') as HTMLInputElement).value = '';
        (document.getElementById('cat-slug') as HTMLInputElement).value = '';
        (document.getElementById('cat-desc') as HTMLTextAreaElement).value = '';
        loadCategories();
      } else showAlert(data.error || 'Failed', 'error');
      btn.disabled = false; btn.textContent = 'Add Category';
    });

    (window as any).deleteCategory = async function(id: string, name: string) {
      if (!confirm(`Delete "${name}"?`)) return;
      const res = await fetch(`/api/admin/categories?id=${id}`, { method: 'DELETE' });
      if (res.ok) { showAlert('Deleted', 'success'); loadCategories(); }
      else showAlert('Failed to delete', 'error');
    };

    loadCategories();
  </script>
</AdminLayout>
