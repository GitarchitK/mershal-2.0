---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { adminDb } from '../../lib/firebase-admin';

let message = '';
let messageType = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action');

    if (action === 'add') {
      const topic = data.get('topic');
      const category = data.get('category');
      
      if (topic && category && adminDb) {
        await adminDb.collection('topicQueue').add({
          topic,
          category,
          createdAt: new Date(),
          status: 'pending'
        });
        message = 'Topic added successfully!';
        messageType = 'success';
      }
    } else if (action === 'delete') {
      const id = data.get('id');
      if (id && adminDb) {
        await adminDb.collection('topicQueue').doc(id.toString()).delete();
        message = 'Topic deleted!';
        messageType = 'success';
      }
    }
  } catch (error) {
    message = 'Error: ' + (error instanceof Error ? error.message : 'Unknown error');
    messageType = 'error';
  }
}

// Fetch topics
let topics: any[] = [];
try {
  if (adminDb) {
    const snapshot = await adminDb.collection('topicQueue')
      .orderBy('createdAt', 'desc')
      .limit(50)
      .get();
    topics = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
  }
} catch (error) {
  console.error('Error fetching topics:', error);
}

const categories = ['usa', 'canada', 'australia', 'technology', 'business', 'politics', 'world', 'entertainment'];
---

<Layout title="Topic Manager - Mershal">
  <Header />
  
  <main class="container mx-auto px-4 py-6 pb-24 md:pb-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">📝 Topic Manager</h1>
    
    {message && (
      <div class={`p-4 rounded-lg mb-6 ${messageType === 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
        {message}
      </div>
    )}
    
    <!-- Add Topic Form -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-lg font-semibold mb-4">Add New Topic</h2>
      <form method="POST" class="space-y-4">
        <input type="hidden" name="action" value="add" />
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Topic</label>
          <input 
            type="text" 
            name="topic" 
            required
            placeholder="e.g., IPL 2026 final match preview"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
          />
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
          <select 
            name="category" 
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
          >
            {categories.map(cat => (
              <option value={cat}>{cat.charAt(0).toUpperCase() + cat.slice(1)}</option>
            ))}
          </select>
        </div>
        
        <button 
          type="submit"
          class="w-full bg-red-600 text-white py-3 px-4 rounded-lg font-semibold hover:bg-red-700 transition"
        >
          Add Topic
        </button>
      </form>
    </div>
    
    <!-- Current Topics -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-lg font-semibold mb-4">Your Topics ({topics.length})</h2>
      
      {topics.length === 0 ? (
        <p class="text-gray-500 text-center py-8">No topics yet. Add one above!</p>
      ) : (
        <div class="space-y-3">
          {topics.map(topic => (
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
              <div>
                <p class="font-medium text-gray-900">{topic.topic}</p>
                <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded uppercase">
                  {topic.category}
                </span>
              </div>
              <form method="POST">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="id" value={topic.id} />
                <button 
                  type="submit"
                  class="text-red-600 hover:text-red-800 p-2"
                  onclick="return confirm('Delete this topic?')"
                >
                  🗑️
                </button>
              </form>
            </div>
          ))}
        </div>
      )}
    </div>
    
    <!-- Quick Actions -->
    <div class="mt-8 grid grid-cols-2 gap-4">
      <a 
        href="/admin/stats"
        class="bg-blue-600 text-white py-4 px-6 rounded-lg text-center font-semibold hover:bg-blue-700 transition"
      >
        📊 Stats
      </a>
      <a 
        href="/"
        class="bg-gray-600 text-white py-4 px-6 rounded-lg text-center font-semibold hover:bg-gray-700 transition"
        >
        🏠 Home
      </a>
    </div>
  </main>
  
  <Footer />
</Layout>