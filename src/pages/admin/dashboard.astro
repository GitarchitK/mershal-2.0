---
export const prerender = false;

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') {
  return Astro.redirect('/admin');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — Mershal Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen">

  <!-- Sidebar -->
  <div class="flex min-h-screen">
    <aside class="w-60 bg-gray-900 border-r border-gray-800 flex flex-col fixed h-full z-10">
      <div class="p-6 border-b border-gray-800">
        <a href="/" class="text-xl font-black text-rose-500">Mershal</a>
        <p class="text-xs text-gray-500 mt-0.5">Admin Panel</p>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <a href="/admin/dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-gray-800 text-white text-sm font-medium">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
          Dashboard
        </a>
        <a href="/admin/posts" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white text-sm font-medium transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/></svg>
          All Posts
        </a>
        <a href="/admin/posts/new" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white text-sm font-medium transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
          New Post
        </a>
        <a href="/admin/categories" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-gray-800 hover:text-white text-sm font-medium transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z"/></svg>
          Categories
        </a>
      </nav>
      <div class="p-4 border-t border-gray-800 space-y-2">
        <a href="/" target="_blank" class="flex items-center gap-2 px-3 py-2 text-gray-500 hover:text-gray-300 text-xs transition">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/><path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"/></svg>
          View Site
        </a>
        <button id="logout-btn" class="flex items-center gap-2 px-3 py-2 text-gray-500 hover:text-red-400 text-xs transition w-full">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/></svg>
          Logout
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="ml-60 flex-1 p-8">
      <div class="mb-8">
        <h1 class="text-2xl font-bold text-white">Dashboard</h1>
        <p class="text-gray-400 text-sm mt-1">Welcome back, Archit 👋</p>
      </div>

      <!-- Stats -->
      <div id="stats-grid" class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800 animate-pulse">
          <div class="h-4 bg-gray-800 rounded w-24 mb-3"></div>
          <div class="h-8 bg-gray-800 rounded w-16"></div>
        </div>
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800 animate-pulse">
          <div class="h-4 bg-gray-800 rounded w-24 mb-3"></div>
          <div class="h-8 bg-gray-800 rounded w-16"></div>
        </div>
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800 animate-pulse">
          <div class="h-4 bg-gray-800 rounded w-24 mb-3"></div>
          <div class="h-8 bg-gray-800 rounded w-16"></div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="mb-10">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Quick Actions</h2>
        <div class="flex flex-wrap gap-3">
          <a href="/admin/posts/new" class="flex items-center gap-2 bg-rose-600 hover:bg-rose-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
            Write New Post
          </a>
          <a href="/admin/posts" class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">
            Manage Posts
          </a>
          <a href="/admin/categories" class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">
            Manage Categories
          </a>
        </div>
      </div>

      <!-- Recent Posts -->
      <div>
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Recent Posts</h2>
        <div id="recent-posts" class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
          <div class="p-6 text-gray-500 text-sm">Loading...</div>
        </div>
      </div>
    </main>
  </div>

  <script>
    // Load stats
    fetch('/api/admin/stats').then(r => r.json()).then(data => {
      document.getElementById('stats-grid')!.innerHTML = `
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
          <p class="text-gray-400 text-sm mb-1">Total Posts</p>
          <p class="text-3xl font-bold text-white">${data.total}</p>
        </div>
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
          <p class="text-gray-400 text-sm mb-1">Published</p>
          <p class="text-3xl font-bold text-green-400">${data.published}</p>
        </div>
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
          <p class="text-gray-400 text-sm mb-1">Drafts</p>
          <p class="text-3xl font-bold text-yellow-400">${data.drafts}</p>
        </div>
      `;
    });

    // Load recent posts
    fetch('/api/admin/posts').then(r => r.json()).then((posts: any[]) => {
      if (!posts.length) {
        document.getElementById('recent-posts')!.innerHTML = '<div class="p-6 text-gray-500 text-sm">No posts yet. <a href="/admin/posts/new" class="text-rose-400 hover:underline">Write your first post →</a></div>';
        return;
      }
      const rows = posts.slice(0, 8).map((p: any) => `
        <tr class="border-t border-gray-800 hover:bg-gray-800/50 transition">
          <td class="px-5 py-3.5 text-sm text-white font-medium max-w-xs truncate">${p.title}</td>
          <td class="px-5 py-3.5 text-sm text-gray-400 capitalize">${p.category}</td>
          <td class="px-5 py-3.5">
            <span class="px-2 py-0.5 rounded-full text-xs font-medium ${p.status === 'published' ? 'bg-green-900/50 text-green-400' : 'bg-yellow-900/50 text-yellow-400'}">
              ${p.status}
            </span>
          </td>
          <td class="px-5 py-3.5 text-sm text-gray-500">${p.publishedAt ? new Date(p.publishedAt).toLocaleDateString() : '—'}</td>
          <td class="px-5 py-3.5 text-sm">
            <a href="/admin/posts/edit?id=${p.id}" class="text-rose-400 hover:text-rose-300 mr-3">Edit</a>
            <a href="/news/${p.slug}" target="_blank" class="text-gray-500 hover:text-gray-300">View</a>
          </td>
        </tr>
      `).join('');
      document.getElementById('recent-posts')!.innerHTML = `
        <table class="w-full">
          <thead><tr class="text-left text-xs text-gray-500 uppercase tracking-wider">
            <th class="px-5 py-3">Title</th>
            <th class="px-5 py-3">Category</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Date</th>
            <th class="px-5 py-3">Actions</th>
          </tr></thead>
          <tbody>${rows}</tbody>
        </table>
      `;
    });

    // Logout
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/admin/auth', { method: 'DELETE' });
      window.location.href = '/admin';
    });
  </script>
</body>
</html>
