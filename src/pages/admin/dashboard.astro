---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
---

<AdminLayout title="Dashboard" activeNav="dashboard">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-black font-outfit text-white tracking-tight">Dashboard</h1>
    <p class="text-slate-450 text-sm mt-1 font-outfit">Welcome back, Archit 👋</p>
  </div>

  <!-- Stats -->
  <div id="stats-grid" class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
    <div class="bg-slate-900/40 rounded-2xl p-6 border border-slate-850/80 animate-pulse h-28"></div>
    <div class="bg-slate-900/40 rounded-2xl p-6 border border-slate-850/80 animate-pulse h-28"></div>
    <div class="bg-slate-900/40 rounded-2xl p-6 border border-slate-850/80 animate-pulse h-28"></div>
  </div>

  <!-- Quick Actions & Auto-Publish Layout -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
    <!-- Quick Actions -->
    <div class="lg:col-span-1 flex flex-col justify-between bg-slate-900/40 border border-slate-850/60 rounded-2xl p-6">
      <div>
        <h2 class="text-xs font-bold text-slate-500 uppercase tracking-widest font-outfit mb-4">Quick Actions</h2>
        <div class="space-y-3">
          <a href="/admin/posts/new" class="flex items-center justify-center gap-2 bg-gradient-to-r from-rose-600 to-rose-700 hover:from-rose-550 hover:to-rose-650 hover:shadow-lg hover:shadow-rose-600/10 text-white px-5 py-3 rounded-xl text-sm font-bold font-outfit transition-all active:scale-[0.98]">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            Write New Post
          </a>
          <a href="/admin/posts" class="flex items-center justify-center gap-2 bg-slate-950/40 hover:bg-slate-950/80 border border-slate-850 hover:border-slate-700 text-slate-200 px-5 py-3 rounded-xl text-sm font-bold font-outfit transition-all">
            Manage Posts
          </a>
          <a href="/admin/categories" class="flex items-center justify-center gap-2 bg-slate-950/40 hover:bg-slate-950/80 border border-slate-850 hover:border-slate-700 text-slate-200 px-5 py-3 rounded-xl text-sm font-bold font-outfit transition-all">
            Manage Categories
          </a>
        </div>
      </div>
    </div>

    <!-- AI Auto-Publish -->
    <div class="lg:col-span-2 bg-gradient-to-br from-rose-500/5 via-slate-900/40 to-amber-500/3 border border-rose-500/10 rounded-2xl p-6 relative overflow-hidden group">
      <!-- Glow decoration -->
      <div class="absolute -right-10 -top-10 w-40 h-40 rounded-full bg-rose-500/5 blur-2xl group-hover:bg-rose-500/10 transition-all"></div>
      
      <div class="flex flex-col justify-between h-full relative z-10">
        <div>
          <h2 class="text-xs font-bold text-rose-450 uppercase tracking-widest font-outfit mb-2 flex items-center gap-1.5">
            <span class="text-sm">⚡</span> AI Trend Auto-Publisher
          </h2>
          <p class="text-sm text-slate-450 leading-relaxed mb-6">Triggers Google Trends parser, generates researched articles using Gemini API, and auto-deploys them via GitHub Actions.</p>
        </div>

        <div class="flex flex-wrap items-center justify-between gap-4 border-t border-slate-900/60 pt-4">
          <div class="flex items-center gap-2">
            <label class="text-xs font-bold text-slate-500 uppercase tracking-wider font-outfit">Count:</label>
            <div class="relative">
              <select id="publish-count" class="bg-slate-950/60 border border-slate-800 text-white rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:border-rose-500 font-outfit appearance-none pr-8 cursor-pointer">
                <option value="1">1 article</option>
                <option value="2" selected>2 articles</option>
                <option value="3">3 articles</option>
                <option value="5">5 articles</option>
              </select>
              <svg class="w-3 h-3 text-slate-500 absolute right-2.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </div>
          
          <button id="trigger-publish" class="flex items-center gap-2 bg-rose-600 hover:bg-rose-500 hover:shadow-lg hover:shadow-rose-600/10 text-white px-5 py-2.5 rounded-xl text-xs font-bold font-outfit transition-all active:scale-[0.98] cursor-pointer">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/></svg>
            Run Auto-Publish Now
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Status Alert -->
  <div id="publish-status" class="hidden mb-8 p-4 rounded-xl text-xs font-semibold font-outfit border animate-in fade-in duration-200"></div>

  <!-- Recent Posts -->
  <div>
    <h2 class="text-xs font-bold text-slate-500 uppercase tracking-widest font-outfit mb-4">Recent Posts</h2>
    <div id="recent-posts" class="bg-slate-900/40 rounded-2xl border border-slate-850/60 overflow-hidden shadow-xl backdrop-blur-sm">
      <div class="p-6 text-slate-550 text-sm flex items-center justify-center gap-3">
        <svg class="w-5 h-5 animate-spin text-rose-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
        <span>Loading posts...</span>
      </div>
    </div>
  </div>

  <script>
    // Stats
    fetch('/api/admin/stats').then(r => r.json()).then(data => {
      document.getElementById('stats-grid')!.innerHTML = `
        <div class="bg-slate-900/40 rounded-2xl p-6 border border-slate-855 hover:border-slate-800 transition-all flex items-center justify-between group">
          <div>
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest font-outfit mb-1">Total Articles</p>
            <p class="text-3xl font-black font-outfit text-white group-hover:scale-102 transition-transform origin-left">${data.total ?? 0}</p>
          </div>
          <div class="w-12 h-12 rounded-xl bg-slate-955 border border-slate-850 flex items-center justify-center text-slate-500 group-hover:text-slate-350 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
          </div>
        </div>
        <div class="bg-slate-900/40 rounded-2xl p-6 border border-slate-855 hover:border-slate-800 transition-all flex items-center justify-between group">
          <div>
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest font-outfit mb-1">Published</p>
            <p class="text-3xl font-black font-outfit text-emerald-400 group-hover:scale-102 transition-transform origin-left">${data.published ?? 0}</p>
          </div>
          <div class="w-12 h-12 rounded-xl bg-emerald-500/5 border border-emerald-500/10 flex items-center justify-center text-emerald-500 group-hover:text-emerald-400 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
        </div>
        <div class="bg-slate-900/40 rounded-2xl p-6 border border-slate-855 hover:border-slate-800 transition-all flex items-center justify-between group">
          <div>
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest font-outfit mb-1">Drafts</p>
            <p class="text-3xl font-black font-outfit text-amber-400 group-hover:scale-102 transition-transform origin-left">${data.drafts ?? 0}</p>
          </div>
          <div class="w-12 h-12 rounded-xl bg-amber-500/5 border border-amber-500/10 flex items-center justify-center text-amber-500 group-hover:text-amber-400 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
          </div>
        </div>
      `;
    });

    fetch('/api/admin/posts').then(r => r.json()).then((posts: any[]) => {
      if (!Array.isArray(posts) || !posts.length) {
        document.getElementById('recent-posts')!.innerHTML = '<div class="p-8 text-slate-500 text-sm text-center font-medium font-outfit">No posts yet. <a href="/admin/posts/new" class="text-rose-450 hover:text-rose-400 font-bold transition-colors">Write your first post →</a></div>';
        return;
      }
      const rows = posts.slice(0, 8).map((p: any) => `
        <tr class="border-t border-slate-900/60 hover:bg-slate-900/20 transition-colors">
          <td class="px-6 py-4 text-sm text-slate-200 font-medium max-w-xs truncate">${p.title}</td>
          <td class="px-6 py-4">
            <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-slate-950 text-xs font-semibold text-slate-450 border border-slate-850 capitalize">${p.category || 'Uncategorized'}</span>
          </td>
          <td class="px-6 py-4">
            <span class="inline-flex items-center gap-1.5 py-0.5 px-2.5 rounded-full text-[10px] font-bold ${p.status === 'published' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-amber-500/10 text-amber-400 border border-amber-500/20'}">
              <span class="w-1.5 h-1.5 rounded-full ${p.status === 'published' ? 'bg-emerald-500' : 'bg-amber-500'}"></span>
              ${p.status}
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-slate-500 whitespace-nowrap font-outfit">${p.publishedAt ? new Date(p.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—'}</td>
          <td class="px-6 py-4 text-sm text-right whitespace-nowrap">
            <div class="inline-flex items-center gap-3">
              <a href="/admin/posts/edit?id=${p.id}" class="text-xs font-bold text-rose-400 hover:text-rose-350 transition-colors">Edit</a>
              <a href="/articles/${p.slug}" target="_blank" class="text-xs font-bold text-slate-500 hover:text-slate-350 transition-colors">View</a>
            </div>
          </td>
        </tr>
      `).join('');
      document.getElementById('recent-posts')!.innerHTML = `
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="text-xs text-slate-500 uppercase tracking-widest border-b border-slate-900 bg-slate-950/40 font-outfit">
                <th class="px-6 py-4 font-bold">Title</th>
                <th class="px-6 py-4 font-bold">Category</th>
                <th class="px-6 py-4 font-bold">Status</th>
                <th class="px-6 py-4 font-bold">Date</th>
                <th class="px-6 py-4 font-bold text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-900/60">${rows}</tbody>
          </table>
        </div>`;
    });

    // Auto-Publish trigger
    document.getElementById('trigger-publish')?.addEventListener('click', async () => {
      const btn = document.getElementById('trigger-publish') as HTMLButtonElement;
      const statusEl = document.getElementById('publish-status') as HTMLElement;
      const count = (document.getElementById('publish-count') as HTMLSelectElement).value;

      const token = prompt('Enter your GitHub Personal Access Token\n(Settings → Developer settings → Personal access tokens → Fine-grained or Classic with "workflow" scope):');
      if (!token) return;

      btn.disabled = true;
      btn.textContent = 'Triggering...';

      try {
        const res = await fetch(
          'https://api.github.com/repos/GitarchitK/mershal-2.0/actions/workflows/auto-publish.yml/dispatches',
          {
            method: 'POST',
            headers: {
              'Authorization': `Bearer ${token}`,
              'Accept': 'application/vnd.github.v3+json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ ref: 'main', inputs: { count } }),
          }
        );

        if (res.status === 204) {
          statusEl.textContent = `✓ Triggered! Publishing ${count} article(s). Check GitHub Actions tab for progress.`;
          statusEl.className = 'mb-8 p-4 rounded-xl text-xs font-semibold font-outfit bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
        } else {
          const err = await res.json().catch(() => ({}));
          statusEl.textContent = `✗ Failed (${res.status}): ${(err as any).message || 'Check token has workflow scope'}`;
          statusEl.className = 'mb-8 p-4 rounded-xl text-xs font-semibold font-outfit bg-rose-500/10 text-rose-400 border border-rose-500/20';
        }
      } catch (e: any) {
        statusEl.textContent = `✗ Error: ${e.message}`;
        statusEl.className = 'mb-8 p-4 rounded-xl text-xs font-semibold font-outfit bg-rose-500/10 text-rose-400 border border-rose-500/20';
      }

      statusEl.classList.remove('hidden');
      btn.disabled = false;
      btn.innerHTML = `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/></svg> Run Auto-Publish Now`;
    });
  </script>
</AdminLayout>
