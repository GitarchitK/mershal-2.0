---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
---

<AdminLayout title="Posts Management" activeNav="posts">
  <!-- Header Section -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-bold text-white tracking-tight">Posts</h1>
      <p class="text-gray-400 text-sm mt-1 flex items-center gap-2">
        <span id="post-count" class="font-medium text-gray-300">Loading...</span>
        <span class="text-gray-600">•</span>
        <span>Manage and publish your content</span>
      </p>
    </div>
    <a href="/admin/posts/new" class="inline-flex items-center gap-2 bg-rose-600 hover:bg-rose-500 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-lg shadow-rose-600/20 active:scale-95">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Create Post
    </a>
  </div>

  <!-- Filters Section -->
  <div class="bg-gray-900/50 border border-gray-800/60 rounded-2xl p-4 mb-6 backdrop-blur-sm">
    <div class="flex flex-col sm:flex-row gap-4">
      <div class="relative flex-1">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="search" type="text" placeholder="Search by title or slug..." class="w-full bg-gray-950/50 border border-gray-700/50 text-white rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-rose-500/50 focus:border-rose-500 transition-all placeholder-gray-500" />
      </div>
      <div class="flex gap-3">
        <select id="filter-status" class="bg-gray-950/50 border border-gray-700/50 text-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-rose-500/50 focus:border-rose-500 transition-all min-w-[140px] appearance-none cursor-pointer">
          <option value="">All Statuses</option>
          <option value="published">Published</option>
          <option value="draft">Draft</option>
        </select>
        <select id="filter-category" class="bg-gray-950/50 border border-gray-700/50 text-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-rose-500/50 focus:border-rose-500 transition-all min-w-[140px] appearance-none cursor-pointer">
          <option value="">All Categories</option>
          <option value="AI Tools">AI Tools</option>
          <option value="SaaS Reviews">SaaS Reviews</option>
          <option value="Productivity">Productivity</option>
          <option value="Freelancing">Freelancing</option>
          <option value="Online Business">Online Business</option>
          <option value="CRM Software">CRM Software</option>
          <option value="Digital Marketing">Digital Marketing</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Table Section -->
  <div class="bg-gray-900/40 border border-gray-800/60 rounded-2xl overflow-hidden shadow-xl backdrop-blur-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-900/80 border-b border-gray-800/60">
            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider w-1/3">Post Details</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Category</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Status</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Stats</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">SEO Health</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Published</th>
            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="posts-table-body" class="divide-y divide-gray-800/50">
          <tr>
            <td colspan="7" class="px-6 py-12 text-center">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gray-800/50 mb-4">
                <svg class="w-6 h-6 text-gray-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              </div>
              <p class="text-gray-400 text-sm">Loading posts...</p>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- SEO Audit Modal -->
  <div id="seo-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-black/70 backdrop-blur-sm p-4">
    <div class="bg-gray-900 border border-gray-800 rounded-2xl max-w-lg w-full overflow-hidden shadow-2xl animate-in fade-in zoom-in-95 duration-200">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-800 bg-gray-950/40">
        <h3 class="text-sm font-bold text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          SEO Optimization Audit
        </h3>
        <button onclick="window.closeSeoAudit()" class="text-gray-400 hover:text-white p-1 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="p-6 max-h-[70vh] overflow-y-auto space-y-6">
        <!-- Title and score -->
        <div>
          <h4 id="seo-modal-title" class="text-base font-semibold text-white truncate mb-2">Article Title</h4>
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-400">SEO Health Score:</span>
            <span id="seo-modal-score" class="text-base font-black px-2 py-0.5 rounded">100/100</span>
          </div>
        </div>
        
        <!-- Alerts / Warnings -->
        <div>
          <h5 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Critical Alerts</h5>
          <div id="seo-modal-warnings" class="space-y-2"></div>
        </div>

        <!-- Recommendations -->
        <div>
          <h5 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Recommendations</h5>
          <div id="seo-modal-recommendations" class="space-y-2"></div>
        </div>

        <!-- Internal Linking -->
        <div>
          <h5 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Internal Linking Suggestions</h5>
          <div id="seo-modal-linking" class="space-y-2"></div>
        </div>
      </div>
      <div class="px-6 py-4 border-t border-gray-800 bg-gray-950/40 flex justify-end">
        <button onclick="window.closeSeoAudit()" class="bg-gray-800 hover:bg-gray-750 border border-gray-700 text-white rounded-xl px-5 py-2 text-xs font-semibold transition-all cursor-pointer">Close Audit</button>
      </div>
    </div>
  </div>

  <script>
    let allPosts: any[] = [];
    let isDeleting = false;

    async function loadPosts() {
      try {
        const res = await fetch('/api/admin/posts');
        allPosts = await res.json();
        updateCount();
        renderTable(allPosts);
      } catch (error) {
        console.error('Failed to load posts:', error);
        document.getElementById('posts-table-body')!.innerHTML = `
          <tr>
            <td colspan="7" class="px-6 py-12 text-center text-red-400">
              Failed to load posts. Please try refreshing the page.
            </td>
          </tr>
        `;
      }
    }

    function updateCount() {
      const countEl = document.getElementById('post-count');
      if (countEl) {
        countEl.textContent = `${allPosts.length} post${allPosts.length === 1 ? '' : 's'}`;
      }
    }

    function renderTable(posts: any[]) {
      const tbody = document.getElementById('posts-table-body');
      if (!tbody) return;

      if (!posts.length) {
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="px-6 py-16 text-center">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-800/30 mb-4">
                <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5L18.5 7M4 13h16M4 18h16"/></svg>
              </div>
              <h3 class="text-white text-lg font-medium mb-1">No posts found</h3>
              <p class="text-gray-500 text-sm">Try adjusting your filters or create a new post.</p>
            </td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = posts.map((p: any) => {
        const isPublished = p.status === 'published';
        const statusBadge = isPublished
          ? `<span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Published</span>`
          : `<span class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20"><span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>Draft</span>`;

        const dateFormatted = p.publishedAt 
          ? new Date(p.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) 
          : '<span class="text-gray-600">—</span>';

        // SEO Badge configuration
        const seoScore = p.seo?.score ?? 100;
        let seoClass = 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20';
        if (seoScore < 50) {
          seoClass = 'bg-rose-500/10 text-rose-400 border border-rose-500/20';
        } else if (seoScore < 85) {
          seoClass = 'bg-amber-500/10 text-amber-400 border border-amber-500/20';
        }

        const seoBadge = `<button onclick="window.showSeoAudit('${p.id}')" class="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-full text-xs font-bold ${seoClass} hover:opacity-85 transition cursor-pointer select-none">${seoScore}/100</button>`;

        return `
          <tr class="group hover:bg-gray-800/40 transition-colors">
            <td class="px-6 py-4">
              <div class="flex flex-col gap-1">
                <a href="/admin/posts/edit?id=${p.id}" class="text-sm font-medium text-gray-200 group-hover:text-rose-400 transition-colors line-clamp-1">${p.title}</a>
                <div class="flex items-center gap-2 text-xs text-gray-500 font-mono">
                  <span class="truncate max-w-[200px]">/articles/${p.slug}</span>
                  <a href="/articles/${p.slug}" target="_blank" class="text-gray-600 hover:text-gray-400 transition-colors" title="Open in new tab">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  </a>
                </div>
              </div>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2 py-1 rounded-md bg-gray-800 text-xs font-medium text-gray-300 capitalize border border-gray-700">
                ${p.category || 'Uncategorized'}
              </span>
            </td>
            <td class="px-6 py-4">
              ${statusBadge}
            </td>
            <td class="px-6 py-4 text-sm text-gray-400">
              <div class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                ${p.wordCount || 0}
              </div>
            </td>
            <td class="px-6 py-4">
              ${seoBadge}
            </td>
            <td class="px-6 py-4 text-sm text-gray-400 whitespace-nowrap">
              ${dateFormatted}
            </td>
            <td class="px-6 py-4 text-right whitespace-nowrap">
              <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                <a href="/admin/posts/edit?id=${p.id}" class="p-2 text-gray-400 hover:text-white hover:bg-gray-700 rounded-lg transition-colors" title="Edit Post">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                </a>
                <button onclick="window.deletePost('${p.id}', '${p.title.replace(/'/g, "\\'")}')" class="p-2 text-gray-400 hover:text-rose-400 hover:bg-rose-500/10 rounded-lg transition-colors cursor-pointer" title="Delete Post">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.8627m5 4v6m4-6v6m1-10V4a1 11v3M4 7h16"/></svg>
                </button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    function filterPosts() {
      const search = (document.getElementById('search') as HTMLInputElement).value.toLowerCase();
      const status = (document.getElementById('filter-status') as HTMLSelectElement).value;
      const category = (document.getElementById('filter-category') as HTMLSelectElement).value;
      
      const filtered = allPosts.filter((p: any) => {
        const matchesSearch = !search || 
          p.title.toLowerCase().includes(search) || 
          (p.slug && p.slug.toLowerCase().includes(search));
        const matchesStatus = !status || p.status === status;
        const matchesCategory = !category || p.category === category;
        return matchesSearch && matchesStatus && matchesCategory;
      });
      
      renderTable(filtered);
    }

    // Modal control functions
    (window as any).showSeoAudit = function(id: string) {
      const post = allPosts.find((p: any) => p.id === id);
      if (!post) return;
      
      const modal = document.getElementById('seo-modal');
      const modalTitle = document.getElementById('seo-modal-title');
      const modalScore = document.getElementById('seo-modal-score');
      const modalWarnings = document.getElementById('seo-modal-warnings');
      const modalRecs = document.getElementById('seo-modal-recommendations');
      const modalLinking = document.getElementById('seo-modal-linking');
      
      if (!modal || !modalTitle || !modalScore || !modalWarnings || !modalRecs || !modalLinking) return;
      
      modalTitle.textContent = post.title;
      
      const score = post.seo?.score ?? 100;
      modalScore.textContent = `${score}/100`;
      
      if (score < 50) {
        modalScore.className = 'text-base font-black text-rose-400 bg-rose-500/10 border border-rose-500/20 px-2 py-0.5 rounded';
      } else if (score < 85) {
        modalScore.className = 'text-base font-black text-amber-400 bg-amber-500/10 border border-amber-500/20 px-2 py-0.5 rounded';
      } else {
        modalScore.className = 'text-base font-black text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded';
      }
      
      // Warnings list
      const warnings = post.seo?.warnings || [];
      if (warnings.length === 0) {
        modalWarnings.innerHTML = '<p class="text-emerald-400 text-xs flex items-center gap-1.5 font-medium">✓ No critical warnings. Content elements are fully optimized.</p>';
      } else {
        modalWarnings.innerHTML = warnings.map((w: string) => `
          <div class="flex items-start gap-2 bg-red-950/20 border border-red-900/30 text-red-300 rounded-xl p-3 text-xs leading-relaxed">
            <span class="text-red-400 font-bold select-none">⚠</span>
            <span>${w}</span>
          </div>
        `).join('');
      }
      
      // Recommendations list
      const recs = post.seo?.recommendations || [];
      if (recs.length === 0) {
        modalRecs.innerHTML = '<p class="text-gray-500 text-xs">No further actions required.</p>';
      } else {
        modalRecs.innerHTML = recs.map((r: string) => `
          <div class="flex items-start gap-2 bg-blue-950/20 border border-blue-900/30 text-blue-300 rounded-xl p-3 text-xs leading-relaxed">
            <span class="text-blue-400 font-bold select-none">ℹ</span>
            <span>${r}</span>
          </div>
        `).join('');
      }

      // Internal links suggestions
      const linking = post.seo?.internalLinkingSuggestions || [];
      if (linking.length === 0) {
        modalLinking.innerHTML = '<p class="text-gray-500 text-xs">No other guides in this category to link to yet.</p>';
      } else {
        modalLinking.innerHTML = linking.map((l: string) => `
          <div class="flex items-center gap-2 bg-gray-950/40 border border-gray-800 text-gray-300 rounded-xl px-3 py-2.5 text-xs">
            <span class="text-rose-500 font-bold">🔗</span>
            <span class="truncate">${l}</span>
          </div>
        `).join('');
      }
      
      modal.classList.remove('hidden');
    };
    
    (window as any).closeSeoAudit = function() {
      const modal = document.getElementById('seo-modal');
      if (modal) {
        modal.classList.add('hidden');
      }
    };

    (window as any).deletePost = async function(id: string, title: string) {
      if (isDeleting) return;
      if (!confirm(`Are you sure you want to delete "${title}"?\nThis action cannot be undone.`)) return;
      
      isDeleting = true;
      try {
        const res = await fetch(`/api/admin/posts?id=${id}`, { method: 'DELETE' });
        if (res.ok) {
          allPosts = allPosts.filter((p: any) => p.id !== id);
          updateCount();
          filterPosts(); 
        } else {
          alert('Failed to delete post. Please try again.');
        }
      } catch (error) {
        console.error('Delete error:', error);
        alert('An error occurred while deleting the post.');
      } finally {
        isDeleting = false;
      }
    };

    document.getElementById('search')?.addEventListener('input', filterPosts);
    document.getElementById('filter-status')?.addEventListener('change', filterPosts);
    document.getElementById('filter-category')?.addEventListener('change', filterPosts);
    
    loadPosts();
  </script>
</AdminLayout>

