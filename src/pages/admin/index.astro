---
export const prerender = false;
import '../../styles/global.css';

const session = Astro.cookies.get('admin_session');
if (session?.value === 'authenticated') return Astro.redirect('/admin/dashboard');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — Mershal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/png" href="/favicon-32x32.png" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-slate-950 flex items-center justify-center p-4 font-sans text-slate-300">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <img src="/logo.png" alt="Mershal Logo" class="h-6 mx-auto object-contain brightness-0 invert mb-2" />
      <p class="text-slate-500 text-xs font-black uppercase tracking-widest">Authority Publisher Console</p>
    </div>

    <div class="bg-slate-900/50 backdrop-blur-md rounded-2xl p-8 border border-slate-800 shadow-2xl">
      <h2 class="text-xl font-bold text-white mb-6">Publisher Login</h2>

      <div id="error" class="hidden mb-4 p-3 bg-red-950/50 border border-red-800 text-red-300 rounded-xl text-xs font-semibold"></div>

      <form id="login-form" class="space-y-5">
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5">Email Address</label>
          <input
            type="email"
            id="email"
            placeholder="name@mershal.in"
            class="w-full bg-slate-850 border border-slate-700 text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary-gold focus:ring-1 focus:ring-primary-gold transition"
            required
          />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5">Password</label>
          <input
            type="password"
            id="password"
            placeholder="••••••••"
            class="w-full bg-slate-850 border border-slate-700 text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary-gold focus:ring-1 focus:ring-primary-gold transition"
            required
          />
        </div>
        <button
          type="submit"
          id="submit-btn"
          class="w-full bg-primary-crimson hover:bg-primary-crimson/95 text-white font-bold py-3.5 rounded-xl text-sm transition shadow-lg hover:shadow-primary-crimson/10"
        >
          Sign In
        </button>
      </form>
    </div>

    <p class="text-center text-slate-600 text-xs mt-6">
      <a href="/" class="hover:text-slate-400 transition">← Back to website</a>
    </p>
  </div>

  <script>
    import { auth } from '../../lib/firebase-auth';
    import { signInWithEmailAndPassword } from 'firebase/auth';

    const loginForm = document.getElementById('login-form') as HTMLFormElement;

    loginForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const errorEl = document.getElementById('error') as HTMLDivElement;
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('password') as HTMLInputElement).value;

      btn.textContent = 'Signing in...';
      btn.disabled = true;
      errorEl.classList.add('hidden');

      try {
        // 1. Authenticate with Firebase Client Auth SDK
        const userCredential = await signInWithEmailAndPassword(auth, email, password);
        const user = userCredential.user;

        // 2. Fetch User ID Token
        const idToken = await user.getIdToken();

        // 3. Verify on server and create HTTP-Only session cookie
        const res = await fetch('/api/admin/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken }),
        });

        if (res.ok) {
          window.location.href = '/admin/dashboard';
        } else {
          const data = await res.json();
          throw new Error(data.error || 'Server session creation failed');
        }
      } catch (err: any) {
        console.error('Authentication Error:', err);
        errorEl.textContent = err.message || 'Authentication failed. Please verify credentials.';
        errorEl.classList.remove('hidden');
        btn.textContent = 'Sign In';
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
