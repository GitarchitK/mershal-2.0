---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { adminDb } from '../../lib/firebase-admin';

let stats = {
  totalArticles: 0,
  publishedToday: 0,
  totalTopics: 0,
  categories: {} as Record<string, number>
};

try {
  // Total articles
  const articlesSnap = await adminDb?.collection('posts').get();
  stats.totalArticles = articlesSnap?.size || 0;
  
  // Published today
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const todaySnap = await adminDb?.collection('posts')
    .where('publishedAt', '>=', today)
    .get();
  stats.publishedToday = todaySnap?.size || 0;
  
  // Total topics
  const topicsSnap = await adminDb?.collection('topicQueue').get();
  stats.totalTopics = topicsSnap?.size || 0;
  
  // Articles by category for international audience
  const categories = ['usa', 'canada', 'australia', 'technology', 'business', 'politics', 'world', 'entertainment'];
  for (const cat of categories) {
    const catSnap = await adminDb?.collection('posts').where('category', '==', cat).get();
    stats.categories[cat] = catSnap?.size || 0;
  }
} catch (error) {
  console.error('Error fetching stats:', error);
}
---

<Layout title="Stats - Mershal Admin">
  <Header />
  
  <main class="container mx-auto px-4 py-6 pb-24 md:pb-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">📊 Dashboard Stats</h1>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-lg shadow-md p-6 text-center">
        <p class="text-3xl font-bold text-red-600">{stats.totalArticles}</p>
        <p class="text-gray-600 text-sm">Total Articles</p>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6 text-center">
        <p class="text-3xl font-bold text-green-600">{stats.publishedToday}</p>
        <p class="text-gray-600 text-sm">Published Today</p>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6 text-center">
        <p class="text-3xl font-bold text-blue-600">{stats.totalTopics}</p>
        <p class="text-gray-600 text-sm">Pending Topics</p>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6 text-center">
        <p class="text-3xl font-bold text-purple-600">{Object.values(stats.categories).reduce((a: any, b: any) => a + b, 0)}</p>
        <p class="text-gray-600 text-sm">Categories</p>
      </div>
    </div>
    
    <!-- Category Breakdown -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <h2 class="text-lg font-semibold mb-4">Articles by Category</h2>
      <div class="space-y-3">
        {Object.entries(stats.categories).map(([cat, count]) => (
          <div class="flex items-center justify-between">
            <span class="capitalize text-gray-700">{cat}</span>
            <div class="flex items-center gap-2">
              <div class="w-32 bg-gray-200 rounded-full h-2">
                <div 
                  class="bg-red-600 h-2 rounded-full" 
                  style={`width: ${Math.min((count as number / stats.totalArticles) * 100, 100)}%`}
                ></div>
              </div>
              <span class="text-sm font-medium text-gray-900 w-8">{count as number}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Quick Links -->
    <div class="grid grid-cols-2 gap-4">
      <a 
        href="/admin/topics"
        class="bg-red-600 text-white py-4 px-6 rounded-lg text-center font-semibold hover:bg-red-700 transition"
      >
        📝 Manage Topics
      </a>
      <a 
        href="/"
        class="bg-gray-600 text-white py-4 px-6 rounded-lg text-center font-semibold hover:bg-gray-700 transition"
      >
        🏠 Home
      </a>
    </div>
  </main>
  
  <Footer />
</Layout>