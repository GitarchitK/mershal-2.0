---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
---

<AdminLayout title="New Post" activeNav="new-post">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">New Post</h1>
      <p class="text-gray-400 text-sm mt-0.5">Block-based editor — drag to reorder</p>
    </div>
    <div class="flex gap-3">
      <button id="save-draft" class="bg-gray-800 hover:bg-gray-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">Save Draft</button>
      <button id="publish-btn" class="bg-rose-600 hover:bg-rose-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">Publish</button>
    </div>
  </div>

  <div id="alert" class="hidden mb-5 p-4 rounded-lg text-sm font-medium"></div>

  <div class="grid grid-cols-3 gap-6">
    <!-- Editor -->
    <div class="col-span-2">
      <!-- Title -->
      <div class="mb-4">
        <input id="title" type="text" placeholder="Post title..."
          class="w-full bg-gray-900 border border-gray-700 text-white text-2xl font-bold rounded-xl px-5 py-4 focus:outline-none focus:border-rose-500 placeholder-gray-600" />
      </div>
      <div class="mb-4">
        <input id="slug" type="text" placeholder="url-slug (auto-generated)"
          class="w-full bg-gray-900 border border-gray-700 text-gray-400 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-rose-500 font-mono placeholder-gray-600" />
      </div>
      <div class="mb-4">
        <textarea id="excerpt" rows="2" placeholder="Brief excerpt / description..."
          class="w-full bg-gray-900 border border-gray-700 text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-rose-500 resize-none placeholder-gray-600"></textarea>
      </div>

      <!-- Block Builder -->
      <div class="bg-gray-900 rounded-xl border border-gray-700 p-4 mb-4">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Content Blocks</span>
          <span id="word-count" class="text-xs text-gray-500">0 words</span>
        </div>

        <!-- Blocks container -->
        <div id="blocks-container" class="space-y-2 min-h-[200px]"></div>

        <!-- Add block buttons -->
        <div class="mt-4 pt-4 border-t border-gray-800">
          <p class="text-xs text-gray-500 mb-3">Add block:</p>
          <div class="flex flex-wrap gap-2">
            <button onclick="addBlock('paragraph')" class="add-block-btn">¶ Paragraph</button>
            <button onclick="addBlock('heading2')" class="add-block-btn">H2 Heading</button>
            <button onclick="addBlock('heading3')" class="add-block-btn">H3 Heading</button>
            <button onclick="addBlock('image')" class="add-block-btn">🖼 Image</button>
            <button onclick="addBlock('code')" class="add-block-btn">{'</>'} Code</button>
            <button onclick="addBlock('quote')" class="add-block-btn">" Quote</button>
            <button onclick="addBlock('list')" class="add-block-btn">• List</button>
            <button onclick="addBlock('divider')" class="add-block-btn">— Divider</button>
            <button onclick="addBlock('callout')" class="add-block-btn">💡 Callout</button>
          </div>
        </div>
      </div>

      <!-- HTML Preview -->
      <details class="bg-gray-900 rounded-xl border border-gray-700 p-4">
        <summary class="text-xs font-semibold text-gray-400 uppercase tracking-wider cursor-pointer">HTML Output (read-only)</summary>
        <pre id="html-preview" class="mt-3 text-xs text-gray-400 overflow-x-auto whitespace-pre-wrap break-all"></pre>
      </details>
    </div>

    <!-- Sidebar -->
    <div class="space-y-5">
      <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
        <h3 class="text-sm font-semibold text-gray-300 mb-4">Post Settings</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">Category</label>
            <select id="category" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
              <option value="technology">Technology</option>
              <option value="programming">Programming</option>
              <option value="tutorials">Tutorials</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">Author</label>
            <input id="author" type="text" value="Archit Karmakar" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">Tags (comma separated)</label>
            <input id="tags" type="text" placeholder="javascript, react, tutorial" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500 placeholder-gray-600" />
          </div>
        </div>
      </div>

      <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
        <h3 class="text-sm font-semibold text-gray-300 mb-3">Featured Image</h3>
        <input id="featured-image" type="url" placeholder="https://images.unsplash.com/..." class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500 placeholder-gray-600 mb-2" />
        <div id="image-preview" class="hidden">
          <img id="preview-img" src="" alt="Preview" class="w-full h-28 object-cover rounded-lg" />
        </div>
      </div>

      <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
        <h3 class="text-sm font-semibold text-gray-300 mb-4">SEO</h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">SEO Title</label>
            <input id="seo-title" type="text" placeholder="Leave blank to use post title" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500 placeholder-gray-600" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">Meta Description</label>
            <textarea id="seo-desc" rows="3" placeholder="Leave blank to use excerpt" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500 resize-none placeholder-gray-600"></textarea>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .add-block-btn {
    background: #1e293b;
    color: #94a3b8;
    border: 1px solid #334155;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .add-block-btn:hover {
    background: #334155;
    color: #e2e8f0;
    border-color: #475569;
  }
  .block-item {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 0.75rem;
    padding: 0.75rem;
    position: relative;
    cursor: default;
  }
  .block-item.dragging {
    opacity: 0.4;
    border-style: dashed;
  }
  .block-item.drag-over {
    border-color: #f43f5e;
    background: #1f1520;
  }
  .block-toolbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .block-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #64748b;
    flex: 1;
  }
  .block-btn {
    background: transparent;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    transition: color 0.15s;
    line-height: 1;
  }
  .block-btn:hover { color: #e2e8f0; }
  .block-btn.drag-handle { cursor: grab; font-size: 1rem; }
  .block-btn.delete:hover { color: #f43f5e; }
  .block-input {
    width: 100%;
    background: transparent;
    border: none;
    color: #e2e8f0;
    font-size: 0.9rem;
    line-height: 1.6;
    resize: none;
    outline: none;
    font-family: inherit;
  }
  .block-input::placeholder { color: #475569; }
  .block-input.code-input {
    font-family: 'SF Mono', 'Consolas', monospace;
    font-size: 0.8rem;
    background: #0d1117;
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #30363d;
    color: #e6edf3;
  }
  .block-input.heading2 { font-size: 1.4rem; font-weight: 700; }
  .block-input.heading3 { font-size: 1.15rem; font-weight: 600; }
  .block-input.quote-input {
    border-left: 3px solid #f43f5e;
    padding-left: 0.75rem;
    font-style: italic;
    color: #94a3b8;
  }
  .block-input.callout-input {
    background: #1e3a5f;
    padding: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #1e40af;
  }
  .divider-block {
    border-top: 2px solid #334155;
    margin: 0.5rem 0;
  }
  .lang-select {
    background: #1e293b;
    border: 1px solid #334155;
    color: #94a3b8;
    font-size: 0.7rem;
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    outline: none;
  }
</style>

<script>
  let blocks: any[] = [];
  let dragSrcIndex: number | null = null;

  // ── Block definitions ──────────────────────────────────────────
  const blockDefs: Record<string, { label: string; defaultContent: string; placeholder: string }> = {
    paragraph: { label: 'Paragraph', defaultContent: '', placeholder: 'Write something...' },
    heading2:  { label: 'H2 Heading', defaultContent: '', placeholder: 'Section heading...' },
    heading3:  { label: 'H3 Heading', defaultContent: '', placeholder: 'Sub-heading...' },
    image:     { label: 'Image', defaultContent: '', placeholder: 'https://images.unsplash.com/...' },
    code:      { label: 'Code', defaultContent: '', placeholder: '// paste your code here' },
    quote:     { label: 'Quote', defaultContent: '', placeholder: 'Blockquote text...' },
    list:      { label: 'List', defaultContent: '', placeholder: 'Item 1\nItem 2\nItem 3' },
    divider:   { label: 'Divider', defaultContent: '', placeholder: '' },
    callout:   { label: 'Callout', defaultContent: '', placeholder: '💡 Key point or tip...' },
  };

  function addBlock(type: string, content = '', meta = '') {
    const id = `block-${Date.now()}-${Math.random().toString(36).slice(2)}`;
    blocks.push({ id, type, content, meta });
    renderBlocks();
    // Focus the new block
    setTimeout(() => {
      const el = document.getElementById(`input-${id}`) as HTMLTextAreaElement;
      if (el) { el.focus(); autoResize(el); }
    }, 50);
  }

  function removeBlock(id: string) {
    blocks = blocks.filter(b => b.id !== id);
    renderBlocks();
  }

  function moveBlock(id: string, dir: 'up' | 'down') {
    const idx = blocks.findIndex(b => b.id === id);
    if (dir === 'up' && idx > 0) [blocks[idx - 1], blocks[idx]] = [blocks[idx], blocks[idx - 1]];
    if (dir === 'down' && idx < blocks.length - 1) [blocks[idx], blocks[idx + 1]] = [blocks[idx + 1], blocks[idx]];
    renderBlocks();
  }

  function updateBlock(id: string, content: string) {
    const b = blocks.find(b => b.id === id);
    if (b) b.content = content;
    updateWordCount();
    updateHtmlPreview();
  }

  function updateBlockMeta(id: string, meta: string) {
    const b = blocks.find(b => b.id === id);
    if (b) b.meta = meta;
    updateHtmlPreview();
  }

  function autoResize(el: HTMLTextAreaElement) {
    el.style.height = 'auto';
    el.style.height = el.scrollHeight + 'px';
  }

  function renderBlocks() {
    const container = document.getElementById('blocks-container')!;
    container.innerHTML = '';

    if (blocks.length === 0) {
      container.innerHTML = '<p class="text-gray-600 text-sm text-center py-8">No blocks yet. Add one below ↓</p>';
      updateHtmlPreview();
      return;
    }

    blocks.forEach((block, idx) => {
      const div = document.createElement('div');
      div.className = 'block-item';
      div.draggable = true;
      div.dataset.id = block.id;
      div.dataset.idx = String(idx);

      // Drag events
      div.addEventListener('dragstart', (e) => {
        dragSrcIndex = idx;
        div.classList.add('dragging');
        e.dataTransfer!.effectAllowed = 'move';
      });
      div.addEventListener('dragend', () => div.classList.remove('dragging'));
      div.addEventListener('dragover', (e) => { e.preventDefault(); div.classList.add('drag-over'); });
      div.addEventListener('dragleave', () => div.classList.remove('drag-over'));
      div.addEventListener('drop', (e) => {
        e.preventDefault();
        div.classList.remove('drag-over');
        if (dragSrcIndex !== null && dragSrcIndex !== idx) {
          const moved = blocks.splice(dragSrcIndex, 1)[0];
          blocks.splice(idx, 0, moved);
          dragSrcIndex = null;
          renderBlocks();
        }
      });

      const def = blockDefs[block.type] || blockDefs.paragraph;

      // Toolbar
      const toolbar = `
        <div class="block-toolbar">
          <span class="block-btn drag-handle" title="Drag to reorder">⠿</span>
          <span class="block-label">${def.label}</span>
          ${idx > 0 ? `<button class="block-btn" onclick="moveBlock('${block.id}','up')" title="Move up">↑</button>` : ''}
          ${idx < blocks.length - 1 ? `<button class="block-btn" onclick="moveBlock('${block.id}','down')" title="Move down">↓</button>` : ''}
          <button class="block-btn delete" onclick="removeBlock('${block.id}')" title="Delete">✕</button>
        </div>`;

      let inputHtml = '';

      if (block.type === 'divider') {
        inputHtml = '<div class="divider-block"></div>';
      } else if (block.type === 'image') {
        inputHtml = `
          <input id="input-${block.id}" type="url" class="block-input" placeholder="${def.placeholder}"
            value="${block.content.replace(/"/g, '&quot;')}"
            oninput="updateBlock('${block.id}', this.value)" />
          ${block.content ? `<img src="${block.content}" alt="preview" class="mt-2 w-full h-32 object-cover rounded-lg" onerror="this.style.display='none'" />` : ''}`;
      } else if (block.type === 'code') {
        const lang = block.meta || 'javascript';
        inputHtml = `
          <div class="flex items-center gap-2 mb-2">
            <select class="lang-select" onchange="updateBlockMeta('${block.id}', this.value)">
              ${['javascript','typescript','python','html','css','bash','json','sql','jsx','tsx'].map(l =>
                `<option value="${l}" ${l === lang ? 'selected' : ''}>${l}</option>`
              ).join('')}
            </select>
          </div>
          <textarea id="input-${block.id}" class="block-input code-input" rows="5"
            placeholder="${def.placeholder}"
            oninput="updateBlock('${block.id}', this.value); autoResize(this)"
          >${block.content}</textarea>`;
      } else if (block.type === 'list') {
        inputHtml = `<textarea id="input-${block.id}" class="block-input" rows="4"
          placeholder="${def.placeholder}"
          oninput="updateBlock('${block.id}', this.value); autoResize(this)"
        >${block.content}</textarea>
        <p class="text-xs text-gray-600 mt-1">One item per line</p>`;
      } else {
        const extraClass = ['heading2','heading3','quote','callout'].includes(block.type)
          ? block.type === 'quote' ? 'quote-input' : block.type === 'callout' ? 'callout-input' : block.type
          : '';
        inputHtml = `<textarea id="input-${block.id}" class="block-input ${extraClass}" rows="2"
          placeholder="${def.placeholder}"
          oninput="updateBlock('${block.id}', this.value); autoResize(this)"
        >${block.content}</textarea>`;
      }

      div.innerHTML = toolbar + inputHtml;
      container.appendChild(div);

      // Auto-resize textareas
      const ta = div.querySelector(`#input-${block.id}`) as HTMLTextAreaElement;
      if (ta && ta.tagName === 'TEXTAREA') autoResize(ta);
    });

    updateWordCount();
    updateHtmlPreview();
  }

  function blocksToHtml(): string {
    return blocks.map(b => {
      const c = b.content.trim();
      switch (b.type) {
        case 'paragraph': return c ? `<p>${c}</p>` : '';
        case 'heading2':  return c ? `<h2>${c}</h2>` : '';
        case 'heading3':  return c ? `<h3>${c}</h3>` : '';
        case 'image':     return c ? `<figure><img src="${c}" alt="" loading="lazy" /></figure>` : '';
        case 'code':      return c ? `<pre><code class="language-${b.meta || 'javascript'}">${c.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</code></pre>` : '';
        case 'quote':     return c ? `<blockquote><p>${c}</p></blockquote>` : '';
        case 'list': {
          const items = c.split('\n').filter(Boolean).map(i => `<li>${i.trim()}</li>`).join('');
          return items ? `<ul>${items}</ul>` : '';
        }
        case 'divider':   return '<hr />';
        case 'callout':   return c ? `<div class="callout"><p>${c}</p></div>` : '';
        default:          return c ? `<p>${c}</p>` : '';
      }
    }).filter(Boolean).join('\n');
  }

  function updateWordCount() {
    const text = blocks.map(b => b.content).join(' ').replace(/<[^>]*>/g, '');
    const words = text.trim() ? text.trim().split(/\s+/).length : 0;
    const el = document.getElementById('word-count');
    if (el) el.textContent = `${words} words`;
  }

  function updateHtmlPreview() {
    const el = document.getElementById('html-preview');
    if (el) el.textContent = blocksToHtml();
  }

  // ── Save / Publish ─────────────────────────────────────────────
  function showAlert(msg: string, type: 'success' | 'error') {
    const el = document.getElementById('alert')!;
    el.textContent = msg;
    el.className = `mb-5 p-4 rounded-lg text-sm font-medium ${type === 'success' ? 'bg-green-900/50 text-green-300 border border-green-700' : 'bg-red-900/50 text-red-300 border border-red-700'}`;
    el.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  async function savePost(status: string) {
    const title = (document.getElementById('title') as HTMLInputElement).value.trim();
    if (!title) { showAlert('Title is required', 'error'); return; }

    const content = blocksToHtml();
    if (!content.trim()) { showAlert('Add at least one content block', 'error'); return; }

    const tags = (document.getElementById('tags') as HTMLInputElement).value.split(',').map((t: string) => t.trim()).filter(Boolean);
    const payload = {
      title,
      slug: (document.getElementById('slug') as HTMLInputElement).value || undefined,
      excerpt: (document.getElementById('excerpt') as HTMLTextAreaElement).value,
      content,
      category: (document.getElementById('category') as HTMLSelectElement).value,
      author: (document.getElementById('author') as HTMLInputElement).value,
      tags,
      featuredImage: (document.getElementById('featured-image') as HTMLInputElement).value,
      seoTitle: (document.getElementById('seo-title') as HTMLInputElement).value,
      seoDescription: (document.getElementById('seo-desc') as HTMLTextAreaElement).value,
      status,
    };

    const btnId = status === 'published' ? 'publish-btn' : 'save-draft';
    const btn = document.getElementById(btnId) as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Saving...';

    const res = await fetch('/api/admin/posts', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await res.json();

    if (res.ok) {
      showAlert(`Post ${status === 'published' ? 'published' : 'saved as draft'}!`, 'success');
      setTimeout(() => window.location.href = '/admin/posts', 1500);
    } else {
      showAlert(data.error || 'Failed to save', 'error');
      btn.disabled = false;
      btn.textContent = status === 'published' ? 'Publish' : 'Save Draft';
    }
  }

  // ── Init ───────────────────────────────────────────────────────
  document.getElementById('title')?.addEventListener('input', (e) => {
    const slug = (e.target as HTMLInputElement).value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    (document.getElementById('slug') as HTMLInputElement).value = slug;
  });

  document.getElementById('featured-image')?.addEventListener('input', (e) => {
    const url = (e.target as HTMLInputElement).value;
    const preview = document.getElementById('image-preview')!;
    if (url) { (document.getElementById('preview-img') as HTMLImageElement).src = url; preview.classList.remove('hidden'); }
    else preview.classList.add('hidden');
  });

  document.getElementById('publish-btn')?.addEventListener('click', () => savePost('published'));
  document.getElementById('save-draft')?.addEventListener('click', () => savePost('draft'));

  // Start with one paragraph block
  addBlock('paragraph');
</script>
