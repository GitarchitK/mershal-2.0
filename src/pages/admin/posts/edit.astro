---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
const postId = Astro.url.searchParams.get('id');
if (!postId) return Astro.redirect('/admin/posts');
---

<AdminLayout title="Edit Post" activeNav="posts">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">Edit Post</h1>
      <p class="text-gray-400 text-sm mt-0.5 font-mono" id="post-slug-display">Loading...</p>
    </div>
    <div class="flex gap-3">
      <span id="word-count" class="text-xs text-gray-500 self-center">0 words</span>
      <a id="view-post-link" href="#" target="_blank" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition">View ↗</a>
      <button id="save-draft" class="bg-gray-700 hover:bg-gray-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">Save Draft</button>
      <button id="publish-btn" class="bg-rose-600 hover:bg-rose-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition">Update & Publish</button>
    </div>
  </div>

  <div id="alert" class="hidden mb-5 p-4 rounded-lg text-sm font-medium"></div>
  <div id="loading" class="text-gray-400 text-sm py-10 text-center">Loading post...</div>

  <div id="editor-wrapper" class="hidden grid-cols-3 gap-6" data-post-id={postId}>
    <div class="col-span-2 space-y-4">
      <input id="title" type="text" placeholder="Post title..."
        class="w-full bg-transparent border-none text-white text-3xl font-black focus:outline-none placeholder-gray-700" />
      <input id="slug" type="text"
        class="w-full bg-gray-900 border border-gray-700 text-gray-400 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-rose-500 font-mono" />
      <textarea id="excerpt" rows="2" placeholder="Brief excerpt..."
        class="w-full bg-gray-900 border border-gray-700 text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-rose-500 resize-none placeholder-gray-600"></textarea>

      <div class="bg-gray-900 rounded-2xl border border-gray-700 min-h-[600px] relative">
        <div id="editorjs" class="px-12 py-8"></div>
      </div>
    </div>

    <div class="space-y-5">
      <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
        <h3 class="text-sm font-semibold text-gray-300 mb-4">Post Settings</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">Category</label>
            <select id="category" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500">
              <option value="technology">Technology</option>
              <option value="programming">Programming</option>
              <option value="tutorials">Tutorials</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">Author</label>
            <input id="author" type="text" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">Tags (comma separated)</label>
            <input id="tags" type="text" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500" />
          </div>
        </div>
      </div>

      <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
        <h3 class="text-sm font-semibold text-gray-300 mb-3">Featured Image</h3>
        <input id="featured-image" type="url" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500 mb-2" />
        <div id="image-preview" class="hidden">
          <img id="preview-img" src="" alt="Preview" class="w-full h-28 object-cover rounded-lg" />
        </div>
      </div>

      <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
        <h3 class="text-sm font-semibold text-gray-300 mb-4">SEO</h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">SEO Title</label>
            <input id="seo-title" type="text" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1.5">Meta Description</label>
            <textarea id="seo-desc" rows="3" class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-500 resize-none"></textarea>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<style is:global>
  #editorjs { color: #e2e8f0; }
  .ce-block__content, .ce-toolbar__content { max-width: 100% !important; }
  .ce-paragraph { color: #e2e8f0; font-size: 1rem; line-height: 1.8; }
  .ce-paragraph[data-placeholder]:empty::before { color: #475569; }
  .ce-header { color: #ffffff; }
  .ce-toolbar__plus, .ce-toolbar__settings-btn { color: #94a3b8 !important; background: #1e293b !important; border: 1px solid #334155 !important; }
  .ce-toolbar__plus:hover, .ce-toolbar__settings-btn:hover { background: #334155 !important; color: #e2e8f0 !important; }
  .ce-popover { background: #1e293b !important; border: 1px solid #334155 !important; box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important; }
  .ce-popover__item { color: #e2e8f0 !important; }
  .ce-popover__item:hover { background: #334155 !important; }
  .ce-popover__item-icon { background: #334155 !important; }
  .ce-popover__search { background: #0f172a !important; border: 1px solid #334155 !important; color: #e2e8f0 !important; }
  .ce-inline-toolbar { background: #1e293b !important; border: 1px solid #334155 !important; box-shadow: 0 4px 16px rgba(0,0,0,0.5) !important; }
  .ce-inline-tool { color: #94a3b8 !important; }
  .ce-inline-tool:hover, .ce-inline-tool--active { color: #f43f5e !important; }
  .ce-conversion-toolbar { background: #1e293b !important; border: 1px solid #334155 !important; }
  .ce-conversion-tool { color: #e2e8f0 !important; }
  .ce-conversion-tool:hover { background: #334155 !important; }
  .cdx-block { color: #e2e8f0; }
  .cdx-quote__text, .cdx-quote__caption { color: #94a3b8; }
  .cdx-quote { border-left: 4px solid #f43f5e; padding-left: 1rem; }
  .ce-code__textarea { background: #0d1117 !important; color: #e6edf3 !important; border: 1px solid #30363d !important; border-radius: 0.5rem !important; font-family: 'SF Mono','Consolas',monospace !important; font-size: 0.875rem !important; }
  .cdx-list__item { color: #e2e8f0; }
  .cdx-delimiter::before { color: #475569; }
  .image-tool__image { border-radius: 0.5rem; }
  .image-tool__caption { color: #94a3b8 !important; background: transparent !important; }
  .tc-table { border-color: #334155 !important; }
  .tc-cell { border-color: #334155 !important; color: #e2e8f0 !important; background: #1e293b !important; }
  .ce-block--selected .ce-block__content { background: #1e293b !important; }
  .cdx-warning { background: #1e293b; border-left: 4px solid #f59e0b; padding: 1rem; border-radius: 0 0.5rem 0.5rem 0; }
  .cdx-warning__title { color: #fbbf24; font-weight: 700; }
  .cdx-warning__message { color: #e2e8f0; }
</style>

<script type="module">
  const EditorJS = (await import('https://esm.sh/@editorjs/editorjs@2.30.7')).default;
  const Header = (await import('https://esm.sh/@editorjs/header@2.8.8')).default;
  const List = (await import('https://esm.sh/@editorjs/list@2.0.2')).default;
  const Quote = (await import('https://esm.sh/@editorjs/quote@2.7.6')).default;
  const Code = (await import('https://esm.sh/@editorjs/code@2.9.3')).default;
  const Delimiter = (await import('https://esm.sh/@editorjs/delimiter@1.4.2')).default;
  const InlineCode = (await import('https://esm.sh/@editorjs/inline-code@1.5.1')).default;
  const Underline = (await import('https://esm.sh/@editorjs/underline@1.1.0')).default;
  const ImageTool = (await import('https://esm.sh/@editorjs/image@2.10.1')).default;
  const Table = (await import('https://esm.sh/@editorjs/table@2.4.3')).default;
  const Warning = (await import('https://esm.sh/@editorjs/warning@1.4.0')).default;
  const Checklist = (await import('https://esm.sh/@editorjs/checklist@1.6.0')).default;

  const postId = document.getElementById('editor-wrapper').dataset.postId;
  let editor;

  // Convert HTML back to Editor.js blocks for editing
  function htmlToEditorBlocks(html) {
    if (!html) return [];
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    const blocks = [];
    doc.body.childNodes.forEach(node => {
      if (node.nodeType !== 1) return;
      const tag = node.tagName.toLowerCase();
      if (['h1','h2','h3','h4'].includes(tag)) {
        blocks.push({ type: 'header', data: { text: node.innerHTML, level: parseInt(tag[1]) } });
      } else if (tag === 'p') {
        if (node.innerHTML.trim()) blocks.push({ type: 'paragraph', data: { text: node.innerHTML } });
      } else if (tag === 'ul') {
        const items = Array.from(node.querySelectorAll('li')).map(li => li.innerHTML);
        blocks.push({ type: 'list', data: { style: 'unordered', items } });
      } else if (tag === 'ol') {
        const items = Array.from(node.querySelectorAll('li')).map(li => li.innerHTML);
        blocks.push({ type: 'list', data: { style: 'ordered', items } });
      } else if (tag === 'blockquote') {
        const p = node.querySelector('p');
        blocks.push({ type: 'quote', data: { text: p ? p.innerHTML : node.innerHTML, caption: '' } });
      } else if (tag === 'pre') {
        const code = node.querySelector('code');
        blocks.push({ type: 'code', data: { code: code ? code.textContent : node.textContent } });
      } else if (tag === 'hr') {
        blocks.push({ type: 'delimiter', data: {} });
      } else if (tag === 'figure') {
        const img = node.querySelector('img');
        const cap = node.querySelector('figcaption');
        if (img) blocks.push({ type: 'image', data: { file: { url: img.src }, caption: cap ? cap.textContent : '', withBorder: false, stretched: false, withBackground: false } });
      } else if (node.innerHTML.trim()) {
        blocks.push({ type: 'paragraph', data: { text: node.innerHTML } });
      }
    });
    return blocks;
  }

  function editorDataToHtml(data) {
    return data.blocks.map(block => {
      const d = block.data;
      switch (block.type) {
        case 'header': return `<h${d.level}>${d.text}</h${d.level}>`;
        case 'paragraph': return `<p>${d.text}</p>`;
        case 'list': {
          const tag = d.style === 'ordered' ? 'ol' : 'ul';
          const items = d.items.map(i => `<li>${typeof i === 'object' ? i.content : i}</li>`).join('');
          return `<${tag}>${items}</${tag}>`;
        }
        case 'checklist': {
          const checks = d.items.map(i => `<li>${i.checked ? '✓' : '○'} ${i.text}</li>`).join('');
          return `<ul class="checklist">${checks}</ul>`;
        }
        case 'quote': return `<blockquote><p>${d.text}</p>${d.caption ? `<cite>${d.caption}</cite>` : ''}</blockquote>`;
        case 'code': return `<pre><code>${d.code.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</code></pre>`;
        case 'delimiter': return '<hr />';
        case 'image': {
          const cap = d.caption ? `<figcaption>${d.caption}</figcaption>` : '';
          return `<figure><img src="${d.file.url}" alt="${d.caption || ''}" loading="lazy" />${cap}</figure>`;
        }
        case 'table': {
          const rows = d.content.map((row, i) => {
            const cells = row.map(cell => i === 0 ? `<th>${cell}</th>` : `<td>${cell}</td>`).join('');
            return `<tr>${cells}</tr>`;
          }).join('');
          return `<table><tbody>${rows}</tbody></table>`;
        }
        case 'warning': return `<div class="callout warning"><strong>${d.title}</strong><p>${d.message}</p></div>`;
        default: return d.text ? `<p>${d.text}</p>` : '';
      }
    }).filter(Boolean).join('\n');
  }

  async function loadPost() {
    const res = await fetch(`/api/admin/posts?id=${postId}`);
    if (!res.ok) { window.location.href = '/admin/posts'; return; }
    const post = await res.json();

    document.getElementById('loading').classList.add('hidden');
    const wrapper = document.getElementById('editor-wrapper');
    wrapper.classList.remove('hidden');
    wrapper.style.display = 'grid';

    document.getElementById('title').value = post.title || '';
    document.getElementById('slug').value = post.slug || '';
    document.getElementById('excerpt').value = post.excerpt || '';
    document.getElementById('author').value = post.author || 'Archit Karmakar';
    document.getElementById('tags').value = (post.tags || []).join(', ');
    document.getElementById('featured-image').value = post.featuredImage || '';
    document.getElementById('seo-title').value = post.seoTitle || '';
    document.getElementById('seo-desc').value = post.seoDescription || '';
    document.getElementById('category').value = post.category || 'technology';
    document.getElementById('post-slug-display').textContent = `/news/${post.slug}`;
    document.getElementById('view-post-link').href = `/news/${post.slug}`;

    if (post.featuredImage) {
      document.getElementById('preview-img').src = post.featuredImage;
      document.getElementById('image-preview').classList.remove('hidden');
    }

    const existingBlocks = htmlToEditorBlocks(post.content || '');

    editor = new EditorJS({
      holder: 'editorjs',
      placeholder: 'Click here to start writing. Press / to see all available blocks.',
      data: existingBlocks.length ? { blocks: existingBlocks } : undefined,
      tools: {
        header: { class: Header, config: { levels: [2, 3, 4], defaultLevel: 2 }, inlineToolbar: true },
        list: { class: List, inlineToolbar: true, config: { defaultStyle: 'unordered' } },
        checklist: { class: Checklist, inlineToolbar: true },
        quote: { class: Quote, inlineToolbar: true },
        code: Code,
        delimiter: Delimiter,
        inlineCode: { class: InlineCode, shortcut: 'CMD+SHIFT+M' },
        underline: Underline,
        image: {
          class: ImageTool,
          config: {
            uploader: {
              uploadByUrl(url) { return Promise.resolve({ success: 1, file: { url } }); },
              uploadByFile(file) {
                return new Promise((resolve) => {
                  const reader = new FileReader();
                  reader.onload = (e) => resolve({ success: 1, file: { url: e.target.result } });
                  reader.readAsDataURL(file);
                });
              },
            },
          },
        },
        table: { class: Table, inlineToolbar: true },
        warning: { class: Warning, inlineToolbar: true },
      },
      onChange: async () => {
        const data = await editor.save();
        const text = data.blocks.map(b => {
          if (b.data.text) return b.data.text.replace(/<[^>]*>/g, '');
          if (b.data.items) return b.data.items.join(' ');
          if (b.data.code) return b.data.code;
          return '';
        }).join(' ');
        const words = text.trim() ? text.trim().split(/\s+/).length : 0;
        document.getElementById('word-count').textContent = `${words} words`;
      },
    });
  }

  document.getElementById('featured-image').addEventListener('input', (e) => {
    const url = e.target.value;
    if (url) { document.getElementById('preview-img').src = url; document.getElementById('image-preview').classList.remove('hidden'); }
    else document.getElementById('image-preview').classList.add('hidden');
  });

  function showAlert(msg, type) {
    const el = document.getElementById('alert');
    el.textContent = msg;
    el.className = `mb-5 p-4 rounded-lg text-sm font-medium ${type === 'success' ? 'bg-green-900/50 text-green-300 border border-green-700' : 'bg-red-900/50 text-red-300 border border-red-700'}`;
    el.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  async function updatePost(status) {
    const title = document.getElementById('title').value.trim();
    if (!title) { showAlert('Title is required', 'error'); return; }

    const editorData = await editor.save();
    const content = editorDataToHtml(editorData);
    const tags = document.getElementById('tags').value.split(',').map(t => t.trim()).filter(Boolean);

    const payload = {
      id: postId,
      title,
      slug: document.getElementById('slug').value,
      excerpt: document.getElementById('excerpt').value,
      content,
      category: document.getElementById('category').value,
      author: document.getElementById('author').value,
      tags,
      featuredImage: document.getElementById('featured-image').value,
      seoTitle: document.getElementById('seo-title').value,
      seoDescription: document.getElementById('seo-desc').value,
      status,
    };

    const btnId = status === 'published' ? 'publish-btn' : 'save-draft';
    const btn = document.getElementById(btnId);
    btn.disabled = true; btn.textContent = 'Saving...';

    const res = await fetch('/api/admin/posts', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const data = await res.json();

    if (res.ok) {
      showAlert('Post updated!', 'success');
    } else {
      showAlert(data.error || 'Failed to update', 'error');
    }
    btn.disabled = false;
    btn.textContent = status === 'published' ? 'Update & Publish' : 'Save Draft';
  }

  document.getElementById('publish-btn').addEventListener('click', () => updatePost('published'));
  document.getElementById('save-draft').addEventListener('click', () => updatePost('draft'));

  loadPost();
</script>
