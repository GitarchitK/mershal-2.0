---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const session = Astro.cookies.get('admin_session');
if (session?.value !== 'authenticated') return Astro.redirect('/admin');
const postId = Astro.url.searchParams.get('id');
if (!postId) return Astro.redirect('/admin/posts');
---

<AdminLayout title="Edit Post" activeNav="posts">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-black font-outfit text-white tracking-tight">Edit Post</h1>
      <p class="text-slate-450 text-xs font-mono mt-1 font-outfit" id="post-slug-display">Loading...</p>
    </div>
    <div class="flex gap-3 items-center">
      <a id="view-post-link" href="#" target="_blank" class="bg-slate-900 hover:bg-slate-800 border border-slate-800 hover:border-slate-700 text-slate-200 px-5 py-2.5 rounded-xl text-xs font-bold font-outfit transition-all cursor-pointer">View Post</a>
      <button id="save-draft" class="bg-slate-900 hover:bg-slate-800 border border-slate-800 hover:border-slate-700 text-slate-200 px-5 py-2.5 rounded-xl text-xs font-bold font-outfit transition-all cursor-pointer">Save Draft</button>
      <button id="publish-btn" class="bg-rose-600 hover:bg-rose-500 hover:shadow-lg hover:shadow-rose-600/10 text-white px-5 py-2.5 rounded-xl text-xs font-bold font-outfit transition-all active:scale-[0.98] cursor-pointer">Update & Publish</button>
    </div>
  </div>

  <div id="alert" class="hidden mb-5 p-4 rounded-xl text-xs font-semibold font-outfit border animate-in fade-in duration-200"></div>
  
  <div id="loading" class="text-slate-400 text-sm py-12 text-center font-outfit bg-slate-900/20 rounded-2xl border border-slate-850/60 backdrop-blur-sm">
    <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-r-2 border-rose-500 mb-3"></div>
    <p>Loading post data...</p>
  </div>

  <div id="editor" class="hidden grid-cols-1 lg:grid-cols-3 gap-6" data-post-id={postId}>
    <div class="lg:col-span-2 space-y-5">
      <input id="title" type="text" placeholder="Post title..." class="w-full bg-slate-900/40 border border-slate-800 text-white text-xl font-bold font-outfit rounded-xl px-5 py-4 focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-500/20 placeholder-slate-600 transition-all shadow-inner" />
      <input id="slug" type="text" placeholder="url-slug (auto-generated)" class="w-full bg-slate-900/40 border border-slate-800 text-slate-400 font-mono rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-500/20 placeholder-slate-600 transition-all" />
      
      <div>
        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-2">Excerpt</label>
        <textarea id="excerpt" rows="2" placeholder="Write a short summary..." class="w-full bg-slate-900/40 border border-slate-800 text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-500/20 resize-none placeholder-slate-650 transition-all"></textarea>
      </div>
      
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit">Content (Visual Editor)</label>
          <span id="word-count" class="text-xs font-bold text-slate-550 font-outfit">0 words</span>
        </div>
        <div class="border border-slate-800 bg-slate-900/40 rounded-2xl overflow-hidden shadow-2xl backdrop-blur-sm">
          <!-- Rich Text Toolbar -->
          <div class="bg-slate-950/60 border-b border-slate-800 px-4 py-3 flex flex-wrap gap-1.5 items-center text-xs backdrop-blur-md">
            <div class="flex items-center gap-1 bg-slate-900/50 border border-slate-850 p-1 rounded-xl">
              <button type="button" id="btn-bold" class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white transition cursor-pointer" title="Bold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 5.25h6.75a3 3 0 013 3v0a3 3 0 01-3 3H6.75v-6zm0 6h7.5a3.375 3.375 0 013.375 3.375v0a3.375 3.375 0 01-3.375 3.375H6.75v-6.75z"/></svg>
              </button>
              <button type="button" id="btn-italic" class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white transition cursor-pointer" title="Italic">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 4.5h-7.5m7.5 0v3m0-3L12 19.5m0 0H4.5m7.5 0v-3"/></svg>
              </button>
              <button type="button" id="btn-underline" class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white transition cursor-pointer" title="Underline">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 3.75V11.25a5.25 5.25 0 11-10.5 0V3.75m0 16.5h10.5"/></svg>
              </button>
              <button type="button" id="btn-strike" class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white transition cursor-pointer" title="Strikethrough">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18"/></svg>
              </button>
            </div>
            
            <div class="flex items-center gap-1 bg-slate-900/50 border border-slate-850 p-1 rounded-xl">
              <button type="button" id="btn-h2" class="px-2.5 py-1.5 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white font-bold font-outfit text-[11px] transition cursor-pointer" title="Heading 2">H2</button>
              <button type="button" id="btn-h3" class="px-2.5 py-1.5 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white font-bold font-outfit text-[11px] transition cursor-pointer" title="Heading 3">H3</button>
              <button type="button" id="btn-p" class="px-2.5 py-1.5 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white font-bold font-outfit text-[11px] transition cursor-pointer" title="Paragraph">P</button>
            </div>
            
            <div class="flex items-center gap-1 bg-slate-900/50 border border-slate-850 p-1 rounded-xl">
              <button type="button" id="btn-ul" class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white transition cursor-pointer" title="Bullet List">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
              </button>
              <button type="button" id="btn-ol" class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white transition cursor-pointer" title="Numbered List">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
              </button>
            </div>
            
            <div class="flex items-center gap-1 bg-slate-900/50 border border-slate-850 p-1 rounded-xl">
              <button type="button" id="btn-link" class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white transition cursor-pointer" title="Add Link">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
              </button>
              <button type="button" id="btn-image" class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-white transition cursor-pointer" title="Add Image">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
              </button>
            </div>
            
            <div class="flex items-center gap-1 bg-slate-900/50 border border-slate-850 p-1 rounded-xl">
              <button type="button" id="btn-tip" class="px-2.5 py-1.5 rounded-lg bg-emerald-955/80 hover:bg-emerald-950 text-emerald-355 text-[11px] font-bold font-outfit transition cursor-pointer border border-emerald-900/20" title="Insert Tip Callout">💡 Tip</button>
              <button type="button" id="btn-warning" class="px-2.5 py-1.5 rounded-lg bg-amber-955/80 hover:bg-amber-950 text-amber-450 text-[11px] font-bold font-outfit transition cursor-pointer border border-amber-900/20" title="Insert Warning Callout">⚠️ Warning</button>
              <button type="button" id="btn-info" class="px-2.5 py-1.5 rounded-lg bg-blue-955/80 hover:bg-blue-900 text-blue-355 text-[11px] font-bold font-outfit transition cursor-pointer border border-blue-900/20" title="Insert Info Callout">ℹ️ Info</button>
              <button type="button" id="btn-step" class="px-2.5 py-1.5 rounded-lg bg-rose-955/80 hover:bg-rose-900 text-rose-355 text-[11px] font-bold font-outfit transition cursor-pointer border border-rose-900/20" title="Insert Step Block">🔢 Step</button>
            </div>
            
            <button type="button" id="btn-template" class="ml-auto px-3.5 py-1.5 rounded-xl bg-rose-600 hover:bg-rose-500 hover:shadow-lg hover:shadow-rose-600/10 text-white font-bold font-outfit transition cursor-pointer" title="Load Article Template">📄 Load Template</button>
          </div>
          
          <!-- Editor Content Area -->
          <div id="wysiwyg-editor" class="px-5 py-4 bg-slate-900/10 text-slate-200 min-h-[450px] overflow-y-auto"></div>
        </div>
      </div>
    </div>

    <!-- Sidebar Settings -->
    <div class="space-y-5">
      <div class="bg-slate-900/40 rounded-2xl border border-slate-850/60 p-5 shadow-xl backdrop-blur-sm">
        <h3 class="text-sm font-bold text-white mb-4 font-outfit">Post Settings</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-1.5">Category</label>
            <div class="relative">
              <select id="category" class="w-full bg-slate-950/40 border border-slate-800 text-white rounded-xl pl-4 pr-10 py-2.5 text-sm focus:outline-none focus:border-rose-500 appearance-none cursor-pointer font-outfit">
                <option value="AI Tools">AI Tools</option>
                <option value="SaaS Reviews">SaaS Reviews</option>
                <option value="Productivity">Productivity</option>
                <option value="Freelancing">Freelancing</option>
                <option value="Online Business">Online Business</option>
                <option value="CRM Software">CRM Software</option>
                <option value="Digital Marketing">Digital Marketing</option>
              </select>
              <svg class="w-4 h-4 text-slate-500 absolute right-3.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-1.5">Author</label>
            <input id="author" type="text" class="w-full bg-slate-950/40 border border-slate-800 text-white rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-rose-500 font-outfit" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-1.5">Tags (comma separated)</label>
            <input id="tags" type="text" placeholder="javascript, react, tutorial" class="w-full bg-slate-950/40 border border-slate-800 text-white rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-rose-500 font-outfit placeholder-slate-650" />
          </div>
        </div>
      </div>

      <div class="bg-slate-900/40 rounded-2xl border border-slate-850/60 p-5 shadow-xl backdrop-blur-sm">
        <h3 class="text-sm font-bold text-white mb-3 font-outfit">Featured Image</h3>
        <div class="space-y-3">
          <div class="flex gap-2">
            <input id="featured-image" type="url" placeholder="https://images.unsplash.com/..." class="flex-1 min-w-0 bg-slate-950/40 border border-slate-800 text-white rounded-xl px-3.5 py-2.5 text-xs focus:outline-none focus:border-rose-500 font-outfit placeholder-slate-650" />
            <label class="bg-slate-900 hover:bg-slate-800 border border-slate-800 hover:border-slate-700 text-slate-200 px-3.5 py-2.5 rounded-xl text-xs font-bold font-outfit flex items-center justify-center cursor-pointer transition-all whitespace-nowrap active:scale-95 select-none shrink-0">
              <span>Upload</span>
              <input id="featured-image-file" type="file" accept="image/*" class="hidden" />
            </label>
          </div>
          <div id="upload-progress-container" class="hidden w-full bg-slate-950 rounded-full h-1 overflow-hidden">
            <div id="upload-progress-bar" class="bg-rose-500 h-1 w-0 transition-all duration-150 shadow-[0_0_8px_rgba(244,63,94,0.6)]"></div>
          </div>
          <div id="image-preview" class="mt-3 hidden border border-slate-800 rounded-xl overflow-hidden relative">
            <img id="preview-img" src="" alt="Preview" class="w-full h-32 object-cover" />
          </div>
        </div>
      </div>

      <div class="bg-slate-900/40 rounded-2xl border border-slate-850/60 p-5 shadow-xl backdrop-blur-sm">
        <h3 class="text-sm font-bold text-white mb-4 font-outfit">SEO Details</h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-1.5">SEO Title</label>
            <input id="seo-title" type="text" placeholder="Leave blank to use post title" class="w-full bg-slate-950/40 border border-slate-800 text-white rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-rose-500 font-outfit placeholder-slate-650" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 font-outfit mb-1.5">Meta Description</label>
            <textarea id="seo-desc" rows="3" placeholder="Leave blank to use excerpt" class="w-full bg-slate-950/40 border border-slate-800 text-white rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-rose-500 resize-none font-outfit placeholder-slate-650"></textarea>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const postId = document.getElementById('editor')?.dataset.postId;

    import { Editor } from '@tiptap/core';
    import StarterKit from '@tiptap/starter-kit';
    import Link from '@tiptap/extension-link';
    import Image from '@tiptap/extension-image';
    import Underline from '@tiptap/extension-underline';
    import Placeholder from '@tiptap/extension-placeholder';

    // Helper for uploading files to Firebase Storage securely via backend API
    async function uploadFile(file: File, folder: string, onProgress?: (pct: number) => void): Promise<string> {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('folder', folder);

      return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/api/admin/upload');
        xhr.withCredentials = true;

        if (onProgress) {
          xhr.upload.onprogress = (event) => {
            if (event.lengthComputable) {
              const pct = (event.loaded / event.total) * 100;
              onProgress(pct);
            }
          };
        }

        xhr.onload = () => {
          if (xhr.status >= 200 && xhr.status < 300) {
            try {
              const response = JSON.parse(xhr.responseText);
              if (response.url) resolve(response.url);
              else reject(new Error(response.error || 'Upload failed'));
            } catch (err) {
              reject(new Error('Invalid response from upload API'));
            }
          } else {
            try {
              const response = JSON.parse(xhr.responseText);
              reject(new Error(response.error || `Upload failed: ${xhr.status}`));
            } catch (err) {
              reject(new Error(`Upload failed: ${xhr.status}`));
            }
          }
        };

        xhr.onerror = () => reject(new Error('Network error during upload'));
        xhr.send(formData);
      });
    }

    // Clean up previous editor instance on client HMR reloads
    if ((window as any).editorInstance) {
      (window as any).editorInstance.destroy();
    }

    // Initialize Tiptap Visual Rich Text Editor
    const editor = new Editor({
      element: document.querySelector('#wysiwyg-editor')!,
      extensions: [
        StarterKit,
        Underline,
        Link.configure({ openOnClick: false }),
        Image,
        Placeholder.configure({ placeholder: 'Write your post content visually here...' }),
      ],
      content: '',
      onUpdate({ editor }) {
        const text = editor.getText();
        const count = text.trim() ? text.trim().split(/\s+/).length : 0;
        document.getElementById('word-count')!.textContent = `${count} words`;
      }
    });
    (window as any).editorInstance = editor;

    // Toolbar Command Bindings
    document.getElementById('btn-bold')?.addEventListener('click', () => editor.chain().focus().toggleBold().run());
    document.getElementById('btn-italic')?.addEventListener('click', () => editor.chain().focus().toggleItalic().run());
    document.getElementById('btn-underline')?.addEventListener('click', () => editor.chain().focus().toggleUnderline().run());
    document.getElementById('btn-strike')?.addEventListener('click', () => editor.chain().focus().toggleStrike().run());
    document.getElementById('btn-h2')?.addEventListener('click', () => editor.chain().focus().toggleHeading({ level: 2 }).run());
    document.getElementById('btn-h3')?.addEventListener('click', () => editor.chain().focus().toggleHeading({ level: 3 }).run());
    document.getElementById('btn-p')?.addEventListener('click', () => editor.chain().focus().setParagraph().run());
    document.getElementById('btn-ul')?.addEventListener('click', () => editor.chain().focus().toggleBulletList().run());
    document.getElementById('btn-ol')?.addEventListener('click', () => editor.chain().focus().toggleOrderedList().run());
    document.getElementById('btn-link')?.addEventListener('click', () => {
      const previousUrl = editor.getAttributes('link').href;
      const url = window.prompt('Enter link URL:', previousUrl);
      if (url === null) return;
      if (url === '') { editor.chain().focus().extendMarkRange('link').unsetLink().run(); return; }
      editor.chain().focus().extendMarkRange('link').setLink({ href: url }).run();
    });
    document.getElementById('btn-image')?.addEventListener('click', () => {
      const choice = window.confirm("Click OK to upload an image from your device to Firebase Storage, or Cancel to paste an image URL instead.");
      if (choice) {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.onchange = async () => {
          const file = input.files?.[0];
          if (!file) return;

          showAlert('Uploading image to Firebase Storage...', 'success');
          try {
            const downloadUrl = await uploadFile(file, 'articles/content-images');
            editor.chain().focus().setImage({ src: downloadUrl }).run();
            showAlert('Image uploaded and inserted successfully!', 'success');
          } catch (err: any) {
            console.error('In-editor image upload failed:', err);
            showAlert(`Upload failed: ${err.message}`, 'error');
          }
        };
        input.click();
      } else {
        const url = window.prompt('Enter image URL:');
        if (url) editor.chain().focus().setImage({ src: url }).run();
      }
    });

    // Featured Image Upload handler
    const fileInput = document.getElementById('featured-image-file') as HTMLInputElement;
    fileInput?.addEventListener('change', async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      const progressContainer = document.getElementById('upload-progress-container')!;
      const progressBar = document.getElementById('upload-progress-bar')!;
      
      progressContainer.classList.remove('hidden');
      progressBar.style.width = '0%';

      try {
        const downloadUrl = await uploadFile(file, 'articles/featured-images', (pct) => {
          progressBar.style.width = `${pct}%`;
        });
        
        const featuredImageInput = document.getElementById('featured-image') as HTMLInputElement;
        featuredImageInput.value = downloadUrl;
        featuredImageInput.dispatchEvent(new Event('input'));
        
        showAlert('Featured image uploaded successfully to Firebase Storage!', 'success');
      } catch (err: any) {
        console.error('Featured image upload failed:', err);
        showAlert(`Upload failed: ${err.message}`, 'error');
      } finally {
        setTimeout(() => {
          progressContainer.classList.add('hidden');
        }, 1500);
      }
    });

    // Custom Editorial Callouts Injections
    document.getElementById('btn-tip')?.addEventListener('click', () => {
      editor.chain().focus().insertContent('<div class="tip-box"><p>💡 <strong>Tip:</strong> Enter recommendation here...</p></div><p></p>').run();
    });
    document.getElementById('btn-warning')?.addEventListener('click', () => {
      editor.chain().focus().insertContent('<div class="warning-box"><p>⚠️ <strong>Warning:</strong> Enter critical pitfall/mistake to avoid here...</p></div><p></p>').run();
    });
    document.getElementById('btn-info')?.addEventListener('click', () => {
      editor.chain().focus().insertContent('<div class="info-box"><p>ℹ️ <strong>Note:</strong> Enter extra context/data facts here...</p></div><p></p>').run();
    });
    document.getElementById('btn-step')?.addEventListener('click', () => {
      const number = window.prompt('Step Number (e.g. 1):', '1');
      if (number) {
        editor.chain().focus().insertContent(`<div class="step"><div class="step-number">${number}</div><div><h4>Step Title</h4><p>Step explanation here...</p></div></div><p></p>`).run();
      }
    });

    const ARTICLE_TEMPLATE_HTML = `
      <h2>Overview of the Topic</h2>
      <p>Write an engaging introduction hook here explaining the core problem and your solution. Emphasize keywords using the bold option or formatting options.</p>

      <div class="info-box">
        <p>ℹ️ <strong>Note:</strong> Enter interesting facts, market stats, or context regarding this topic here.</p>
      </div>

      <h2>Step-by-Step Implementation Guide</h2>

      <div class="step">
        <div class="step-number">1</div>
        <div>
          <h4>Establish Your First Step</h4>
          <p>Describe what the reader needs to do in this initial step. Provide actionable detail and clear instructions.</p>
        </div>
      </div>

      <div class="step">
        <div class="step-number">2</div>
        <div>
