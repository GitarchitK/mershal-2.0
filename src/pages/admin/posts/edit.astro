    document.getElementById('btn-template')?.addEventListener('click', () => {
      if (window.confirm("Are you sure you want to load the article template? This will replace your current editor content.")) {
        editor.commands.setContent(ARTICLE_TEMPLATE_HTML);
        
        // Auto-fill form details with professional placeholder content
        const titleInput = document.getElementById('title') as HTMLInputElement;
        if (titleInput && !titleInput.value) {
          titleInput.value = "How to Build a Low-Code SaaS Business Automation Workflow";
          titleInput.dispatchEvent(new Event('input'));
        }
        
        const excerptTextarea = document.getElementById('excerpt') as HTMLTextAreaElement;
        if (excerptTextarea && !excerptTextarea.value) {
          excerptTextarea.value = "Learn how to build a low-code SaaS business automation workflow to connect your tools, automate data pipes, and scale your business without touching a line of code.";
        }
        
        const tagsInput = document.getElementById('tags') as HTMLInputElement;
        if (tagsInput && !tagsInput.value) {
          tagsInput.value = "saas, productivity, automation, tutorial";
        }
        
        const featuredImageInput = document.getElementById('featured-image') as HTMLInputElement;
        if (featuredImageInput && !featuredImageInput.value) {
          featuredImageInput.value = "https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1200&q=80";
          featuredImageInput.dispatchEvent(new Event('input'));
        }
      }
    });

    async function loadPost() {
      if (!postId) return;
      const res = await fetch(`/api/admin/posts?id=${postId}`);
      if (!res.ok) { window.location.href = '/admin/posts'; return; }
      const post = await res.json();

      document.getElementById('loading')!.classList.add('hidden');
      const editorEl = document.getElementById('editor')!;
      editorEl.classList.remove('hidden');
      editorEl.style.display = 'grid';

      (document.getElementById('title') as HTMLInputElement).value = post.title || '';
      (document.getElementById('slug') as HTMLInputElement).value = post.slug || '';
      (document.getElementById('excerpt') as HTMLTextAreaElement).value = post.excerpt || '';
      (document.getElementById('author') as HTMLInputElement).value = post.author || 'Archit Karmakar';
      (document.getElementById('tags') as HTMLInputElement).value = (post.tags || []).join(', ');
      (document.getElementById('featured-image') as HTMLInputElement).value = post.featuredImage || '';
      (document.getElementById('seo-title') as HTMLInputElement).value = post.seoTitle || '';
      (document.getElementById('seo-desc') as HTMLTextAreaElement).value = post.seoDescription || '';
      (document.getElementById('category') as HTMLSelectElement).value = post.category || 'AI Tools';
      document.getElementById('post-slug-display')!.textContent = `/articles/${post.slug}`;
      (document.getElementById('view-post-link') as HTMLAnchorElement).href = `/articles/${post.slug}`;

      // Insert loaded post content directly into Tiptap
      editor.commands.setContent(post.content || '');

      if (post.featuredImage) {
        (document.getElementById('preview-img') as HTMLImageElement).src = post.featuredImage;
        document.getElementById('image-preview')!.classList.remove('hidden');
      }

      const text = (post.content || '').replace(/<[^>]*>/g, '');
      document.getElementById('word-count')!.textContent = `${text.trim() ? text.trim().split(/\s+/).length : 0} words`;
    }

    document.getElementById('featured-image')?.addEventListener('input', (e) => {
      const url = (e.target as HTMLInputElement).value;
      const preview = document.getElementById('image-preview')!;
      if (url) {
        (document.getElementById('preview-img') as HTMLImageElement).src = url;
        preview.classList.remove('hidden');
      } else {
        preview.classList.add('hidden');
      }
    });

    function showAlert(msg: string, type: 'success' | 'error') {
      const el = document.getElementById('alert')!;
      el.textContent = msg;
      el.className = `mb-5 p-4 rounded-lg text-sm font-medium ${type === 'success' ? 'bg-green-900/50 text-green-300 border border-green-700' : 'bg-red-900/50 text-red-300 border border-red-700'}`;
      el.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    async function updatePost(status: string) {
      const title = (document.getElementById('title') as HTMLInputElement).value.trim();
      if (!title) { showAlert('Title is required', 'error'); return; }

      const tags = (document.getElementById('tags') as HTMLInputElement).value.split(',').map((t: string) => t.trim()).filter(Boolean);
      const payload = {
        id: postId,
        title,
        slug: (document.getElementById('slug') as HTMLInputElement).value,
        excerpt: (document.getElementById('excerpt') as HTMLTextAreaElement).value,
        content: editor.getHTML(),
        category: (document.getElementById('category') as HTMLSelectElement).value,
        author: (document.getElementById('author') as HTMLInputElement).value,
        tags,
        featuredImage: (document.getElementById('featured-image') as HTMLInputElement).value,
        seoTitle: (document.getElementById('seo-title') as HTMLInputElement).value,
        seoDescription: (document.getElementById('seo-desc') as HTMLTextAreaElement).value,
        status,
      };

      const btnId = status === 'published' ? 'publish-btn' : 'save-draft';
      const btn = document.getElementById(btnId) as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Saving...';

      const res = await fetch('/api/admin/posts', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      const data = await res.json();

      if (res.ok) {
        showAlert('Post updated!', 'success');
      } else {
        showAlert(data.error || 'Failed to update', 'error');
      }
      btn.disabled = false;
      btn.textContent = status === 'published' ? 'Update & Publish' : 'Save Draft';
    }

    document.getElementById('publish-btn')?.addEventListener('click', () => updatePost('published'));
    document.getElementById('save-draft')?.addEventListener('click', () => updatePost('draft'));
    loadPost();
  </script>

