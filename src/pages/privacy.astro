---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BreakingNews from '../components/BreakingNews.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Privacy Policy - Mershal" description="Mershal Privacy Policy - Learn how we protect your data and privacy">
  <Header />
  <BreakingNews />
  
  <main class="container mx-auto px-4 py-8 pb-20 md:pb-8">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold mb-6">Privacy Policy</h1>
      <p class="text-gray-500 mb-8">Last updated: March 2026</p>

      <div class="prose prose-lg max-w-none">
        <p class="mb-6">
          At Mershal, we take your privacy seriously. This policy explains what information we collect and how we use it.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Information We Collect</h2>
        <ul class="list-disc pl-6 mb-6 space-y-2">
          <li><strong>Personal Information:</strong> When you contact us, we collect your name and email address</li>
          <li><strong>Analytics:</strong> We use anonymous analytics to understand how visitors use our site</li>
          <li><strong>Cookies:</strong> We use essential cookies to improve your experience</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">How We Use Your Information</h2>
        <ul class="list-disc pl-6 mb-6 space-y-2">
          <li>To respond to your messages and questions</li>
          <li>To improve our content based on visitor feedback</li>
          <li>To analyze site traffic and optimize user experience</li>
          <li>To send updates if you've subscribed to our newsletter</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Third-Party Services</h2>
        <p class="mb-4">
          We use the following third-party services that may collect data:
        </p>
        <ul class="list-disc pl-6 mb-6 space-y-2">
          <li><strong>Google Analytics:</strong> For site analytics</li>
          <li><strong>Google AdSense:</strong> For displaying advertisements</li>
          <li><strong>Firebase:</strong> For backend services</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Your Rights</h2>
        <p class="mb-4">You have the right to:</p>
        <ul class="list-disc pl-6 mb-6 space-y-2">
          <li>Request deletion of your personal data</li>
          <li>Opt-out of cookies</li>
          <li>Request access to your data</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Contact Us</h2>
        <p class="mb-4">
          If you have any questions about this privacy policy, please contact us at <a href="mailto:contact@mershal.in" class="text-red-600 hover:underline">contact@mershal.in</a>
        </p>
      </div>
    </div>
  </main>

  <Footer />
  <BottomNav />
</Layout>