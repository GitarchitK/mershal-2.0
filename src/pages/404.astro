---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Page Not Found - Mershal" description="The page you are looking for doesn't exist. Navigate back to our reviews and guides.">
  <Header />
  
  <main class="container mx-auto px-4 py-16 pb-24 md:pb-16 text-center font-sans text-slate-800">
    <div class="max-w-2xl mx-auto">
      <!-- 404 Icon -->
      <div class="mb-8">
        <div class="text-8xl mb-4 select-none">🤖</div>
        <h1 class="text-6xl font-serif font-black text-slate-950 mb-2">404</h1>
        <h2 class="text-xl font-bold text-slate-500 mb-6">Page Not Found</h2>
      </div>
      
      <!-- Error Message -->
      <div class="bg-slate-100 border border-slate-200 rounded-2xl p-6 mb-8 shadow-inner">
        <p class="text-slate-700 text-base mb-3 font-semibold">
          Sorry, the guide, review, or page you are looking for doesn't exist or has been relocated.
        </p>
        <p class="text-xs text-slate-400">
          Double-check the URL slug or browse our popular categories below.
        </p>
      </div>
      
      <!-- Action Buttons -->
      <div class="space-y-6">
        <a 
          href="/" 
          class="inline-block bg-primary-crimson hover:bg-primary-crimson/95 text-white px-8 py-3.5 rounded-xl font-bold text-sm transition shadow-sm"
        >
          🏠 Go to Homepage
        </a>
        
        <div class="flex flex-wrap justify-center gap-4 mt-6 text-xs uppercase font-extrabold tracking-wider">
          <a href="/category/ai-tools" class="text-primary-crimson hover:underline">AI Tools</a>
          <a href="/category/saas-reviews" class="text-primary-crimson hover:underline">SaaS Reviews</a>
          <a href="/category/productivity" class="text-primary-crimson hover:underline">Productivity</a>
          <a href="/category/online-business" class="text-primary-crimson hover:underline">Online Business</a>
        </div>
      </div>
      
      <!-- Debug Info (only in development) -->
      {import.meta.env.DEV && (
        <div class="mt-12 p-4 bg-slate-100 border border-slate-200 rounded-xl text-left text-xs font-mono">
          <h3 class="font-bold text-slate-700 mb-2">Debug Information:</h3>
          <p><strong>URL:</strong> {Astro.url.pathname}</p>
          <p><strong>Environment:</strong> Development</p>
          <p class="mt-2 text-slate-500">
            Make sure:
            <br />• Firebase has articles loaded
            <br />• The target post slug exists and status is 'published'
          </p>
        </div>
      )}
    </div>
  </main>
  
  <Footer />
  <BottomNav />
</Layout>