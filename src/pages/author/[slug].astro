---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { Image } from 'astro:assets';
import { adminDb } from '../../lib/firebase-admin';
import { getFeaturedImageUrl } from '../../lib/utils';

const { slug } = Astro.params;

let author: any = null;
let articles: any[] = [];

if (adminDb && slug) {
  try {
    // 1. Fetch author details by slug
    const snapshot = await adminDb.collection('authors')
      .where('slug', '==', slug)
      .limit(1)
      .get();
      
    if (!snapshot.empty) {
      const doc = snapshot.docs[0];
      author = { id: doc.id, ...doc.data() };
      
      // 2. Fetch articles authored by this author
      let articlesSnap = await adminDb.collection('articles')
        .where('status', '==', 'published')
        .get();
        
      let allDocs = articlesSnap.docs;
      
      // Load fallback legacy posts too if empty
      if (allDocs.length === 0) {
        const postsSnap = await adminDb.collection('posts')
          .where('status', '==', 'published')
          .get();
        allDocs = postsSnap.docs;
      }
      
      const allArticles = allDocs.map(doc => {
        const d = doc.data();
        return {
          id: doc.id,
          slug: d.slug || doc.id,
          title: d.title || '',
          excerpt: d.excerpt || '',
          featuredImage: getFeaturedImageUrl(d.featured_image || d.featuredImage),
          category: d.category || 'AI Tools',
          categorySlug: (d.category || 'ai-tools').toLowerCase().replace(/[^a-z0-9]+/g, '-'),
          author: d.author || 'Mershal Editorial Team',
          authorId: d.author_id || '',
          publishDate: d.publish_date?.toDate?.() || d.publishedAt?.toDate?.() || null,
          readingTime: d.readingTime || d.reading_time || 5,
        };
      });
      
      // Filter by author name or author ID
      articles = allArticles.filter(art => 
        art.authorId === author.id || 
        art.author.toLowerCase() === author.name.toLowerCase()
      ).sort((a, b) => {
        const aT = a.publishDate || new Date(0);
        const bT = b.publishDate || new Date(0);
        return bT.getTime() - aT.getTime();
      });
    }
  } catch (e) {
    console.error('Author page fetch error:', e);
  }
}

if (!author) {
  return Astro.redirect('/404');
}
---

<Layout
  title={`${author.name} — ${author.role} at Mershal`}
  description={author.bio}
>
  <Header />

  <!-- AdSense Leaderboard Placement -->
  <div class="container mx-auto px-4 max-w-7xl">
    <AdUnit type="header" />
  </div>

  <main class="bg-slate-50 min-h-screen pb-16 font-sans">
    
    <!-- Author Bio Card Block -->
    <section class="bg-white border-b border-slate-100 py-12 md:py-16">
      <div class="container mx-auto px-4 max-w-4xl">
        <nav class="flex items-center gap-2 text-xs font-semibold text-slate-400 font-sans mb-6">
          <a href="/" class="hover:text-primary-crimson transition-colors">Home</a>
          <span>›</span>
          <span class="text-slate-700">Authors</span>
          <span>›</span>
          <span class="text-slate-900 font-bold">{author.name}</span>
        </nav>
        
        <div class="flex flex-col md:flex-row items-center md:items-start gap-6 md:gap-8 text-center md:text-left">
          <!-- Avatar -->
          {author.avatar ? (
            <Image 
              src={author.avatar} 
              alt={author.name} 
              width={160} 
              height={160} 
              class="w-24 h-24 md:w-32 md:h-32 rounded-full object-cover border-2 border-slate-100 shadow-sm flex-shrink-0"
            />
          ) : (
            <div class="w-24 h-24 md:w-32 md:h-32 rounded-full bg-primary-crimson/10 text-primary-crimson flex items-center justify-center font-black text-3xl tracking-wider uppercase border border-primary-crimson/20 flex-shrink-0">
              {author.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
            </div>
          )}
          
          <div class="flex-1">
            <span class="inline-block bg-primary-crimson/5 text-primary-crimson text-xs font-black uppercase tracking-wider px-3 py-1 rounded-full mb-3">
              {author.role}
            </span>
            <h1 class="text-3xl md:text-4xl font-black font-serif text-slate-900 tracking-tight leading-none mb-4">
              {author.name}
            </h1>
            <p class="text-slate-600 text-sm md:text-base leading-relaxed max-w-2xl mb-5">
              {author.bio}
            </p>
            
            <!-- Social profile connections -->
            <div class="flex items-center justify-center md:justify-start gap-4">
              {author.twitter_url && (
                <a href={author.twitter_url} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-primary-crimson transition-colors" title="Follow on X / Twitter">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </a>
              )}
              {author.linkedin_url && (
                <a href={author.linkedin_url} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-primary-crimson transition-colors" title="Connect on LinkedIn">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Articles List Grid -->
    <div class="container mx-auto px-4 py-12 max-w-6xl">
      <div class="space-y-8">
        <h2 class="text-xs uppercase tracking-widest font-black text-slate-400">Guides & Articles By {author.name}</h2>
        
        {articles.length === 0 ? (
          <div class="bg-white border border-slate-100 shadow-sm rounded-2xl p-16 text-center text-slate-500">
            <h3 class="text-lg font-serif font-black text-slate-900 mb-2">No articles published by {author.name} yet</h3>
            <p class="text-slate-400 text-sm mb-6 max-w-md mx-auto">This author profile has no published guides yet. Come back later for reviews and comparisons.</p>
            <a href="/" class="inline-flex items-center justify-center bg-slate-900 text-white font-bold text-xs uppercase px-5 py-3 rounded-lg shadow-sm">← Back Home</a>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {articles.map(art => (
              <ArticleCard
                id={art.id}
                slug={art.slug}
                title={art.title}
                excerpt={art.excerpt}
                imageUrl={art.featuredImage}
                category={art.category}
                categorySlug={art.categorySlug}
                author={art.author}
                publishDate={art.publishDate}
                readingTime={art.readingTime}
              />
            ))}
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
