---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Terms of Service" description="Mershal Terms of Service - Rules and guidelines for using our website">
  <Header />
  
  <main class="container mx-auto px-4 py-8 pb-20 md:pb-8">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-gray-900 mb-8">Terms of Service</h1>
      
      <div class="bg-blue-50 border-l-4 border-blue-500 p-6 mb-8">
        <p class="text-blue-800">
          <strong>Last updated:</strong> March 17, 2026
        </p>
      </div>

      <div class="prose prose-lg max-w-none">
        <h2>1. Acceptance of Terms</h2>
        <p>By accessing and using Mershal ("the website"), you accept and agree to be bound by the terms and provision of this agreement.</p>

        <h2>2. Description of Service</h2>
        <p>Mershal is a technology and programming news website that provides:</p>
        <ul>
          <li>Technology news and innovations</li>
          <li>Programming tutorials and guides</li>
          <li>App reviews and recommendations</li>
          <li>Software development insights</li>
          <li>Tech industry analysis and trends</li>
        </ul>

        <h2>3. User Conduct</h2>
        <p>You agree not to use the website to:</p>
        <ul>
          <li>Post or transmit any unlawful, harmful, or offensive content</li>
          <li>Violate any applicable laws or regulations</li>
          <li>Infringe on intellectual property rights</li>
          <li>Distribute spam or unsolicited communications</li>
          <li>Attempt to gain unauthorized access to our systems</li>
        </ul>

        <h2>4. Intellectual Property</h2>
        <p>All content on this website, including text, graphics, logos, and images, is the property of Mershal or its content suppliers and is protected by copyright laws.</p>

        <h2>5. User-Generated Content</h2>
        <p>By submitting content to our website, you grant us a non-exclusive, royalty-free license to use, modify, and display such content.</p>

        <h2>6. Disclaimers</h2>
        <p>The information on this website is provided on an "as is" basis. We make no warranties, expressed or implied, regarding:</p>
        <ul>
          <li>The accuracy or completeness of information</li>
          <li>The availability of the website</li>
          <li>The fitness for any particular purpose</li>
        </ul>

        <h2>7. Limitation of Liability</h2>
        <p>Mershal shall not be liable for any direct, indirect, incidental, or consequential damages arising from your use of the website.</p>

        <h2>8. Advertising</h2>
        <p>Our website displays advertisements through Google AdSense and other advertising partners. We are not responsible for the content of advertisements or the practices of advertisers.</p>

        <h2>9. Privacy</h2>
        <p>Your privacy is important to us. Please review our Privacy Policy, which also governs your use of the website.</p>

        <h2>10. Modifications</h2>
        <p>We reserve the right to modify these terms at any time. Changes will be effective immediately upon posting on the website.</p>

        <h2>11. Termination</h2>
        <p>We may terminate or suspend your access to the website at any time, without prior notice, for conduct that we believe violates these terms.</p>

        <h2>12. Governing Law</h2>
        <p>These terms shall be governed by and construed in accordance with the laws of India.</p>

        <h2>13. Contact Information</h2>
        <p>If you have any questions about these terms, please contact us at:</p>
        <ul>
          <li>Email: legal@mershal.in</li>
          <li>Address: Kolkata, West Bengal, India</li>
        </ul>
      </div>
    </div>
  </main>
  
  <Footer />
  <BottomNav />
</Layout>

<style>
  .prose h2 {
    color: #1f2937;
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .prose p {
    margin-bottom: 1rem;
    line-height: 1.7;
  }
  
  .prose ul {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  
  .prose li {
    margin-bottom: 0.5rem;
  }
  
  .prose a {
    color: #dc2626;
    text-decoration: underline;
  }
  
  .prose a:hover {
    color: #b91c1c;
  }
</style>