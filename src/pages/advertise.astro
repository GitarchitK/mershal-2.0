---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout
  title="Advertise on Mershal — Reach Builders & SaaS Decision Makers"
  description="Promote your tool or platform on Mershal — an authority resource read by software buyers, agency owners, and digital marketers."
>
  <Header />

  <main class="bg-slate-50 pb-20 md:pb-8 font-sans text-slate-800">

    <!-- Hero -->
    <section class="relative bg-gradient-to-b from-slate-900 via-slate-900 to-slate-950 text-white border-b border-slate-850 py-16 overflow-hidden text-center">
      <div class="absolute right-0 top-0 w-[400px] h-[400px] bg-primary-crimson/10 rounded-full blur-3xl"></div>
      <div class="container mx-auto px-4 max-w-4xl relative z-10">
        <span class="inline-block bg-primary-crimson/25 border border-primary-crimson/50 text-primary-gold text-xs font-black uppercase tracking-widest px-3 py-1 rounded-full mb-4">Sponsorship Opportunities</span>
        <h1 class="text-4xl md:text-5xl font-serif font-black text-white mb-4 leading-tight">Reach Software Buyers &<br/>SaaS Decision Makers</h1>
        <p class="text-slate-300 text-lg max-w-2xl mx-auto mb-8 leading-relaxed">
          Mershal is a premium digital publication covering AI Tools, software reviews, and business automation guides. Get your platform in front of high-intent founders, freelancers, and agency builders.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="#plans" class="bg-primary-crimson hover:bg-primary-crimson/95 text-white px-6 py-3 rounded-lg font-bold text-sm transition shadow-md">View Rates</a>
          <a href="mailto:advertise@mershal.in" class="bg-slate-800 hover:bg-slate-700 text-white px-6 py-3 rounded-lg font-bold text-sm transition">Send Proposal</a>
        </div>
      </div>
    </section>

    <!-- Stats bar -->
    <section class="py-8 bg-white border-b border-slate-100 shadow-sm">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div class="p-2">
            <p class="text-2xl font-black text-primary-crimson mb-1">Founders</p>
            <p class="text-xs text-slate-400 uppercase font-bold tracking-wider">Target Audience</p>
          </div>
          <div class="p-2">
            <p class="text-2xl font-black text-primary-crimson mb-1">AI & SaaS</p>
            <p class="text-xs text-slate-400 uppercase font-bold tracking-wider">Focused Niches</p>
          </div>
          <div class="p-2">
            <p class="text-2xl font-black text-primary-crimson mb-1">SEO Niche</p>
            <p class="text-xs text-slate-400 uppercase font-bold tracking-wider">High intent traffic</p>
          </div>
          <div class="p-2">
            <p class="text-2xl font-black text-primary-crimson mb-1">Custom</p>
            <p class="text-xs text-slate-400 uppercase font-bold tracking-wider">Flexible formats</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Plans -->
    <section id="plans" class="py-14">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-serif font-black text-slate-900 mb-2">Advertising Plans</h2>
          <p class="text-slate-500">Choose the placement that matches your tool’s growth targets.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

          <!-- Plan 1 - Starter -->
          <div class="bg-white rounded-2xl border border-slate-200/60 p-7 flex flex-col hover:border-slate-350 transition duration-200 shadow-sm">
            <div class="mb-6">
              <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2">Tool Placement</p>
              <div class="flex items-end gap-1 mb-1">
                <span class="text-4xl font-black text-slate-900">₹299</span>
                <span class="text-slate-400 text-sm mb-1">/month</span>
              </div>
              <p class="text-sm text-slate-500">Perfect for indie hackers, new AI tools, or database listings.</p>
            </div>
            <ul class="space-y-3 mb-8 flex-1">
              {[
                'Standard sidebar banner placement',
                'Active listing under relevant tool category',
                'Ad stays live for 30 consecutive days',
                'Basic email traffic report',
              ].map(f => (
                <li class="flex items-start gap-2 text-sm text-slate-600">
                  <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="mailto:advertise@mershal.in?subject=Tool Placement Plan Enquiry" class="block text-center bg-slate-900 hover:bg-slate-800 text-white py-3 rounded-lg text-sm font-bold transition">
              Get Started
            </a>
          </div>

          <!-- Plan 2 - Growth (Popular) -->
          <div class="bg-slate-950 text-white rounded-2xl p-7 flex flex-col relative shadow-xl border border-primary-crimson/25 overflow-hidden">
            <div class="absolute right-0 top-0 w-24 h-24 bg-primary-crimson/20 rounded-full blur-xl"></div>
            <div class="absolute top-3 right-4">
              <span class="bg-primary-gold text-slate-950 text-[10px] font-black px-2.5 py-1 rounded-full uppercase tracking-wider">Best Seller</span>
            </div>
            <div class="mb-6 relative z-10">
              <p class="text-xs font-black text-primary-gold uppercase tracking-widest mb-2">Growth Review</p>
              <div class="flex items-end gap-1 mb-1">
                <span class="text-4xl font-black text-white">₹399</span>
                <span class="text-slate-400 text-sm mb-1">/month</span>
              </div>
              <p class="text-sm text-slate-300">Detailed hands-on tool review and guide integration.</p>
            </div>
            <ul class="space-y-3 mb-8 flex-1 relative z-10">
              {[
                'Everything in Tool Placement package',
                '1 Editorial review published on Mershal',
                '1 Callout box mentions in our trending guides',
                'Optimized internal linking to review page',
                'Performance and conversion analytics report',
              ].map(f => (
                <li class="flex items-start gap-2 text-sm text-slate-200">
                  <svg class="w-4 h-4 text-primary-gold mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="mailto:advertise@mershal.in?subject=Growth Review Plan Enquiry" class="block text-center bg-primary-crimson hover:bg-primary-crimson/95 text-white py-3 rounded-lg text-sm font-bold transition relative z-10">
              Choose Growth
            </a>
          </div>

          <!-- Plan 3 - Pro -->
          <div class="bg-white rounded-2xl border border-slate-200/60 p-7 flex flex-col hover:border-slate-350 transition duration-200 shadow-sm">
            <div class="mb-6">
              <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2">Authority Takeover</p>
              <div class="flex items-end gap-1 mb-1">
                <span class="text-4xl font-black text-slate-900">₹499</span>
                <span class="text-slate-400 text-sm mb-1">/month</span>
              </div>
              <p class="text-sm text-slate-500">Complete category-wide visibility and banner takeover.</p>
            </div>
            <ul class="space-y-3 mb-8 flex-1">
              {[
                'Everything in Growth Review package',
                'Dedicated homepage featured placement (14 days)',
                'Newsletter feature mentions (2x publications)',
                'Permanent follow-links inside review contents',
                'Custom design styling tweaks for your tool pages',
              ].map(f => (
                <li class="flex items-start gap-2 text-sm text-slate-600">
                  <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="mailto:advertise@mershal.in?subject=Authority Takeover Plan Enquiry" class="block text-center bg-slate-900 hover:bg-slate-800 text-white py-3 rounded-lg text-sm font-bold transition">
              Go Pro
            </a>
          </div>

        </div>

        <p class="text-center text-xs text-slate-400 mt-6 font-mono">All rates listed in Indian Rupees (INR). Payments processed securely via UPI or Bank Transfer.</p>
      </div>
    </section>

    <!-- Custom Integrations Info -->
    <section class="py-10 bg-white border-t border-b border-slate-100 shadow-inner">
      <div class="container mx-auto px-4 max-w-3xl">
        <h3 class="text-xl font-serif font-black text-slate-900 mb-4 text-center">Interested in custom arrangements?</h3>
        <p class="text-sm text-slate-600 leading-relaxed mb-4">
          If you are seeking native integration, newsletters, video tutorials, or tailored enterprise category takeovers, let us know! We customize sponsorships to match your exact budget and tracking APIs (e.g. UTM parameters, discount links, custom landing sections).
        </p>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="py-14 bg-slate-900 text-white relative overflow-hidden">
      <div class="absolute left-0 bottom-0 w-48 h-48 bg-primary-crimson/25 rounded-full blur-3xl"></div>
      <div class="container mx-auto px-4 max-w-2xl text-center relative z-10">
        <h2 class="text-3xl font-serif font-black text-white mb-3">Ready to promote your platform?</h2>
        <p class="text-slate-300 text-sm mb-8 leading-relaxed">Send over details about your platform, preferred package, and links. We will review it and follow up within 24 hours.</p>
        <a
          href="mailto:advertise@mershal.in"
          class="inline-flex items-center gap-2 bg-primary-crimson hover:bg-primary-crimson/95 text-white px-8 py-4 rounded-xl font-bold text-base transition shadow-md hover:scale-[1.01]"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
          advertise@mershal.in
        </a>
      </div>
    </section>

  </main>

  <Footer />
  <BottomNav />
</Layout>
